function loadSingleEmailTemplate(key) {
    const tpl = singleEmailTemplates[key];
    if (!tpl) return;
    document.getElementById('ce_subject').value = tpl.subject;
    document.getElementById('ce_body').value = tpl.body;
    showToast('info', 'Đã tải mẫu', `Mẫu "${key}" đã được áp dụng`);
}

async function sendSingleCustomerEmail() {
    const subject = document.getElementById('ce_subject').value.trim();
    const body = document.getElementById('ce_body').value.trim();
    if (!subject || !body) {
        showToast('warning', 'Thiếu thông tin', 'Vui lòng nhập đủ tiêu đề và nội dung');
        return;
    }
    if (!currentEmailRecipient || !currentEmailRecipient.uid) {
        showToast('error', 'Lỗi', 'Không xác định được khách hàng nhận');
        return;
    }
    const fd = new FormData();
    fd.append('userId', currentEmailRecipient.uid);
    fd.append('subject', subject);
    fd.append('body', body);
    const r = await fetch('/Home/SendCustomerEmail', { method:'POST', body: fd });
    if (r.ok) {
        closeModal('customerEmailModal');
        showToast('success', 'Đã gửi', `Đã gửi thông báo tới ${currentEmailRecipient.name} (hiển thị ở mục Thông báo của khách)`);
    } else showToast('error', 'Lỗi', 'Không gửi được');
}

// === XÓA KHÁCH HÀNG ===
let deletingCustomer = null;
function deleteCustomer(name) {
    deletingCustomer = name;
    document.getElementById('cd_name').textContent = name;
    document.getElementById('customerDeleteModal').classList.add('show');
}

function confirmDeleteCustomer() {
    closeModal('customerDeleteModal');
    if (!deletingCustomer) return;
    const name = deletingCustomer;
    const row = document.querySelector('tr[data-cust="' + name.replace(/"/g, '\\"') + '"]');
    if (!row) { deletingCustomer = null; return; }
    const uid = row.getAttribute('data-uid');
    const fd = new FormData(); fd.append('userId', uid);
    fetch('/Home/DeleteCustomer', { method: 'POST', body: fd })
        .then(r => r.ok ? r.json() : Promise.reject(r))
        .then(() => {
            row.style.transition = 'all 0.4s ease';
            row.style.opacity = '0';
            row.style.transform = 'translateX(40px)';
            setTimeout(() => row.remove(), 400);
            showToast('success', 'Đã xóa khách hàng', 'Tài khoản ' + name + ' đã bị xóa vĩnh viễn');
        })
        .catch(() => showToast('error', 'Lỗi', 'Không thể xóa khách hàng này'));
    deletingCustomer = null;
}

// === HẠN CHẾ TÀI KHOẢN ===
let restrictingCustomer = null;
function restrictCustomer(name, btn) {
    const row = document.querySelector('tr[data-cust="' + (name || '').replace(/"/g, '\\"') + '"]');
    if (!row) return;
    var locked = row.getAttribute('data-locked') === '1';
    restrictingCustomer = name;
    document.getElementById('cr_name').textContent = name;
    if (locked) {
        // Đang khóa → mở khóa
        document.getElementById('cr_title').textContent = 'Mở khóa tài khoản?';
        document.getElementById('cr_desc').innerHTML = 'Tài khoản "<span style="color:#1a1a1a; font-weight:500;">' + name + '</span>" sẽ được mở khóa và có thể đăng nhập, đặt hàng trở lại.';
        document.getElementById('cr_icon').style.background = '#e6f7ef';
        document.getElementById('cr_icon').style.color = '#2eb872';
        document.getElementById('cr_icon').innerHTML = '<i class="ti ti-lock-open"></i>';
        document.getElementById('cr_action_text').textContent = 'Mở khóa ngay';
        document.querySelector('#customerRestrictModal .btn-primary').style.background = '#2eb872';
    } else {
        // Đang hoạt động → khóa
        document.getElementById('cr_title').textContent = 'Hạn chế tài khoản?';
        document.getElementById('cr_desc').innerHTML = 'Tài khoản "<span style="color:#1a1a1a; font-weight:500;">' + name + '</span>" sẽ bị tạm khóa, không thể đăng nhập và đặt hàng. Bạn có thể mở lại bất cứ lúc nào.';
        document.getElementById('cr_icon').style.background = '#fff4e0';
        document.getElementById('cr_icon').style.color = '#d18800';
        document.getElementById('cr_icon').innerHTML = '<i class="ti ti-lock"></i>';
        document.getElementById('cr_action_text').textContent = 'Hạn chế ngay';
        document.querySelector('#customerRestrictModal .btn-primary').style.background = '#d18800';
    }
    document.getElementById('customerRestrictModal').classList.add('show');
}

function restrictCustomerFromView() {
    if (!currentViewCustomer) return;
    closeModal('customerViewModal');
    setTimeout(() => restrictCustomer(currentViewCustomer, null), 200);
}

function confirmRestrictCustomer() {
    closeModal('customerRestrictModal');
    if (!restrictingCustomer) return;
    const name = restrictingCustomer;
    const row = document.querySelector('tr[data-cust="' + name.replace(/"/g, '\\"') + '"]');
    if (!row) { restrictingCustomer = null; return; }
    const uid = row.getAttribute('data-uid');
    const fd = new FormData(); fd.append('userId', uid);
    fetch('/Home/ToggleUserActive', { method: 'POST', body: fd })
        .then(r => r.ok ? r.json() : Promise.reject(r))
        .then(d => {
            row.setAttribute('data-locked', d.locked ? '1' : '0');
            row.style.opacity = d.locked ? '0.6' : '1';
            row.style.background = d.locked ? '#fffafa' : '';
            // Cập nhật nút hạn chế/mở khóa trong dòng
            const rb = row.querySelector('.restrict-btn');
            if (rb) {
                rb.title = d.locked ? 'Mở khóa tài khoản' : 'Hạn chế tài khoản';
                rb.style.color = d.locked ? '#d18800' : '';
                rb.innerHTML = d.locked ? '<i class="ti ti-lock-open"></i>' : '<i class="ti ti-lock"></i>';
            }
            showToast('success', d.locked ? 'Đã hạn chế' : 'Đã mở khóa', 'Tài khoản ' + name + (d.locked ? ' đã bị tạm khóa' : ' có thể hoạt động trở lại'));
        })
        .catch(() => showToast('error', 'Lỗi', 'Không thực hiện được'));
    restrictingCustomer = null;
}

// === XUẤT DANH SÁCH KH ===
function exportCustomers() {
    let csv = 'Họ tên,Email,Số điện thoại,Hạng,Số đơn,Ngày tham gia,Trạng thái\n';
    document.querySelectorAll('#customersTableBody tr[data-cust]').forEach(function (row) {
        var name = row.getAttribute('data-cust');
        var email = (row.querySelector('.tbl-customer-email')?.textContent || '').trim();
        var phone = (row.children[1]?.textContent || '').trim();
        var tier = (row.querySelector('.tier-badge')?.textContent || '').trim();
        var orders = (row.children[3]?.textContent || '').trim();
        var joindate = (row.children[5]?.textContent || '').trim();
        var status = row.getAttribute('data-locked') === '1' ? 'Đã hạn chế' : 'Hoạt động';
        csv += `${name},${email},${phone},${tier},${orders},${joindate},${status}\n`;
    });
    const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `MONOWEAR_KhachHang_${new Date().toISOString().slice(0,10)}.csv`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('success','Đã xuất danh sách', a.download + ' đã tải xuống');
}
</script>


