async function sendBulkEmail() {
    const subject = document.getElementById('emailSubject').value.trim();
    const body = document.getElementById('emailBody').value.trim();
    if (!subject || !body) { showToast('warning','Thiếu nội dung','Nhập tiêu đề và nội dung email'); return; }
    const fd = new FormData();
    fd.append('subject', subject);
    fd.append('body', body);
    fd.append('toAll', 'true');
    const r = await fetch('/Home/SendCustomerEmail', { method:'POST', body: fd });
    if (r.ok) {
        const d = await r.json();
        closeModal('emailModal');
        showToast('success','Đã gửi!', `Đã gửi thông báo tới ${d.count} khách hàng (hiển thị ở mục Thông báo của khách)`);
    } else showToast('error','Lỗi','Không gửi được');
}

