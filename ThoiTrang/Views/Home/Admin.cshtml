    <!-- ===== MODAL CHI TIẾT ĐƠN HÀNG (ADMIN) ===== -->
    <div id="adminOrderModal" style="display:none;position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,0.55);align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:18px;padding:32px;width:min(600px,95vw);max-height:90vh;overflow-y:auto;position:relative;">
            <button onclick="closeAdminOrderModal()" style="position:absolute;top:16px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#666;"><i class="ti ti-x"></i></button>
            <div style="font-size:18px;font-weight:700;margin-bottom:4px;" id="aoCode">—</div>
            <div style="display:flex;gap:10px;align-items:center;margin-bottom:20px;flex-wrap:wrap;">
                <span id="aoStatus" style="font-size:12px;padding:4px 12px;border-radius:999px;background:#f0f0ec;font-weight:600;"></span>
                <span id="aoPayStatus" style="font-size:12px;padding:4px 12px;border-radius:999px;background:#f0f0ec;font-weight:600;"></span>
                <span id="aoDate" style="color:#888;font-size:13px;"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;">
                <div style="background:#fafafa;border-radius:10px;padding:14px;font-size:13px;line-height:1.6;">
                    <div style="color:#888;font-size:12px;margin-bottom:4px;">NGƯỜI NHẬN</div>
                    <div><strong id="aoName">—</strong></div>
                    <div id="aoPhone" style="color:#666;"></div>
                    <div id="aoAddr" style="color:#666;margin-top:2px;"></div>
                </div>
                <div style="background:#fafafa;border-radius:10px;padding:14px;font-size:13px;line-height:1.6;">
                    <div style="color:#888;font-size:12px;margin-bottom:4px;">GIAO HÀNG &amp; THANH TOÁN</div>
                    <div>Vận chuyển: <strong id="aoShipMethod">—</strong></div>
                    <div>Thanh toán: <strong id="aoPayMethod">—</strong></div>
                    <div id="aoNote" style="color:#888;font-style:italic;margin-top:2px;"></div>
                </div>
            </div>

            <div style="font-size:13px;color:#888;margin-bottom:6px;">SẢN PHẨM</div>
            <div id="aoItems" style="margin-bottom:18px;"></div>

            <div style="border-top:1px solid #f0f0ec;padding-top:14px;font-size:14px;display:flex;flex-direction:column;gap:6px;">
                <div style="display:flex;justify-content:space-between;"><span style="color:#888;">Tạm tính</span><span id="aoSubtotal">—</span></div>
                <div id="aoVoucherRow" style="display:flex;justify-content:space-between;"><span style="color:#888;">Giảm voucher <span id="aoVoucherCode" style="color:#aaa;"></span></span><span id="aoVoucherDiscount" style="color:#d4537e;">—</span></div>
                <div style="display:flex;justify-content:space-between;"><span style="color:#888;">Phí vận chuyển</span><span id="aoShipping">—</span></div>
                <div style="display:flex;justify-content:space-between;font-weight:700;font-size:16px;border-top:1px solid #f0f0ec;padding-top:10px;margin-top:4px;">
                    <span>Tổng cộng</span><span id="aoTotal" style="color:#d4537e;">—</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== MODAL THÊM/SỬA COMBO ===== -->
    <div id="comboModal" style="display:none;position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,0.55);align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:18px;padding:32px;width:min(560px,95vw);max-height:90vh;overflow-y:auto;position:relative;">
            <button onclick="closeComboModal()" style="position:absolute;top:16px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#666;"><i class="ti ti-x"></i></button>
            <div style="font-size:18px;font-weight:700;margin-bottom:18px;" id="comboModalTitle">Tạo combo</div>
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div>
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Tên combo</label>
                    <input type="text" id="cb-name" placeholder="VD: Combo Smart Casual" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                </div>
                <div>
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Mô tả</label>
                    <input type="text" id="cb-desc" placeholder="Mô tả ngắn" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                </div>
                <div style="display:flex;gap:10px;">
                    <div style="flex:1;">
                        <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Giá combo (₫)</label>
                        <input type="number" id="cb-price" min="0" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                    </div>
                    <div style="flex:1;">
                        <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Giá gốc (₫) <span style="color:#aaa;font-weight:400;">tự tính nếu để trống</span></label>
                        <input type="number" id="cb-oldprice" min="0" placeholder="0" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                    </div>
                </div>
                <div>
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Nhãn</label>
                    <select id="cb-badge" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;">
                        <option value="">Không có</option>
                        <option value="fire">🔥 Bán chạy</option>
                        <option value="new">🎁 Combo mới</option>
                    </select>
                </div>
                <div>
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Sản phẩm trong combo</label>
                    <div id="cb-items" style="display:flex;flex-direction:column;gap:8px;"></div>
                    <button type="button" onclick="addComboItemRow()" style="margin-top:8px;background:#fff;border:1.5px dashed #d4537e;color:#d4537e;padding:8px 14px;border-radius:8px;cursor:pointer;font-size:13px;"><i class="ti ti-plus"></i> Thêm sản phẩm</button>
                </div>
                <button onclick="saveCombo()" id="cb-saveBtn" style="background:#1a1a1a;color:#fff;border:none;padding:12px;border-radius:10px;cursor:pointer;font-size:14px;font-weight:600;margin-top:4px;">Lưu combo</button>
            </div>
