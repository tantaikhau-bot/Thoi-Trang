        let lastStatsData = null;
        async function loadStats(period) {
            try {
                const r = await fetch('/Home/GetStats?period=' + encodeURIComponent(period));
                if (!r.ok) return;
                const d = await r.json();
                lastStatsData = d;
                const fmt = v => v >= 1000000 ? (v/1000000).toFixed(1).replace('.0','') + 'M₫' : (v >= 1000 ? Math.round(v/1000) + 'K₫' : v.toLocaleString('vi-VN') + '₫');
                document.getElementById('st_revenue').textContent = fmt(d.revenue);
                document.getElementById('st_orders').textContent = d.orderCount;
                document.getElementById('st_newcust').textContent = d.newCustomers;
                document.getElementById('st_aov').textContent = fmt(d.aov);
                document.getElementById('st_chartLabel').textContent = d.label;
                // Vẽ biểu đồ
                const chartEl = document.getElementById('st_chart');
                const max = Math.max(...d.chart.map(c => c.value), 1);
                const fmtM = v => v >= 1000000 ? (v/1000000).toFixed(1).replace('.0','') + 'M' : (v >= 1000 ? Math.round(v/1000) + 'K' : v);
                // Nếu nhiều cột (>15) ẩn label giá trị cho gọn
                const dense = d.chart.length > 15;
                chartEl.innerHTML = d.chart.map((c, i) => {
                    let h = max > 0 ? Math.round(c.value / max * 100) : 0;
                    if (h < 2 && c.value > 0) h = 2;
                    const muted = i === d.chart.length - 1 ? ' muted' : '';
                    const valLabel = (dense && c.value === 0) ? '' : `<span class="chart-bar-value">${fmtM(c.value)}</span>`;
                    return `<div class="chart-bar-wrap"><div class="chart-bar${muted}" style="height:${h}%">${valLabel}</div><span class="chart-bar-label">${c.label}</span></div>`;
                }).join('');
            } catch (e) { console.error(e); }
        }

