                                <thead><tr><th>MÃ ĐƠN</th><th>KHÁCH HÀNG</th><th>TỔNG</th><th>TRẠNG THÁI</th></tr></thead>
                                <tbody>
                                    @{
                                        var recent = ViewBag.RecentOrders as List<ThoiTrang.Models.Entities.Order>;
                                    }
                                    @if (recent != null && recent.Count > 0)
