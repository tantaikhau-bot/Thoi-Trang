                                @{
                                    var topProducts = ViewBag.TopProducts as System.Collections.IEnumerable;
                                    string[] topBgs = { "bg-cream", "bg-dark dark", "bg-blue dark", "bg-gray", "bg-brown dark" };
                                    int tpRank = 0;
                                    bool hasTop = false;
                                }
                                @if (topProducts != null)
                                {
                                    foreach (dynamic tp in topProducts)
                                    {
                                        hasTop = true;
                                        tpRank++;
                                        var tname = ((string)tp.Name ?? "").ToLower();
                                        var ticon = "ti-shirt";
                                        if (tname.Contains("giày") || tname.Contains("sneaker")) ticon = "ti-shoe";
                                        else if (tname.Contains("quần") || tname.Contains("kaki") || tname.Contains("jean") || tname.Contains("váy") || tname.Contains("đầm")) ticon = "ti-hanger";
                                        else if (tname.Contains("túi")) ticon = "ti-shopping-bag";
                                        else if (tname.Contains("hoodie") || tname.Contains("khoác") || tname.Contains("bomber")) ticon = "ti-shirt-sport";
                                        var rankCls = tpRank <= 3 ? "gold" : "";
                                        <div class="top-item" style="cursor:pointer;" onclick="window.open('/Home/CTSP/@tp.ProductId','_blank')">
                                            <div class="top-rank @rankCls">@tpRank</div>
                                            <div class="top-img @topBgs[(tpRank - 1) % 5]"><i class="ti @ticon"></i></div>
                                            <div class="top-info">
                                                <div class="top-name">@tp.Name</div>
                                                <div class="top-meta">@(((decimal)tp.Price).ToString("#,##0"))₫</div>
                                            </div>
                                            <div class="top-sold">@(((int)tp.SoldCount) > 0 ? "+" + ((int)tp.SoldCount).ToString("#,##0") : "0")</div>
                                        </div>
                                    }
                                }
