            font-size: 12px; font-weight: 600; cursor: pointer;
            transition: all 0.2s;
        }
        .badge-opt[data-badge="new"].active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
        .badge-opt[data-badge="sale"].active { background: #d4537e; color: #fff; border-color: #d4537e; }
        .badge-opt[data-badge="bestseller"].active { background: #1a6cf0; color: #fff; border-color: #1a6cf0; }
