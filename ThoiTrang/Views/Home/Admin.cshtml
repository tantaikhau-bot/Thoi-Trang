let openPanel = null;

function openSidePanel(id) {
    if (openPanel && openPanel !== id) closeSidePanel(openPanel);
    const panel = document.getElementById(id);
    if (!panel) return;
    panel.classList.add('open');
    document.getElementById('spBackdrop').style.display = 'block';
    openPanel = id;
}

