        .variant-table input[type="number"] {
            width: 80px; padding: 5px 8px; border: 1px solid #e8e8e4;
            border-radius: 6px; font-size: 12px; font-family: inherit; outline: none;
        }
        .variant-table input[type="number"]:focus { border-color: #1a1a1a; }
        .color-swatch { display: inline-block; width: 14px; height: 14px; border-radius: 50%; margin-right: 6px; vertical-align: middle; border: 1px solid rgba(0,0,0,0.1); }

        /* Import stock modal */
        .import-row {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 0; border-bottom: 1px solid #f5f5f3;
        }
        .import-row:last-of-type { border-bottom: none; }
        .import-row-info { flex: 1; }
        .import-row-name { font-size: 13px; font-weight: 500; }
        .import-row-meta { font-size: 11px; color: #999; margin-top: 2px; }
        .import-qty { width: 80px; padding: 7px 10px; border: 1.5px solid #e8e8e4; border-radius: 8px; font-size: 13px; font-family: inherit; outline: none; text-align: center; }
        .import-qty:focus { border-color: #1a1a1a; }
        .import-current { font-size: 12px; color: #888; min-width: 60px; text-align: right; }
        .import-summary {
            background: #f5f5f3; border-radius: 8px;
            padding: 12px 16px; margin-top: 14px;
