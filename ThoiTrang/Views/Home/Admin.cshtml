                                        {
                                            var (cls, ic, txt) = o.OrderStatus switch
                                            {
                                                "Completed" => ("status-delivered", "ti-circle-check", "Hoàn tất"),
                                                "Shipping" => ("status-shipping", "ti-truck", "Đang giao"),
                                                "Confirmed" => ("status-shipping", "ti-circle-check", "Đã xác nhận"),
                                                "Cancelled" => ("status-pending", "ti-x", "Đã hủy"),
                                                _ => ("status-pending", "ti-clock", "Chờ xử lý")
                                            };
                                            <tr>
                                                <td><strong>#@o.OrderCode</strong></td>
                                                <td>@o.ReceiverName</td>
                                                <td><strong>@o.TotalAmount.ToString("#,##0")₫</strong></td>
                                                <td><span class="tbl-status @cls"><i class="ti @ic"></i>@txt</span></td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="4" style="text-align:center;color:#999;">Chưa có đơn hàng</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="card">
