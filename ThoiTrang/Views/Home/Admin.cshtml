let eventsData = [];
function loadEvents() {
    fetch('/Home/GetEvents').then(r => r.ok ? r.json() : []).then(list => {
        eventsData = list.map(e => ({ id: e.id, day: e.day, month: e.month, title: e.title, meta: e.meta || '', tags: (e.tags || '').split(',').filter(Boolean), status: e.status }));
        renderEvents();
        updateEventsBadge();
    }).catch(() => {});
}

function renderEvents() {
    const list = document.getElementById('eventsList');
    list.innerHTML = eventsData.map((e, idx) => `
        <div class="ev-item" data-idx="${idx}">
            <div class="ev-date-box"><div class="ev-date-day">${e.day}</div><div class="ev-date-mo">${e.month}</div></div>
            <div class="ev-info">
                <div class="ev-title">${e.title}</div>
                <div class="ev-meta">${e.meta}</div>
                <div class="ev-tags">
                    ${e.tags.map(t=>`<span class="ev-tag ${t}">${t==='sale'?'🔥 Sale':t==='email'?'📧 Email':t==='voucher'?'🎟 Voucher':'🖼 Banner'}</span>`).join('')}
                    <span class="ev-tag ${e.status}">${e.status==='scheduled'?'✅ Đã lên lịch':e.status==='active'?'🟢 Đang chạy':'📝 Nháp'}</span>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:4px;flex-shrink:0;">
                <button class="action-btn" title="Sửa" onclick="editEvent(${idx})"><i class="ti ti-pencil"></i></button>
                <button class="action-btn" title="${e.status==='active'?'Tạm dừng':'Kích hoạt'}" onclick="toggleEventStatus(${idx})"><i class="ti ti-${e.status==='active'?'player-pause':'player-play'}"></i></button>
                <button class="action-btn danger" title="Xóa" onclick="deleteEvent(${idx})"><i class="ti ti-trash"></i></button>
            </div>
        </div>`).join('') + `
        <div class="ev-add-form">
            <h4><i class="ti ti-plus" style="color:#d4537e;"></i> THÊM SỰ KIỆN NHANH</h4>
            <div style="display:flex;flex-direction:column;gap:8px;">
                <input type="text" class="form-input" placeholder="Tên sự kiện..." style="font-size:13px;" id="quickEvName"/>
                <input type="datetime-local" class="form-input" style="font-size:13px;" id="quickEvTime"/>
                <select class="form-input" style="font-size:13px;" id="quickEvAction">
                    <option>Kích hoạt voucher</option>
                    <option>Gửi email hàng loạt</option>
                    <option>Đăng banner sale</option>
                    <option>Thay đổi giá</option>
                </select>
                <button class="btn btn-primary" style="width:100%;justify-content:center;" onclick="addQuickEvent()"><i class="ti ti-calendar-plus"></i>Thêm sự kiện</button>
            </div>
        </div>`;
}

// === Sửa sự kiện ===
let editingEventIdx = -1;
function editEvent(idx) {
    const e = eventsData[idx];
    if (!e) return;
    editingEventIdx = idx;
    document.getElementById('evEditName').value = e.title;
    document.getElementById('evEditMeta').value = e.meta || '';
    // Reconstruct datetime from day + month
    const monthNum = parseInt(e.month.replace(/T/, '').split('/')[0]);
    const yearShort = e.month.split('/')[1];
    const year = '20' + yearShort;
    const dateStr = year + '-' + String(monthNum).padStart(2,'0') + '-' + e.day + 'T00:00';
    document.getElementById('evEditTime').value = dateStr;
    document.getElementById('evEditStatus').value = e.status;
    // Tags checkboxes
    document.querySelectorAll('.ev-edit-tag').forEach(cb => cb.checked = e.tags.includes(cb.value));
    document.getElementById('eventEditModal').classList.add('show');
}

function saveEditEvent() {
    if (editingEventIdx < 0) return;
    const name = document.getElementById('evEditName').value.trim();
    const meta = document.getElementById('evEditMeta').value.trim();
    const time = document.getElementById('evEditTime').value;
    const status = document.getElementById('evEditStatus').value;
    if (!name) { showToast('warning','Thiếu tên','Vui lòng nhập tên sự kiện'); return; }
    const tags = Array.from(document.querySelectorAll('.ev-edit-tag:checked')).map(cb => cb.value);
    if (tags.length === 0) { showToast('warning','Thiếu hành động','Chọn ít nhất 1 hành động tự động'); return; }
    const ev = eventsData[editingEventIdx];
    const fd = new FormData();
    fd.append('id', ev.id);
    fd.append('title', name);
    fd.append('meta', meta || 'Tự động kích hoạt');
    fd.append('eventDate', time || '');
    fd.append('tags', tags.join(','));
    fd.append('status', status);
    fetch('/Home/UpdateEvent', { method:'POST', body: fd })
        .then(r => r.ok ? r.json() : Promise.reject(r))
        .then(() => { closeModal('eventEditModal'); loadEvents(); showToast('success','Đã cập nhật', name + ' đã được lưu'); editingEventIdx = -1; })
        .catch(() => showToast('error','Lỗi','Không lưu được sự kiện'));
}

// === Xóa sự kiện (có xác nhận) ===
let deletingEventIdx = -1;
function deleteEvent(idx) {
    deletingEventIdx = idx;
    const e = eventsData[idx];
    document.getElementById('evDeleteName').textContent = e.title;
    document.getElementById('eventDeleteModal').classList.add('show');
}

function confirmDeleteEvent() {
    closeModal('eventDeleteModal');
    if (deletingEventIdx < 0) return;
    const ev = eventsData[deletingEventIdx];
    const fd = new FormData(); fd.append('id', ev.id);
    fetch('/Home/DeleteEvent', { method:'POST', body: fd })
        .then(r => r.ok ? r.json() : Promise.reject(r))
        .then(() => { deletingEventIdx = -1; loadEvents(); showToast('success','Đã xóa', '"' + ev.title + '" đã bị xóa khỏi lịch'); })
        .catch(() => showToast('error','Lỗi','Không xóa được sự kiện'));
}

// === Toggle status ===
function toggleEventStatus(idx) {
    const e = eventsData[idx];
    if (!e) return;
    const fd = new FormData(); fd.append('id', e.id);
    fetch('/Home/ToggleEventStatus', { method:'POST', body: fd })
        .then(r => r.ok ? r.json() : Promise.reject(r))
        .then(d => { loadEvents(); showToast(d.status === 'active' ? 'success' : 'info', d.status === 'active' ? 'Đã kích hoạt' : 'Đã tạm dừng', e.title); })
        .catch(() => showToast('error','Lỗi','Không đổi được trạng thái'));
}

function addQuickEvent() {
    const name = document.getElementById('quickEvName').value.trim();
    const time = document.getElementById('quickEvTime').value;
    if (!name) { showToast('warning','Thiếu thông tin','Vui lòng nhập tên sự kiện'); return; }
    const fd = new FormData();
    fd.append('title', name);
    fd.append('meta', document.getElementById('quickEvAction').value);
    fd.append('eventDate', time || '');
    fd.append('tags', 'sale');
    fd.append('status', 'scheduled');
    fetch('/Home/AddEvent', { method:'POST', body: fd })
        .then(r => r.ok ? r.json() : Promise.reject(r))
        .then(() => { document.getElementById('quickEvName').value=''; loadEvents(); showToast('success','Đã thêm sự kiện', name + ' đã được lên lịch'); })
        .catch(() => showToast('error','Lỗi','Không thêm được sự kiện'));
}

function updateEventsBadge() {
    const scheduled = eventsData.filter(e=>e.status==='scheduled').length;
    document.getElementById('eventsBadge').textContent = scheduled;
}

