        // ===== Phân trang client-side cho bảng Admin =====
        const PAGE_SIZE = 10;
        function setupPagination(pagiEl) {
            const panel = pagiEl.closest('.panel');
            if (!panel) return;
            const tbody = panel.querySelector('table.data-table tbody');
            if (!tbody) return;
            // Chỉ lấy dòng dữ liệu thật (bỏ dòng "trống/colspan")
            const allRows = Array.from(tbody.querySelectorAll('tr')).filter(tr => !tr.querySelector('td[colspan]'));
            const totalPages = Math.ceil(allRows.length / PAGE_SIZE);
            if (totalPages <= 1) { pagiEl.innerHTML = ''; allRows.forEach(r => r.style.display = ''); return; }

            let current = 1;
            function render() {
                allRows.forEach((r, i) => {
                    r.style.display = (i >= (current - 1) * PAGE_SIZE && i < current * PAGE_SIZE) ? '' : 'none';
                });
                let html = `<button class="page-btn" ${current === 1 ? 'disabled' : ''} data-go="prev"><i class="ti ti-chevron-left"></i></button>`;
                for (let p = 1; p <= totalPages; p++) {
                    if (p === 1 || p === totalPages || Math.abs(p - current) <= 1) {
                        html += `<button class="page-btn ${p === current ? 'active' : ''}" data-go="${p}">${p}</button>`;
                    } else if (p === current - 2 || p === current + 2) {
                        html += `<button class="page-btn" disabled>...</button>`;
                    }
                }
                html += `<button class="page-btn" ${current === totalPages ? 'disabled' : ''} data-go="next"><i class="ti ti-chevron-right"></i></button>`;
                pagiEl.innerHTML = html;
                pagiEl.querySelectorAll('.page-btn[data-go]').forEach(b => {
                    b.addEventListener('click', () => {
                        const go = b.dataset.go;
                        if (go === 'prev' && current > 1) current--;
                        else if (go === 'next' && current < totalPages) current++;
                        else if (go !== 'prev' && go !== 'next') current = parseInt(go);
                        render();
                    });
                });
            }
            render();
        }
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.pagination[data-pagi]').forEach(setupPagination);
        });

