.chat-av {
    width:40px; height:40px; border-radius:50%; flex-shrink:0;
    display:flex; align-items:center; justify-content:center;
    font-size:15px; font-weight:600; color:#fff;
}
.chat-conv-info { flex:1; min-width:0; }
.chat-conv-name { font-size:13px; margin-bottom:2px; }
.chat-conv-preview { font-size:12px; color:#888; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.chat-conv-time { font-size:11px; color:#bbb; flex-shrink:0; }
/* active chat */
.chat-window { display:none; flex-direction:column; height:100%; }
.chat-window.active { display:flex; }
.chat-conv-list-wrap { flex:1; overflow-y:auto; }
.chat-msg-area { flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:10px; }
.chat-bubble-row { display:flex; gap:8px; align-items:flex-end; }
.chat-bubble-row.me { flex-direction:row-reverse; }
.chat-bubble {
    max-width:72%; padding:9px 13px; border-radius:14px;
    font-size:13px; line-height:1.5;
}
.chat-bubble-row.them .chat-bubble { background:#f5f5f3; border-bottom-left-radius:4px; }
.chat-bubble-row.me .chat-bubble { background:#1a1a1a; color:#fff; border-bottom-right-radius:4px; }
.chat-av-sm { width:28px; height:28px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:600; color:#fff; }
.chat-input-area { padding:12px 14px; border-top:1px solid #eee; display:flex; gap:8px; }
.chat-text-input { flex:1; padding:9px 13px; border:1.5px solid #e8e8e4; border-radius:10px; font-family:inherit; font-size:13px; outline:none; }
.chat-text-input:focus { border-color:#1a1a1a; }
.chat-send-btn { width:38px; height:38px; border-radius:10px; border:none; background:#1a1a1a; color:#fff; font-size:17px; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.2s; }
.chat-send-btn:hover { background:#d4537e; }
.chat-back-btn { background:none; border:none; font-size:20px; color:#888; cursor:pointer; padding:4px 8px; border-radius:6px; }
.chat-back-btn:hover { background:#f5f5f3; }

/* ---- Events panel ---- */
#eventsPanel { width:400px; }
.ev-item {
    padding:14px 18px; border-bottom:1px solid #f5f5f3;
    display:flex; gap:14px; align-items:flex-start;
    cursor:pointer; transition:background 0.15s;
}
.ev-item:hover { background:#fafaf8; }
.ev-date-box {
    width:48px; flex-shrink:0; text-align:center;
    background:linear-gradient(135deg,#d4537e,#e2856b); color:#fff;
    border-radius:10px; padding:8px 4px;
}
.ev-date-day { font-size:20px; font-weight:700; line-height:1; }
.ev-date-mo { font-size:9px; letter-spacing:1px; opacity:0.85; margin-top:1px; }
.ev-info { flex:1; }
.ev-title { font-size:13px; font-weight:500; margin-bottom:3px; }
.ev-meta { font-size:12px; color:#888; }
.ev-tags { display:flex; gap:5px; margin-top:6px; flex-wrap:wrap; }
.ev-tag { font-size:10px; font-weight:600; padding:2px 8px; border-radius:999px; }
.ev-tag.sale { background:#fbeaf0; color:#d4537e; }
.ev-tag.email { background:#e8f3fc; color:#378add; }
.ev-tag.voucher { background:#e6f7ef; color:#2eb872; }
.ev-tag.banner { background:#fff4e0; color:#d18800; }
.ev-tag.active { background:#e6f7ef; color:#2eb872; }
.ev-tag.scheduled { background:#e8f3fc; color:#378add; }
.ev-tag.draft { background:#f5f5f3; color:#888; }
.ev-actions { display:flex; gap:6px; margin-top:8px; }
.ev-add-form { padding:16px 18px; border-top:1px solid #f0f0ec; }
.ev-add-form h4 { font-size:12px; letter-spacing:1.5px; color:#888; font-weight:600; margin-bottom:12px; }

/* ---- AI floating bubble (proactive) ---- */
.ai-float-bubble {
    position:fixed; bottom:24px; right:24px;
    background:#fff; border-radius:18px; padding:14px 18px;
    box-shadow:0 8px 32px rgba(0,0,0,0.14); max-width:280px;
    display:flex; gap:10px; align-items:flex-start;
    z-index:300; cursor:pointer;
    animation:bubbleIn 0.4s cubic-bezier(0.34,1.56,0.64,1);
    border:1px solid rgba(212,83,126,0.15);
}
@@keyframes bubbleIn { from{transform:translateY(30px) scale(0.9);opacity:0;} to{transform:translateY(0) scale(1);opacity:1;} }
.ai-float-icon {
    width:36px; height:36px; border-radius:10px; flex-shrink:0;
    background:linear-gradient(135deg,#d4537e,#e2856b);
    display:flex; align-items:center; justify-content:center;
    font-size:18px; color:#fff;
}
.ai-float-text { font-size:13px; line-height:1.5; flex:1; }
.ai-float-close {
    position:absolute; top:8px; right:10px;
    background:none; border:none; font-size:14px; color:#bbb; cursor:pointer;
}
.ai-float-close:hover { color:#888; }

/* ---- AI avatar in panel – animated face ---- */
.ai-face {
    width:48px; height:48px; border-radius:14px; flex-shrink:0;
    background:linear-gradient(135deg,#d4537e,#e2856b);
    display:flex; align-items:center; justify-content:center;
    position:relative; overflow:hidden;
}
.ai-face-svg { width:32px; height:32px; }
.ai-face.thinking .ai-face-svg { animation:faceThink 0.5s ease infinite alternate; }
.ai-face.speaking .ai-face-svg { animation:faceSpeak 0.15s ease infinite alternate; }
@@keyframes faceThink { from{transform:rotate(-8deg) scale(0.95);} to{transform:rotate(8deg) scale(1.05);} }
@@keyframes faceSpeak { from{transform:scaleY(0.96);} to{transform:scaleY(1.04);} }

/* ---- Knowledge ticker ---- */
.ai-knowledge-bar {
    background:linear-gradient(135deg,rgba(212,83,126,0.06),rgba(226,133,107,0.06));
    border:1px solid rgba(212,83,126,0.12);
    border-radius:8px; padding:8px 12px;
    font-size:11px; color:#888; margin:8px 14px;
    display:flex; gap:8px; align-items:center;
}
.ai-knowledge-bar i { color:#d4537e; flex-shrink:0; }
.ai-know-text { flex:1; }

/* overlay for all side panels */
.sp-backdrop { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.15); z-index:197; }
</style>

<!-- NOTIFICATION PANEL -->
<div class="side-panel" id="notifPanel">
    <div class="side-panel-head">
        <i class="ti ti-bell" style="color:#d4537e;font-size:18px;"></i>
        <h3>Thông báo</h3>
        <button class="btn btn-outline btn-sm" onclick="markAllRead()" style="font-size:11px;padding:4px 10px;">Đọc tất cả</button>
        <button class="sp-close" onclick="closeSidePanel('notifPanel')"><i class="ti ti-x"></i></button>
    </div>
    <div class="notif-tabs">
        <div class="notif-tab active" onclick="filterNotif('all',this)">Tất cả <strong id="notifAllCount">5</strong></div>
        <div class="notif-tab" onclick="filterNotif('order',this)">Đơn hàng</div>
        <div class="notif-tab" onclick="filterNotif('product',this)">Sản phẩm</div>
        <div class="notif-tab" onclick="filterNotif('ai',this)">AI</div>
    </div>
    <div class="side-panel-body" id="notifList">
        <!-- rendered by JS -->
    </div>
    <div class="side-panel-foot">
        <button class="btn btn-outline" style="width:100%;justify-content:center;" onclick="closeSidePanel('notifPanel');switchPanel('analytics')"><i class="ti ti-chart-line"></i>Xem báo cáo đầy đủ</button>
    </div>
</div>

<!-- CHAT PANEL -->
<div class="side-panel" id="chatPanel">
    <div class="side-panel-head" id="chatPanelHead">
        <i class="ti ti-message-circle" style="color:#d4537e;font-size:18px;"></i>
        <h3>Tin nhắn</h3>
        <button class="sp-close" onclick="closeSidePanel('chatPanel')"><i class="ti ti-x"></i></button>
    </div>
    <div class="side-panel-body">
        <!-- Conversation list -->
        <div id="chatConvListWrap">
            <div class="chat-conv-list" id="chatConvList"><!-- rendered by JS --></div>
        </div>
        <!-- Active chat window -->
        <div class="chat-window" id="chatWindow">
            <div class="chat-msg-area" id="chatMsgArea"></div>
            <div class="chat-input-area">
                <input class="chat-text-input" id="chatTextInput" placeholder="Nhập tin nhắn..." onkeydown="if(event.key==='Enter')sendChatMsg()" />
                <button class="chat-send-btn" onclick="sendChatMsg()"><i class="ti ti-send"></i></button>
            </div>
        </div>
    </div>
</div>

<!-- EVENTS PANEL -->
<div class="side-panel" id="eventsPanel">
    <div class="side-panel-head">
        <i class="ti ti-calendar-event" style="color:#d4537e;font-size:18px;"></i>
        <h3>Sự kiện đã lên lịch</h3>
        <button class="btn btn-primary btn-sm" onclick="closeSidePanel('eventsPanel');openSchedulerModal()" style="font-size:11px;padding:5px 10px;"><i class="ti ti-plus"></i>Thêm</button>
        <button class="sp-close" onclick="closeSidePanel('eventsPanel')"><i class="ti ti-x"></i></button>
    </div>
    <div class="side-panel-body" id="eventsList"><!-- rendered by JS --></div>
    <div class="side-panel-foot">
        <button class="btn btn-outline" style="width:100%;justify-content:center;" onclick="openSchedulerModal()"><i class="ti ti-calendar-plus"></i>Tạo sự kiện mới</button>
    </div>
</div>

<!-- shared backdrop -->
<div class="sp-backdrop" id="spBackdrop" onclick="closeAllSidePanels()"></div>

<!-- AI Floating bubble -->
<div class="ai-float-bubble" id="aiFloatBubble" style="display:none;" onclick="toggleAIPanel();removeFloatBubble()">
    <div class="ai-float-icon"><i class="ti ti-robot"></i></div>
    <div class="ai-float-text" id="aiFloatText">Xin chào @(User.Identity?.Name ?? "Admin")!</div>
    <button class="ai-float-close" onclick="event.stopPropagation();removeFloatBubble()"><i class="ti ti-x"></i></button>
</div>

<script>
// ================================================================
// PROACTIVE AI – greeting + action watching
// ================================================================
const proactiveMessages = [
    { delay:1500, text:`🌟 Xin chào <strong>${ADMIN_NAME}</strong>! Hiện có <strong>${ADMIN_STAT.pending} đơn chờ xử lý</strong> và <strong>${ADMIN_STAT.lowStock} sản phẩm sắp hết hàng</strong>. Để tôi giúp bạn?`, bubble:`☀️ Chào ${ADMIN_NAME}! ${ADMIN_STAT.pending} đơn đang chờ xử lý.` },
    { delay:25000, text:`📈 Tổng doanh thu hiện tại: <strong>${fmtMoney(ADMIN_STAT.revenue)}₫</strong> từ <strong>${ADMIN_STAT.totalOrders} đơn hàng</strong>. Xem chi tiết ở trang Thống kê nhé! 🚀`, bubble:`📈 Doanh thu: ${fmtMoney(ADMIN_STAT.revenue)}₫` },
    { delay:60000, text:`💡 Bạn đang có <strong>${ADMIN_STAT.unansweredQ} câu hỏi</strong> của khách chưa trả lời. Trả lời sớm để tăng trải nghiệm mua hàng nhé!`, bubble:`💡 ${ADMIN_STAT.unansweredQ} câu hỏi chờ trả lời.` },
    { delay:120000, text:`🎯 Có <strong>${ADMIN_STAT.vouchers} voucher</strong> đang hoạt động. Bạn có thể gửi email khuyến mãi cho khách để tăng doanh thu!`, bubble:`🎯 ${ADMIN_STAT.vouchers} voucher đang chạy.` },
];

let proactiveIndex = 0;
let currentBubbleTimer = null;

function scheduleProactive() {
    if (proactiveIndex >= proactiveMessages.length) return;
    const msg = proactiveMessages[proactiveIndex++];
    setTimeout(() => {
        showFloatBubble(msg.bubble);
        // Also add to AI chat
        setTimeout(() => addAIProactiveMsg(msg.text), msg.delay + 500);
        scheduleProactive();
    }, msg.delay);
}

function showFloatBubble(text) {
    const b = document.getElementById('aiFloatBubble');
    document.getElementById('aiFloatText').innerHTML = text;
    b.style.display = 'flex';
    // pulse the AI button
    document.getElementById('aiTopBtn').classList.add('speaking');
    setTimeout(() => document.getElementById('aiTopBtn').classList.remove('speaking'), 3000);
    if (currentBubbleTimer) clearTimeout(currentBubbleTimer);
    currentBubbleTimer = setTimeout(removeFloatBubble, 8000);
}

function removeFloatBubble() {
    document.getElementById('aiFloatBubble').style.display = 'none';
}

function addAIProactiveMsg(text) {
    const msgs = document.getElementById('aiMessages');
    if (!msgs) return;
    const div = document.createElement('div');
    div.className = 'ai-msg bot';
    div.innerHTML = `<div class="ai-msg-avatar"><i class="ti ti-robot"></i></div><div class="ai-msg-bubble">${text}</div>`;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    // Add as notification too
    addNotification('ai', 'AI Assistant', text.replace(/<[^>]+>/g,'').slice(0,60)+'...', 'Vừa xong');
}

// ================================================================
// ACTIVITY WATCHER – fires when admin navigates panels
// ================================================================
const activitySuggestions = {
    products: [`📦 Có ${ADMIN_STAT.lowStock} sản phẩm sắp hết và ${ADMIN_STAT.outStock} sản phẩm đã hết hàng. Bạn có muốn nhập thêm không?`, '💡 Thêm tag "Bestseller" cho sản phẩm bán chạy để tăng tỷ lệ chuyển đổi!'],
    orders: [`📋 ${ADMIN_STAT.pending} đơn đang chờ xử lý. Xử lý trước các đơn COD để giảm tỷ lệ hoàn!`, '🖨 Bạn có thể in hóa đơn hàng loạt bằng lệnh "in hóa đơn" cho tôi nhé.'],
    customers: [`👥 Hiện có ${ADMIN_STAT.customers} khách hàng. Gửi email khuyến mãi để tăng tương tác!`, `💬 Có ${ADMIN_STAT.unansweredQ} câu hỏi chưa trả lời — phản hồi sớm để giữ khách.`],
    vouchers: [`🎟 Có ${ADMIN_STAT.vouchers} voucher đang hoạt động. Tạo thêm voucher cho dịp lễ để thu hút khách.`, '📊 Theo dõi số lượng voucher còn lại để gia hạn kịp thời.'],
    collections: ['🎨 Gợi ý: Thêm bộ sưu tập theo mùa để tăng traffic trang chủ!', '🔗 Liên kết bộ sưu tập với chiến dịch email để tăng doanh thu.'],
    analytics: [`📈 Tổng doanh thu hiện tại: ${fmtMoney(ADMIN_STAT.revenue)}₫ từ ${ADMIN_STAT.totalOrders} đơn.`, '🎯 Xem biểu đồ doanh thu 12 tháng để nắm xu hướng kinh doanh.'],
    settings: ['⚙️ Đã bật cảnh báo tồn kho thấp. Tôi sẽ nhắc bạn khi sản phẩm sắp hết.'],
    dashboard: [`🌟 Bạn có ${ADMIN_STAT.pending} đơn chờ xử lý và ${ADMIN_STAT.unansweredQ} câu hỏi cần trả lời. Cùng bắt đầu nhé, ${ADMIN_NAME}! 💪`],
};

const originalSwitchPanel = window.switchPanel;
window.switchPanel = function(section) {
    if (originalSwitchPanel) originalSwitchPanel(section);
    else {
        document.querySelectorAll('.sb-item[data-section]').forEach(i => i.classList.toggle('active', i.dataset.section === section));
        document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
        const t = document.querySelector(`[data-panel="${section}"]`);
        if (t) t.classList.add('active');
    }
    const tips = activitySuggestions[section];
    if (tips) {
        setTimeout(() => {
            const tip = tips[Math.floor(Math.random()*tips.length)];
            showFloatBubble(tip);
            setTimeout(() => addAIProactiveMsg(tip), 600);
        }, 1200);
    }
};

// ================================================================
// NOTIFICATIONS DATA & RENDER
// ================================================================
let notifications = [
    { id:1, type:'order', icon:'ti-shopping-cart', iconClass:'ni-order', title:'Đơn hàng mới #MNW2685920519', desc:'Trần Minh Khôi đặt 2 sản phẩm · 1.050.000₫', time:'2 phút trước', read:false },
    { id:2, type:'product', icon:'ti-alert-circle', iconClass:'ni-warning', title:'Sản phẩm sắp hết hàng', desc:'Áo thun cotton Essential (Đen·M) còn 3 cái', time:'15 phút trước', read:false },
    { id:3, type:'ai', icon:'ti-robot', iconClass:'ni-ai', title:'AI: Gợi ý chiến dịch email', desc:'200 khách Gold chưa nhận email tháng này...', time:'30 phút trước', read:false },
    { id:4, type:'customer', icon:'ti-user-plus', iconClass:'ni-customer', title:'Khách hàng mới đăng ký', desc:'Phạm Thu Hương – vừa tạo tài khoản', time:'1 giờ trước', read:false },
    { id:5, type:'order', icon:'ti-truck', iconClass:'ni-order', title:'Đơn #MNW2685920516 đã giao', desc:'Giao thành công cho Lan Phương', time:'2 giờ trước', read:true },
];
let notifFilter = 'all';

function addNotification(type, title, desc, time) {
    const iconMap = { ai:'ti-robot', order:'ti-shopping-cart', product:'ti-package', customer:'ti-user' };
    const classMap = { ai:'ni-ai', order:'ni-order', product:'ni-product', customer:'ni-customer' };
    notifications.unshift({ id:Date.now(), type, icon:iconMap[type]||'ti-bell', iconClass:classMap[type]||'ni-order', title, desc, time:time||'Vừa xong', read:false });
    renderNotifications();
    updateNotifBadge();
}

function renderNotifications() {
    const list = document.getElementById('notifList');
    const filtered = notifFilter === 'all' ? notifications : notifications.filter(n => n.type === notifFilter);
    if (!filtered.length) { list.innerHTML = `<div class="notif-empty"><i class="ti ti-bell-off" style="font-size:32px;display:block;margin-bottom:8px;"></i>Không có thông báo</div>`; return; }
    list.innerHTML = filtered.map(n => `
        <div class="notif-item ${n.read?'':'unread'}" onclick="readNotif(${n.id})">
            <div class="notif-icon ${n.iconClass}"><i class="ti ${n.icon}"></i></div>
            <div class="notif-info">
                <div class="notif-title">${n.title}</div>
                <div class="notif-desc">${n.desc}</div>
                <div class="notif-time">${n.time}</div>
            </div>
        </div>`).join('');
}

function updateNotifBadge() {
    const unread = notifications.filter(n => !n.read).length;
    const badge = document.getElementById('notifBadge');
    const dot = document.getElementById('notifDot');
    if (unread > 0) { badge.textContent = unread; badge.style.display = 'flex'; if(dot) dot.style.display='block'; }
    else { badge.style.display = 'none'; if(dot) dot.style.display='none'; }
    document.getElementById('notifAllCount').textContent = unread;
}

function readNotif(id) {
    const n = notifications.find(x => x.id === id);
    if (n) n.read = true;
    renderNotifications(); updateNotifBadge();
}

function markAllRead() {
    notifications.forEach(n => n.read = true);
    renderNotifications(); updateNotifBadge();
    showToast('success','Đã đọc tất cả','Tất cả thông báo đã được đánh dấu là đã đọc');
}

function filterNotif(type, el) {
    notifFilter = type;
    document.querySelectorAll('.notif-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    renderNotifications();
}

// ================================================================
// CHAT DATA & RENDER
// ================================================================
let chatConversations = [];
let activeChatId = null;
const chatColors = ['#d4537e','#378add','#2eb872','#e2856b','#7a4a2a'];
function chatEsc(s){ return (s||'').replace(/</g,'&lt;'); }
function chatInitial(n){ return (n||'?').trim().charAt(0).toUpperCase(); }

function loadChatConvos() {
    fetch('/Home/GetChatUsers').then(r=>r.ok?r.json():[]).then(list => {
        chatConversations = list.map((c,i) => ({
            id: c.userId, name: c.name, initials: chatInitial(c.name),
            color: chatColors[i % chatColors.length], preview: c.lastMessage, unread: c.unread
        }));
        renderChatList();
        if (activeChatId) loadChatMessages(activeChatId);
    }).catch(()=>{});
}

function renderChatList() {
    const list = document.getElementById('chatConvList');
    if (!chatConversations.length) { list.innerHTML = '<div style="padding:30px;text-align:center;color:#999;font-size:13px;">Chưa có cuộc trò chuyện nào</div>'; }
    else list.innerHTML = chatConversations.map(c => `
        <div class="chat-conv-item ${c.unread?'unread':''}" onclick="openChat(${c.id})">
            <div class="chat-av" style="background:${c.color};">${c.initials}</div>
            <div class="chat-conv-info">
                <div class="chat-conv-name">${chatEsc(c.name)}</div>
                <div class="chat-conv-preview">${chatEsc(c.preview)}</div>
            </div>
            ${c.unread?`<div class="chat-conv-time" style="background:#d4537e;color:#fff;border-radius:999px;padding:2px 7px;font-size:11px;">${c.unread}</div>`:''}
        </div>`).join('');
    const total = chatConversations.reduce((a,c)=>a+c.unread,0);
    const badge = document.getElementById('chatBadge');
    if (badge) { badge.textContent = total; badge.style.display = total>0?'flex':'none'; }
}

function loadChatMessages(userId) {
    const conv = chatConversations.find(c=>c.id===userId);
    fetch('/Home/GetAdminMessages?userId=' + userId).then(r=>r.ok?r.json():[]).then(msgs => {
        const area = document.getElementById('chatMsgArea');
        area.innerHTML = msgs.map(m=>`
            <div class="chat-bubble-row ${m.fromAdmin?'me':'them'}">
                ${!m.fromAdmin&&conv?`<div class="chat-av-sm" style="background:${conv.color};">${conv.initials}</div>`:''}
                <div class="chat-bubble">${chatEsc(m.content)}</div>
            </div>`).join('');
        area.scrollTop = area.scrollHeight;
    }).catch(()=>{});
}

function openChat(id) {
    activeChatId = id;
    const conv = chatConversations.find(c=>c.id===id);
    if (!conv) return;
    conv.unread = 0;
    document.getElementById('chatPanelHead').innerHTML = `
        <button class="chat-back-btn" onclick="closeChatWindow()"><i class="ti ti-arrow-left"></i></button>
        <div class="chat-av" style="background:${conv.color};width:34px;height:34px;font-size:13px;">${conv.initials}</div>
        <h3>${chatEsc(conv.name)}</h3>
        <button class="sp-close" onclick="closeSidePanel('chatPanel')"><i class="ti ti-x"></i></button>
    `;
