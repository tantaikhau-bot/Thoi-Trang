        // ===== Tìm kiếm trong bảng Admin (theo từ khóa) =====
        function searchAdminTable(input, panel) {
            const q = (input.value || '').toLowerCase().trim();
            const attr = panel === 'products' ? 'pstatus' : (panel === 'orders' ? 'status' : 'tier');
            const panelEl = document.querySelector('.panel[data-panel="' + panel + '"]');
            if (!panelEl) return;
            let shown = 0;
            panelEl.querySelectorAll('tbody tr[data-' + attr + ']').forEach(function (tr) {
                const ok = !q || tr.textContent.toLowerCase().indexOf(q) >= 0;
                tr.style.display = ok ? '' : 'none';
                if (ok) shown++;
            });
            let emptyRow = panelEl.querySelector('tbody tr.admin-empty-row');
            if (shown === 0) {
                if (!emptyRow) {
                    const tb = panelEl.querySelector('tbody');
                    if (tb) { emptyRow = document.createElement('tr'); emptyRow.className = 'admin-empty-row'; emptyRow.innerHTML = '<td colspan="8" style="text-align:center;color:#999;padding:24px;">Không tìm thấy kết quả</td>'; tb.appendChild(emptyRow); }
