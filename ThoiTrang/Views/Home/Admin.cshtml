async function saveCollection() {
    const title = document.getElementById('col-title').value.trim();
    if (!title) { showToast('warning','Thiếu tiêu đề','Nhập tiêu đề bộ sưu tập'); return; }
    const payload = {
        collectionId: editingCollectionId,
        title,
        label: document.getElementById('col-label').value.trim(),
        description: document.getElementById('col-desc').value.trim(),
        coverClass: document.getElementById('col-cover').value,
        icon: document.getElementById('col-icon').value,
        linkUrl: document.getElementById('col-link').value.trim(),
        linkText: document.getElementById('col-linktext').value.trim(),
        displayOrder: parseInt(document.getElementById('col-order').value) || 0
    };
    const r = await fetch('/Home/SaveCollection', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
    if (r.ok) { closeModal('collectionModal'); showToast('success', editingCollectionId>0?'Đã cập nhật':'Đã tạo bộ sưu tập',''); setTimeout(()=>location.reload(),900); }
    else { const e = await r.json().catch(()=>({})); showToast('error','Lỗi', e.message||'Không lưu được'); }
}
async function deleteCollection(id) {
    if (!confirm('Xóa bộ sưu tập này?')) return;
    const fd = new FormData(); fd.append('collectionId', id);
    const r = await fetch('/Home/DeleteCollection', { method:'POST', body: fd });
    if (r.ok) { showToast('success','Đã xóa',''); setTimeout(()=>location.reload(),700); }
}
async function toggleCollection(id) {
    const fd = new FormData(); fd.append('collectionId', id);
    const r = await fetch('/Home/ToggleCollection', { method:'POST', body: fd });
    if (r.ok) { setTimeout(()=>location.reload(),400); }
}

