                    <div class="collection-grid" id="collectionGrid">
                        @{
                            var allCols = ViewBag.AllCollections as List<ThoiTrang.Models.Entities.Collection> ?? new List<ThoiTrang.Models.Entities.Collection>();
                        }
                        @for (int ci2 = 0; ci2 < allCols.Count; ci2++)
                        {
                            var col = allCols[ci2];
                            var coverN = (ci2 % 4) + 1;
                            <div class="collection-card">
                                <div class="collection-cover collection-cover-@coverN" style="@(col.IsActive ? "" : "opacity:.5;")">
                                    <span class="collection-badge">@(col.IsActive ? "ĐANG HIỂN THỊ" : "ĐÃ ẨN")</span>
                                    <i class="ti @(string.IsNullOrEmpty(col.Icon) ? "ti-hanger" : col.Icon)"></i>
                                </div>
                                <div class="collection-info">
                                    <div class="collection-title">@col.Title</div>
                                    <div class="collection-desc">@col.Label</div>
                                    <div class="collection-meta">
                                        <span class="collection-stats" style="cursor:pointer;" onclick="toggleCollection(@col.CollectionId)"><i class="ti ti-eye"></i> @(col.IsActive ? "Đang hiển thị" : "Đã ẩn") — bấm để đổi</span>
                                        <div class="collection-actions">
                                            @if (!string.IsNullOrEmpty(col.LinkUrl))
                                            {
                                                <button class="action-btn" title="Xem trước" onclick="window.open('@col.LinkUrl','_blank')"><i class="ti ti-eye"></i></button>
                                            }
                                            <button class="action-btn" title="Sửa" onclick='editCollection(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new { id = col.CollectionId, label = col.Label, title = col.Title, description = col.Description, icon = col.Icon, coverClass = col.CoverClass, linkUrl = col.LinkUrl, linkText = col.LinkText, displayOrder = col.DisplayOrder })))'><i class="ti ti-pencil"></i></button>
                                            <button class="action-btn danger" title="Xóa" onclick="deleteCollection(@col.CollectionId)"><i class="ti ti-trash"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (allCols.Count == 0)
                        {
                            <div style="padding:30px;color:#999;">Chưa có bộ sưu tập nào.</div>
                        }
                    </div>
                </div>

