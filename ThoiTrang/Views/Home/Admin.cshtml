                                        var pstatus = !pr.IsActive ? "draft" : (pstock == 0 ? "out" : (pstock <= 10 ? "low" : "active"));
                                        var stt = pr.IsActive
                                            ? ("status-active", "ti-circle-check", "Đang bán")
                                            : ("status-cancelled", "ti-x", "Ngừng bán");
                                        <tr data-pstatus="@pstatus" data-pid="@pr.ProductId" data-name="@pr.Name" data-price="@pr.Price" data-old="@(pr.OldPrice ?? 0)" data-material="@pr.Material" data-gender="@(pr.Category?.Slug == "nu" ? "female" : "male")" data-badge="@(pr.IsNew ? "new" : pr.IsSale ? "sale" : pr.IsFeatured ? "bestseller" : "none")">
