                <div style="font-size: 13px; color: #888; line-height: 1.6;" id="cr_desc">Tài khoản "<span id="cr_name" style="color:#1a1a1a; font-weight:500;">khách hàng</span>" sẽ bị tạm khóa, không thể đăng nhập và đặt hàng. Bạn có thể mở lại bất cứ lúc nào.</div>

                <div style="margin-top:16px; text-align:left;">
                    <label class="form-label" style="font-size:11px;">LÝ DO HẠN CHẾ (tùy chọn)</label>
                    <select class="form-input" id="cr_reason" style="font-size:13px;">
                        <option>Vi phạm chính sách</option>
                        <option>Khách hàng yêu cầu</option>
                        <option>Nghi ngờ gian lận</option>
                        <option>Spam / Quấy rối</option>
                        <option>Lý do khác</option>
                    </select>
                </div>
            </div>
            <div class="modal-foot" style="justify-content: center;">
                <button class="btn btn-outline" onclick="closeModal('customerRestrictModal')">Hủy</button>
                <button class="btn btn-primary" style="background: #d18800;" onclick="confirmRestrictCustomer()"><i class="ti ti-lock"></i><span id="cr_action_text">Hạn chế ngay</span></button>
            </div>
        </div>
    </div>

