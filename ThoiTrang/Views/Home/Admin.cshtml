// === XEM CHI TIẾT ===
function viewCustomer(name) {
    const row = document.querySelector('tr[data-cust="' + (name || '').replace(/"/g, '\\"') + '"]');
    if (!row) { showToast('warning','Không tìm thấy', 'Khách hàng không tồn tại'); return; }
    const tierBadgeEl = row.querySelector('.tier-badge');
    const spentCell = row.children[4];
    const c = {
        name: name,
        avatar: 'av-1',
        email: (row.querySelector('.tbl-customer-email')?.textContent || '').trim(),
        phone: (row.children[1]?.textContent || '').trim(),
        tier: tierBadgeEl ? (tierBadgeEl.className.match(/tier-(\w+)/)?.[1] || 'bronze') : 'bronze',
        tierLabel: tierBadgeEl ? tierBadgeEl.textContent.trim() : 'MEMBER',
        joindate: (row.children[5]?.textContent || '').trim(),
        orders: (row.children[3]?.textContent || '0').trim(),
        spent: (spentCell?.querySelector('strong')?.textContent || '0₫').trim(),
        points: (spentCell?.querySelector('div')?.textContent || '0 điểm').replace(' điểm','').trim(),
        note: '—',
        locked: false
    };
    currentViewCustomer = name;
    currentViewUid = row.getAttribute('data-uid');
    const cvAv = document.getElementById('cv_avatar');
    const avUrl = row.querySelector('.tbl-avatar')?.getAttribute('data-avatar') || '';
    cvAv.className = 'tbl-avatar ' + c.avatar;
    cvAv.style.width = '64px';
    cvAv.style.height = '64px';
    cvAv.style.fontSize = '22px';
    if (avUrl) {
        cvAv.textContent = '';
        cvAv.style.backgroundImage = `url('${avUrl}')`;
        cvAv.style.backgroundSize = 'cover';
        cvAv.style.backgroundPosition = 'center';
    } else {
        cvAv.textContent = name.charAt(0).toUpperCase();
        cvAv.style.backgroundImage = '';
    }
    document.getElementById('cv_name').textContent = c.name;
    document.getElementById('cv_email').textContent = c.email;
    const tierIcon = c.tier === 'gold' ? '<i class="ti ti-crown"></i>' : c.tier === 'platinum' ? '<i class="ti ti-diamond"></i>' : '';
    document.getElementById('cv_tier_wrap').innerHTML = `<span class="tier-badge tier-${c.tier}">${tierIcon}${c.tierLabel}</span>`;
    document.getElementById('cv_phone').textContent = c.phone;
    document.getElementById('cv_joindate').textContent = c.joindate;
    document.getElementById('cv_orders').textContent = c.orders + ' đơn';
    document.getElementById('cv_spent').textContent = c.spent;
    document.getElementById('cv_points').textContent = c.points + ' điểm';
    document.getElementById('cv_note').textContent = c.note;

    if (c.locked) {
        document.getElementById('cv_locked_badge').style.display = 'block';
        document.getElementById('cv_status').className = 'tbl-status';
        document.getElementById('cv_status').style.background = '#fbeaea';
        document.getElementById('cv_status').style.color = '#e63946';
        document.getElementById('cv_status').innerHTML = '<i class="ti ti-lock"></i>Đã hạn chế';
        document.getElementById('cv_restrict_text').textContent = 'Mở khóa tài khoản';
    } else {
        document.getElementById('cv_locked_badge').style.display = 'none';
        document.getElementById('cv_status').className = 'tbl-status status-active';
        document.getElementById('cv_status').style.background = '';
        document.getElementById('cv_status').style.color = '';
        document.getElementById('cv_status').innerHTML = '<i class="ti ti-circle-check"></i>Đang hoạt động';
        document.getElementById('cv_restrict_text').textContent = 'Hạn chế tài khoản';
    }

    // Lưu email để nút "Gửi email" dùng
    currentViewEmail = c.email;

    // Tải đơn hàng thật của khách
    var uid = row.getAttribute('data-uid');
    var listEl = document.getElementById('cv_orders_list');
    if (listEl) {
        listEl.innerHTML = '<div style="color:#999;font-size:13px;">Đang tải...</div>';
        fetch('/Home/GetCustomerOrders?userId=' + uid).then(function (r) { return r.ok ? r.json() : []; }).then(function (orders) {
            if (!orders.length) { listEl.innerHTML = '<div style="color:#999;font-size:13px;">Khách chưa có đơn hàng nào.</div>'; return; }
            listEl.innerHTML = orders.map(function (o) {
                var st = o.orderStatus === 'Completed' ? 'Đã giao' : o.orderStatus === 'Shipping' ? 'Đang giao' : o.orderStatus === 'Confirmed' ? 'Đã xác nhận' : o.orderStatus === 'Cancelled' ? 'Đã hủy' : 'Chờ xử lý';
                return '<div style="display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:#fafaf8; border-radius:8px; font-size:13px;">'
                    + '<span style="font-family:monospace; font-weight:600;">#' + o.orderCode + '</span>'
                    + '<span style="color:#888;">' + o.date + '</span>'
                    + '<strong>' + (o.totalAmount || 0).toLocaleString('vi-VN') + '₫</strong>'
                    + '<span class="tbl-status status-delivered" style="font-size:10px;">' + st + '</span></div>';
            }).join('');
        }).catch(function () { listEl.innerHTML = '<div style="color:#999;font-size:13px;">Không tải được đơn hàng.</div>'; });
    }

    document.getElementById('customerViewModal').classList.add('show');
}
