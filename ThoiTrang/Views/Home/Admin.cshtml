            } else if (emptyRow) emptyRow.style.display = 'none';
        }

        // ===== Cập nhật trạng thái đơn (lưu DB) =====
        function updateOrderStatus(orderId, status, sel) {
            const fd = new FormData(); fd.append('orderId', orderId); fd.append('status', status);
            fetch('/Home/UpdateOrderStatus', { method: 'POST', body: fd })
                .then(r => r.ok ? r.json() : Promise.reject(r))
                .then(() => showToast('success', 'Đã cập nhật', 'Trạng thái đơn hàng đã thay đổi'))
                .catch(() => showToast('error', 'Lỗi', 'Không thể cập nhật trạng thái'));
        }

        // ===== Xóa sản phẩm (lưu DB) =====
        function deleteProductRow(btn, productId) {
            if (!confirm('Bạn có chắc muốn xóa sản phẩm này?')) return;
            const fd = new FormData(); fd.append('productId', productId);
            fetch('/Home/DeleteProduct', { method: 'POST', body: fd })
                .then(r => r.ok ? r.json() : Promise.reject(r))
                .then(d => {
                    btn.closest('tr').remove();
                    showToast('success', 'Đã xóa', d.softDeleted ? 'Sản phẩm đã được ẩn (đã có đơn hàng)' : 'Sản phẩm đã được xóa khỏi hệ thống');
                })
                .catch(() => showToast('error', 'Lỗi', 'Không thể xóa sản phẩm'));
        }
        function openOrderModal() { document.getElementById('orderModal').classList.add('show'); }
        function openVoucherModal() {
            editingVoucherId = 0;
            ['v-code','v-value','v-min','v-qty','v-start','v-end','v-desc'].forEach(id => { var el=document.getElementById(id); if(el) el.value=''; });
            var t = document.querySelector('#voucherModal .modal-title'); if (t) t.textContent = 'Tạo voucher mới';
            document.getElementById('voucherModal').classList.add('show');
        }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }
        document.querySelectorAll('.modal-overlay').forEach(m => {
            m.addEventListener('click', (e) => { if (e.target === m) m.classList.remove('show'); });
        });

        function saveProduct() {
            const name = (document.getElementById('p-name').value || '').trim();
            const price = parseFloat(document.getElementById('p-price').value) || 0;
            if (!name || price <= 0) {
                showToast('error', 'Thiếu thông tin', 'Vui lòng nhập tên và giá bán hợp lệ');
                return;
            }
            const payload = {
                productId: editingProductId,
                name: name,
                sku: (document.getElementById('p-sku').value || '').trim(),
                price: price,
                oldPrice: parseFloat(document.getElementById('p-origprice').value) || 0,
                material: (document.getElementById('p-material') ? document.getElementById('p-material').value : '').trim(),
                description: (document.getElementById('p-desc') ? document.getElementById('p-desc').value : '').trim(),
                gender: (typeof currentGender !== 'undefined') ? currentGender : 'male',
                badge: (typeof selectedBadge !== 'undefined') ? selectedBadge : 'none'
            };
            const url = editingProductId > 0 ? '/Home/EditProduct' : '/Home/AddProduct';
            fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
                .then(r => r.ok ? r.json() : Promise.reject(r))
                .then(async d => {
                    // Lưu tồn kho biến thể (nếu đang sửa và có dữ liệu thật)
                    const rows = document.querySelectorAll('#variantTableBody tr[data-vid]');
                    if (editingProductId > 0 && rows.length) {
                        const items = Array.from(rows).map(tr => ({
                            variantId: parseInt(tr.dataset.vid),
                            stock: parseInt(tr.querySelector('.variant-stock-input')?.value) || 0
                        }));
                        await fetch('/Home/UpdateVariantStock', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(items) });
                    }
                    closeModal('productModal');
                    showToast('success', editingProductId > 0 ? 'Đã cập nhật' : 'Đã thêm sản phẩm', 'Tải lại trang để xem thay đổi...');
                    setTimeout(() => location.reload(), 1000);
                })
                .catch(() => showToast('error', 'Lỗi', 'Không thể lưu sản phẩm'));
        }

        // ===== Product modal tabs =====
        function switchProdTab(tab) {
            document.querySelectorAll('.prod-tab').forEach((t, i) => {
                const ids = ['info','classify','variants'];
                t.classList.toggle('active', ids[i] === tab);
            });
            document.querySelectorAll('.prod-tab-panel').forEach(p => p.classList.remove('active'));
            document.getElementById('ptab-' + tab).classList.add('active');
        }

        // ===== Gender & category =====
        const catsByGender = {
            male: [
                { label: 'Áo thun', icon: 'ti-shirt' },
                { label: 'Áo sơ mi', icon: 'ti-shirt' },
                { label: 'Áo polo', icon: 'ti-shirt' },
                { label: 'Áo khoác', icon: 'ti-shirt' },
                { label: 'Hoodie', icon: 'ti-shirt' },
                { label: 'Quần jeans', icon: 'ti-versions' },
                { label: 'Quần kaki', icon: 'ti-versions' },
                { label: 'Quần short', icon: 'ti-versions' },
                { label: 'Giày', icon: 'ti-shoe' },
                { label: 'Túi', icon: 'ti-briefcase' },
                { label: 'Phụ kiện', icon: 'ti-tag' },
            ],
            female: [
                { label: 'Áo thun nữ', icon: 'ti-shirt' },
                { label: 'Áo sơ mi', icon: 'ti-shirt' },
                { label: 'Áo blouse', icon: 'ti-shirt' },
                { label: 'Áo croptop', icon: 'ti-shirt' },
                { label: 'Áo khoác nữ', icon: 'ti-shirt' },
                { label: 'Đầm / Váy', icon: 'ti-dress' },
                { label: 'Chân váy', icon: 'ti-dress' },
                { label: 'Quần jeans nữ', icon: 'ti-versions' },
                { label: 'Giày nữ', icon: 'ti-shoe' },
                { label: 'Túi xách', icon: 'ti-briefcase' },
                { label: 'Phụ kiện', icon: 'ti-tag' },
            ],
            unisex: [
                { label: 'Áo thun', icon: 'ti-shirt' },
                { label: 'Hoodie', icon: 'ti-shirt' },
                { label: 'Áo khoác', icon: 'ti-shirt' },
                { label: 'Quần', icon: 'ti-versions' },
                { label: 'Giày', icon: 'ti-shoe' },
                { label: 'Phụ kiện', icon: 'ti-tag' },
            ]
        };
        const sizesByGender = {
            male: ['XS','S','M','L','XL','XXL','28','29','30','31','32','33'],
            female: ['XS','S','M','L','XL','26','27','28'],
            unisex: ['XS','S','M','L','XL','XXL']
        };
        let currentGender = 'male';
        let selectedCat = '';
        let selectedBadge = 'none';
        let selectedColors = ['#1a1a1a'];
        let selectedSizes = [];

        const colorNames = {
            '#1a1a1a':'Đen','#f5f0e8':'Kem','#b0b0b0':'Xám','#ffffff':'Trắng',
            '#1a4c8c':'Navy','#7a4a2a':'Nâu','#3a6b3a':'Xanh lá',
            '#d4537e':'Hồng','#e63946':'Đỏ','#f5c518':'Vàng'
        };

        function selectGender(g) {
            currentGender = g;
            document.querySelectorAll('.gender-btn').forEach(b => b.classList.toggle('active', b.dataset.gender === g));
            renderCatGrid();
            renderSizeTags();
            renderVariantTable();
        }

        function renderCatGrid() {
            const grid = document.getElementById('catGrid');
            grid.innerHTML = catsByGender[currentGender].map(c =>
                `<div class="cat-chip${selectedCat===c.label?' active':''}" onclick="selectCat('${c.label}')">
                    <i class="ti ${c.icon}"></i>${c.label}
                </div>`
            ).join('');
        }

        function selectCat(label) {
            selectedCat = label;
            renderCatGrid();
        }

        function selectBadge(b) {
            selectedBadge = b;
            document.querySelectorAll('.badge-opt').forEach(el => el.classList.toggle('active', el.dataset.badge === b));
            document.getElementById('salePercentBox').style.display = (b === 'sale') ? 'block' : 'none';
        }

        // ===== Color toggle =====
        function toggleColor(btn) {
            const c = btn.dataset.color;
            if (selectedColors.includes(c)) {
                if (selectedColors.length === 1) return; // keep at least 1
                selectedColors = selectedColors.filter(x => x !== c);
                btn.classList.remove('active');
            } else {
                selectedColors.push(c);
                btn.classList.add('active');
            }
            renderVariantTable();
        }

        function addCustomColor(hex) {
            if (!hex) return;
            colorNames[hex] = hex;
            const row = document.getElementById('colorRow');
            const newBtn = document.createElement('button');
            newBtn.className = 'color-dot-btn active';
            newBtn.dataset.color = hex;
            newBtn.style.background = hex;
            newBtn.title = hex;
            newBtn.onclick = function() { toggleColor(this); };
            row.insertBefore(newBtn, row.lastElementChild);
            selectedColors.push(hex);
            renderVariantTable();
        }

        // ===== Size tags =====
        function renderSizeTags() {
            const row = document.getElementById('sizeTagRow');
            const sizes = sizesByGender[currentGender];
            selectedSizes = [];
            row.innerHTML = sizes.map(s =>
                `<div class="size-tag" onclick="toggleSize(this,'${s}')">${s}</div>`
            ).join('');
        }

        function toggleSize(el, s) {
            if (selectedSizes.includes(s)) {
                selectedSizes = selectedSizes.filter(x => x !== s);
                el.classList.remove('active');
            } else {
                selectedSizes.push(s);
                el.classList.add('active');
            }
            renderVariantTable();
        }

        // ===== Variant table =====
        function renderVariantTable() {
            const tbody = document.getElementById('variantTableBody');
            if (!selectedColors.length || !selectedSizes.length) {
                tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:#aaa;padding:20px;">Chọn màu và size để tạo biến thể</td></tr>';
                return;
            }
            let rows = '';
            selectedColors.forEach(c => {
                selectedSizes.forEach(s => {
                    const name = colorNames[c] || c;
                    rows += `<tr>
                        <td><span class="color-swatch" style="background:${c};"></span>${name}</td>
                        <td><strong>${s}</strong></td>
                        <td><input type="number" placeholder="0" min="0" class="var-stock" data-color="${c}" data-size="${s}" /></td>
                        <td><input type="number" placeholder="—" min="0" class="var-price" /></td>
                    </tr>`;
                });
            });
            tbody.innerHTML = rows;
        }

        function fillAllVariantStock() {
            const val = prompt('Nhập số lượng tồn kho cho tất cả biến thể:');
            if (val === null) return;
            document.querySelectorAll('.var-stock').forEach(i => i.value = parseInt(val) || 0);
        }

        // ===== Import stock =====
        function openImportFromProduct() {
            document.getElementById('importDate').textContent = new Date().toLocaleDateString('vi-VN');
            closeModal('productModal');
            document.getElementById('importModal').classList.add('show');
        }

        function openImportModal() {
            document.getElementById('importDate').textContent = new Date().toLocaleDateString('vi-VN');
            document.getElementById('importModal').classList.add('show');
        }

        function filterImportRows(q) {
            const rows = document.querySelectorAll('#importRows .import-row');
            rows.forEach(r => {
                r.style.display = r.dataset.name.includes(q.toLowerCase()) ? '' : 'none';
            });
        }

        function updateImportSummary() {
            const inputs = document.querySelectorAll('#importRows .import-qty');
            let count = 0, total = 0;
            inputs.forEach(i => {
                const v = parseInt(i.value) || 0;
                if (v > 0) { count++; total += v; }
            });
            document.getElementById('importCount').textContent = count + ' biến thể';
            document.getElementById('importTotal').textContent = total + ' sản phẩm';
        }

        function clearImportForm() {
            document.querySelectorAll('#importRows .import-qty').forEach(i => i.value = '');
            document.getElementById('importNote').value = '';
            updateImportSummary();
        }

        function confirmImport() {
            const total = document.getElementById('importTotal').textContent;
            closeModal('importModal');
            showToast('success', 'Nhập hàng thành công', `Đã cập nhật kho: ${total}`);
        }

        // Init
        renderCatGrid();
        renderSizeTags();
        function saveVoucher() {
            const code = (document.getElementById('v-code').value || '').trim().toUpperCase();
            const value = parseFloat(document.getElementById('v-value').value) || 0;
            if (!code || value <= 0) {
                showToast('error', 'Thiếu thông tin', 'Vui lòng nhập mã và giá trị giảm');
                return;
            }
            const payload = {
                voucherId: editingVoucherId,
                code: code,
                discountType: document.getElementById('v-type').value,
                discountValue: value,
                minOrder: parseFloat(document.getElementById('v-min').value) || 0,
                quantity: parseInt(document.getElementById('v-qty').value) || 0,
                startDate: document.getElementById('v-start').value || null,
                endDate: document.getElementById('v-end').value || null,
                description: (document.getElementById('v-desc').value || '').trim()
            };
            const url = editingVoucherId > 0 ? '/Home/EditVoucher' : '/Home/SaveVoucher';
            fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
                .then(r => r.ok ? r.json() : Promise.reject(r))
                .then(() => {
                    closeModal('voucherModal');
                    showToast('success', editingVoucherId > 0 ? 'Đã cập nhật voucher' : 'Đã tạo voucher', 'Tải lại trang để xem...');
                    setTimeout(() => location.reload(), 900);
                })
                .catch(() => showToast('error', 'Lỗi', 'Không thể lưu voucher (mã có thể đã tồn tại)'));
        }

        // ===== Logout =====
        document.getElementById('logoutBtn').addEventListener('click', () => {
            document.getElementById('logoutModal').classList.add('show');
        });
        function confirmLogout() {
            closeModal('logoutModal');
            showToast('success', 'Đã đăng xuất', 'Đang chuyển về trang đăng nhập...');
            setTimeout(() => { window.location.href = '/Home/Logout'; }, 1000);
        }

        // ===== Toast =====
        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type || ''}`;
            const icons = { success: 'ti-circle-check', info: 'ti-info-circle', warning: 'ti-alert-circle', error: 'ti-x' };
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
            `;
            container.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 400); }, 3500);
        }

        // ===== Welcome toast =====
        setTimeout(() => {
            showToast('success', 'Chào ' + ADMIN_NAME + '!', 'Bạn có ' + ADMIN_STAT.pending + ' đơn chờ xử lý hôm nay');
        }, 600);

        // ===== Keyboard shortcut search =====
        document.addEventListener('keydown', (e) => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                const input = document.querySelector('.topbar-search input');
                if (input) input.focus();
            }
        });
    </script>

</body>
</html>

