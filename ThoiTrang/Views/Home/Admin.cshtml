            } else if (emptyRow) emptyRow.style.display = 'none';
        }

        // ===== Lọc danh sách theo tab (Sản phẩm / Đơn hàng / Khách hàng) =====
        function filterAdminTab(btn, panel, key) {
            const tabs = btn.parentElement;
            tabs.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const panelEl = document.querySelector('.panel[data-panel="' + panel + '"]');
            if (!panelEl) return;
            const attr = panel === 'products' ? 'pstatus' : (panel === 'orders' ? 'status' : 'tier');
            let shown = 0;
            panelEl.querySelectorAll('tbody tr[data-' + attr + ']').forEach(function (tr) {
                const val = tr.getAttribute('data-' + attr);
                const ok = (key === 'all' || val === key);
                tr.style.display = ok ? '' : 'none';
                if (ok) shown++;
            });
            // dòng "không có dữ liệu" tạm thời
            let emptyRow = panelEl.querySelector('tbody tr.admin-empty-row');
            if (shown === 0) {
                if (!emptyRow) {
                    const tb = panelEl.querySelector('tbody');
                    if (tb) { emptyRow = document.createElement('tr'); emptyRow.className = 'admin-empty-row'; emptyRow.innerHTML = '<td colspan="8" style="text-align:center;color:#999;padding:24px;">Không có mục nào ở trạng thái này</td>'; tb.appendChild(emptyRow); }
