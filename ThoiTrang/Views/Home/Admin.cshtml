        .color-picker-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-bottom: 14px; }
        .color-dot-btn {
            width: 28px; height: 28px; border-radius: 50%;
            border: 2px solid transparent; cursor: pointer;
            transition: all 0.2s; position: relative;
            outline: none;
        }
        .color-dot-btn.active { border-color: #1a1a1a; box-shadow: 0 0 0 2px #fff inset; }
        .color-add-btn {
            width: 28px; height: 28px; border-radius: 50%;
            border: 1.5px dashed #ccc; background: transparent;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 14px; color: #999;
            transition: all 0.2s;
        }
        .color-add-btn:hover { border-color: #888; color: #555; }
        .color-input-hidden { display: none; }

        .size-tag-row { display: flex; gap: 7px; flex-wrap: wrap; margin-bottom: 14px; }
        .size-tag {
            min-width: 44px; height: 34px; padding: 0 10px;
            border: 1.5px solid #e8e8e4; border-radius: 7px;
            background: #fff; font-size: 12px; font-weight: 600;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: all 0.2s; color: #555;
        }
        .size-tag.active { border-color: #1a1a1a; background: #1a1a1a; color: #fff; }

        /* Variant stock table */
        .variant-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 10px; }
        .variant-table th {
            background: #f5f5f3; padding: 8px 10px; text-align: left;
