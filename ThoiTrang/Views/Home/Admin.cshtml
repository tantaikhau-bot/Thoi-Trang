function editCollection(c) {
    editingCollectionId = c.id;
    document.getElementById('collectionModalTitle').textContent = 'Sửa bộ sưu tập';
    document.getElementById('col-title').value = c.title || '';
    document.getElementById('col-label').value = c.label || '';
