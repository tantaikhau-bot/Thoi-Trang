<script>
// ============================================================
// SMART SEARCH
// ============================================================
const searchData = [
    { type:'order', icon:'ti-shopping-cart', label:'#MNW2685920518', meta:'Trần Minh Khôi · 1.050.000₫', badge:'order', action:()=>{ switchPanel('orders'); } },
    { type:'order', icon:'ti-shopping-cart', label:'#MNW2685920516', meta:'Lan Phương · 840.000₫', badge:'order', action:()=>{ switchPanel('orders'); } },
    { type:'product', icon:'ti-shirt', label:'Áo thun cotton Essential', meta:'Đen · Size M · Tồn: 45', badge:'product', action:()=>{ switchPanel('products'); } },
    { type:'product', icon:'ti-shirt', label:'Sơ mi linen oversize', meta:'Kem · SKU: MNW-SM-012', badge:'product', action:()=>{ switchPanel('products'); } },
    { type:'product', icon:'ti-shirt', label:'Polo classic cao cấp', meta:'Navy · SKU: MNW-PL-005', badge:'product', action:()=>{ switchPanel('products'); } },
    { type:'customer', icon:'ti-user', label:'Trần Minh Khôi', meta:'0901 234 567 · VIP Gold', badge:'customer', action:()=>{ switchPanel('customers'); } },
    { type:'customer', icon:'ti-user', label:'Lan Phương', meta:'0918 765 432 · VIP Platinum', badge:'customer', action:()=>{ switchPanel('customers'); } },
    { type:'voucher', icon:'ti-ticket', label:'MONO150K', meta:'Giảm 150K · Đã dùng 78/100', badge:'order', action:()=>{ switchPanel('vouchers'); } },
    { type:'page', icon:'ti-layout-dashboard', label:'Dashboard', meta:'Trang tổng quan', badge:'order', action:()=>{ switchPanel('dashboard'); } },
    { type:'page', icon:'ti-chart-line', label:'Thống kê', meta:'Phân tích doanh thu', badge:'order', action:()=>{ switchPanel('analytics'); } },
];
const recentSearches = ['Áo thun', 'Đơn #MNW2685920518', 'Trần Minh Khôi'];

function handleGlobalSearch(val) {
    const dd = document.getElementById('searchDropdown');
    if (!val.trim()) { showSearchSuggestions(); return; }
    const q = val.toLowerCase();
    const results = searchData.filter(d => d.label.toLowerCase().includes(q) || d.meta.toLowerCase().includes(q));
    if (!results.length) {
        dd.innerHTML = `<div style="padding:16px;text-align:center;color:#aaa;font-size:13px;">Không tìm thấy kết quả cho "<strong>${val}</strong>"</div>`;
    } else {
        dd.innerHTML = `<div class="sd-section-title">KẾT QUẢ TÌM KIẾM</div>` +
            results.slice(0,6).map(r => `
                <div class="sd-item" onclick="(${r.action.toString()})()">
                    <i class="ti ${r.icon}"></i>
                    <div class="sd-item-label">${r.label}</div>
                    <div class="sd-item-meta">${r.meta}</div>
                    <span class="sd-item-badge ${r.badge}">${r.type}</span>
                </div>`).join('');
    }
    dd.style.display = 'block';
}

function showSearchSuggestions() {
    const val = document.getElementById('globalSearchInput').value;
    if (val.trim()) return;
    const dd = document.getElementById('searchDropdown');
    dd.innerHTML = `
        <div class="sd-section-title">TÌM KIẾM GẦN ĐÂY</div>
        ${recentSearches.map(s=>`<div class="sd-item" onclick="document.getElementById('globalSearchInput').value='${s}';handleGlobalSearch('${s}')"><i class="ti ti-history"></i><div class="sd-item-label">${s}</div></div>`).join('')}
        <div class="sd-section-title" style="margin-top:4px;">GỢI Ý NHANH</div>
        <div class="sd-item" onclick="switchPanel('orders');hideSearchSuggestions()"><i class="ti ti-shopping-cart"></i><div class="sd-item-label">Đơn hàng chờ xử lý</div><span class="sd-item-badge order">${ADMIN_STAT.pending} đơn</span></div>
        <div class="sd-item" onclick="switchPanel('products');hideSearchSuggestions()"><i class="ti ti-package"></i><div class="sd-item-label">Sản phẩm sắp hết hàng</div><span class="sd-item-badge product">${ADMIN_STAT.lowStock} SP</span></div>
        <div class="sd-item" onclick="switchPanel('reviews');hideSearchSuggestions()"><i class="ti ti-message"></i><div class="sd-item-label">Câu hỏi chưa trả lời</div><span class="sd-item-badge customer">${ADMIN_STAT.unansweredQ}</span></div>
    `;
    dd.style.display = 'block';
}

function hideSearchSuggestions() {
    document.getElementById('searchDropdown').style.display = 'none';
}

// ============================================================
// AI PANEL
// ============================================================
let aiOpen = false;

function toggleAIPanel() {
    aiOpen = !aiOpen;
    document.getElementById('aiPanel').classList.toggle('open', aiOpen);
    document.getElementById('aiBackdrop').style.display = aiOpen ? 'block' : 'none';
    if (aiOpen) setTimeout(() => document.getElementById('aiInput').focus(), 400);
}

function aiCommand(text) {
    document.getElementById('aiInput').value = text;
    sendAIMessage();
}

function sendAIMessage() {
    const input = document.getElementById('aiInput');
    const text = input.value.trim();
    if (!text) return;
    input.value = ''; input.style.height = 'auto';
    appendAIMsg('user', text);
    showAITyping();
    setTimeout(() => {
        removeAITyping();
        const reply = generateAIReply(text);
        appendAIMsg('bot', reply.text, reply.action);
    }, 900 + Math.random()*600);
}

function appendAIMsg(role, text, action) {
    const msgs = document.getElementById('aiMessages');
    const div = document.createElement('div');
    div.className = `ai-msg ${role}`;
    div.innerHTML = `
        <div class="ai-msg-avatar">${role==='bot'?'<i class="ti ti-robot"></i>':(ADMIN_NAME.charAt(0).toUpperCase())}</div>
        <div class="ai-msg-bubble">${text}${action?`<br><br><button class="btn btn-primary btn-sm" style="margin-top:4px;" onclick="${action}"><i class="ti ti-bolt"></i>Thực hiện ngay</button>`:''}</div>
    `;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
}

let typingEl = null;
function showAITyping() {
    const msgs = document.getElementById('aiMessages');
    typingEl = document.createElement('div');
    typingEl.className = 'ai-msg bot';
    typingEl.innerHTML = `<div class="ai-msg-avatar"><i class="ti ti-robot"></i></div><div class="ai-msg-bubble"><div class="ai-typing"><span></span><span></span><span></span></div></div>`;
    msgs.appendChild(typingEl);
    msgs.scrollTop = msgs.scrollHeight;
}
function removeAITyping() { if(typingEl) { typingEl.remove(); typingEl=null; } }

function generateAIReply(text) {
    const t = text.toLowerCase();
    if (t.includes('xuất excel') || t.includes('export')) {
        return { text: '📊 Tôi sẽ xuất file Excel cho bạn. Dữ liệu sẽ bao gồm toàn bộ đơn hàng với các cột: Mã đơn, Khách hàng, Sản phẩm, Tổng tiền, Trạng thái, Ngày đặt.', action: "exportExcel(); showToast('success','Đang xuất Excel','File sẽ được tải về trong giây lát')" };
    }
    if (t.includes('in hóa đơn') || t.includes('print')) {
        return { text: `🖨 Sẵn sàng in hóa đơn! Tôi tìm thấy <strong>${ADMIN_STAT.pending} đơn hàng</strong> đang chờ xử lý. Bạn muốn in tất cả hay chỉ một số đơn?`, action: "printAllInvoices()" };
    }
    if (t.includes('gửi email') || t.includes('email')) {
