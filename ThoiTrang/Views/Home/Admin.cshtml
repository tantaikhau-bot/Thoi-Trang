        const row = document.querySelector('tr[data-cust="' + (name || '').replace(/"/g, '\\"') + '"]');
        uid = row ? row.getAttribute('data-uid') : null;
    }
    currentEmailRecipient = { name, email, uid };
    document.getElementById('ce_recipient').textContent = name;
    document.getElementById('ce_to_email').textContent = email.replace('@@', '@@');
    document.getElementById('ce_subject').value = '';
    document.getElementById('ce_body').value = '';
    document.getElementById('customerEmailModal').classList.add('show');
}

function emailCustomerFromView() {
    if (!currentViewCustomer) return;
    var nm = currentViewCustomer, em = currentViewEmail, uid = currentViewUid;
    closeModal('customerViewModal');
    setTimeout(() => emailCustomer(nm, em, uid), 200);
}

