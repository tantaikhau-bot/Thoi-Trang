    <!-- ===== MODAL THÊM/SỬA ADMIN ===== -->
    <div id="adminModal" style="display:none;position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,0.55);align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:18px;padding:32px;width:min(460px,95vw);position:relative;">
            <button onclick="closeAdminModal()" style="position:absolute;top:16px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#666;"><i class="ti ti-x"></i></button>
            <div style="font-size:18px;font-weight:700;margin-bottom:18px;" id="adminModalTitle">Thêm quản trị viên</div>
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div id="adminNameWrap">
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Họ và tên</label>
                    <input type="text" id="ad-name" placeholder="Nguyễn Văn A" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                </div>
                <div id="adminEmailWrap">
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Email</label>
                    <input type="email" id="ad-email" placeholder="admin@monowear.vn" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                </div>
                <div id="adminPassWrap">
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Mật khẩu</label>
                    <input type="password" id="ad-pass" placeholder="Tối thiểu 8 ký tự" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                </div>
                <div>
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Cấp bậc</label>
                    <select id="ad-title" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;">
                        <option value="Staff">Staff — Đơn hàng + Hỗ trợ KH</option>
                        <option value="Manager">Manager — Sản phẩm + Đơn hàng</option>
                        <option value="SuperAdmin">Super Admin — Toàn quyền</option>
                    </select>
                </div>
                <button onclick="saveAdmin()" id="ad-saveBtn" style="background:#1a1a1a;color:#fff;border:none;padding:12px;border-radius:10px;cursor:pointer;font-size:14px;font-weight:600;margin-top:4px;">Lưu</button>
            </div>
        </div>
    </div>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        // ===== Quản lý quản trị viên (phân quyền) =====
        let editingAdminId = 0;
        function openAdminModal() {
            editingAdminId = 0;
            document.getElementById('adminModalTitle').textContent = 'Thêm quản trị viên';
            document.getElementById('ad-name').value = '';
            document.getElementById('ad-email').value = '';
            document.getElementById('ad-pass').value = '';
            document.getElementById('ad-title').value = 'Staff';
            document.getElementById('adminEmailWrap').style.display = '';
            document.getElementById('adminPassWrap').style.display = '';
            document.getElementById('adminNameWrap').style.display = '';
            document.getElementById('adminModal').style.display = 'flex';
        }
        function editAdmin(id, title, name) {
            editingAdminId = id;
            document.getElementById('adminModalTitle').textContent = 'Sửa quyền: ' + name;
            document.getElementById('ad-title').value = title || 'Staff';
            // Khi sửa chỉ đổi cấp bậc
            document.getElementById('adminEmailWrap').style.display = 'none';
            document.getElementById('adminPassWrap').style.display = 'none';
            document.getElementById('adminNameWrap').style.display = 'none';
            document.getElementById('adminModal').style.display = 'flex';
        }
        function closeAdminModal() { document.getElementById('adminModal').style.display = 'none'; }
        async function saveAdmin() {
            const title = document.getElementById('ad-title').value;
            const btn = document.getElementById('ad-saveBtn'); btn.disabled = true;
            try {
                if (editingAdminId > 0) {
                    const fd = new FormData(); fd.append('userId', editingAdminId); fd.append('title', title);
                    const r = await fetch('/Home/UpdateAdminTitle', { method:'POST', body: fd });
                    if (r.ok) { showToast('success','Đã cập nhật','Quyền quản trị viên đã đổi'); setTimeout(()=>location.reload(),900); }
                    else { const e = await r.json().catch(()=>({})); showToast('error','Lỗi', e.message||'Không cập nhật được'); btn.disabled=false; }
                } else {
                    const name = document.getElementById('ad-name').value.trim();
                    const email = document.getElementById('ad-email').value.trim();
                    const pass = document.getElementById('ad-pass').value;
                    if (!name || !email || !pass) { showToast('warning','Thiếu thông tin','Nhập đủ họ tên, email, mật khẩu'); btn.disabled=false; return; }
                    const fd = new FormData(); fd.append('fullName',name); fd.append('email',email); fd.append('password',pass); fd.append('title',title);
                    const r = await fetch('/Home/AddAdmin', { method:'POST', body: fd });
                    if (r.ok) { showToast('success','Đã thêm admin', name + ' đã được cấp quyền'); setTimeout(()=>location.reload(),900); }
                    else { const e = await r.json().catch(()=>({})); showToast('error','Lỗi', e.message||'Không thêm được'); btn.disabled=false; }
                }
            } catch { showToast('error','Lỗi','Thử lại sau'); btn.disabled=false; }
        }
        async function deleteAdmin(id, name) {
            if (!confirm('Xóa quản trị viên "' + name + '"?')) return;
            const fd = new FormData(); fd.append('userId', id);
            const r = await fetch('/Home/DeleteAdmin', { method:'POST', body: fd });
            if (r.ok) { showToast('success','Đã xóa', name + ' đã bị gỡ quyền'); setTimeout(()=>location.reload(),900); }
            else { const e = await r.json().catch(()=>({})); showToast('error','Lỗi', e.message||'Không xóa được'); }
        }
        document.getElementById('adminModal').addEventListener('click', e => { if (e.target === document.getElementById('adminModal')) closeAdminModal(); });

        // ===== Số liệu thật + tên admin (cho AI Assistant) =====
        const ADMIN_NAME = "@(User.Identity?.Name ?? "Admin")";
        const ADMIN_STAT = {
            pending: @(ViewBag.OrdPending ?? 0),
            confirmed: @(ViewBag.OrdConfirmed ?? 0),
            shipping: @(ViewBag.OrdShipping ?? 0),
            completed: @(ViewBag.OrdCompleted ?? 0),
            totalOrders: @(ViewBag.OrdTotal ?? 0),
            lowStock: @(ViewBag.ProdLow ?? 0),
            outStock: @(ViewBag.ProdOut ?? 0),
            totalProducts: @(ViewBag.TotalProducts ?? 0),
            customers: @(ViewBag.TotalCustomers ?? 0),
            revenue: @(ViewBag.TotalRevenue ?? 0),
            vouchers: @(ViewBag.VoucherActive ?? 0),
            unansweredQ: @(ViewBag.UnansweredQuestions ?? 0),
            reviews: @(ViewBag.TotalReviews ?? 0)
        };
        function fmtMoney(v) {
            if (v >= 1000000000) return (v/1000000000).toFixed(1).replace('.0','') + ' tỷ';
            if (v >= 1000000) return (v/1000000).toFixed(1).replace('.0','') + 'M';
            if (v >= 1000) return Math.round(v/1000) + 'K';
            return v.toLocaleString('vi-VN');
        }

        // ===== Chi tiết đơn hàng (Admin) =====
        async function viewAdminOrder(orderId) {
            const modal = document.getElementById('adminOrderModal');
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            ['aoCode','aoName','aoPhone','aoAddr','aoShipMethod','aoPayMethod','aoSubtotal','aoShipping','aoTotal','aoDate'].forEach(id => document.getElementById(id).textContent = '...');
            document.getElementById('aoItems').innerHTML = '<div style="padding:16px;text-align:center;color:#bbb;">Đang tải...</div>';
            try {
                const r = await fetch(`/Home/GetOrderDetail?orderId=${orderId}`);
                if (!r.ok) { document.getElementById('aoItems').innerHTML = '<div style="padding:16px;text-align:center;color:#e55;">Không tải được đơn hàng</div>'; return; }
                const d = await r.json();
                const statusMap = {
                    'Pending': ['Chờ xử lý','#f59e0b','#fffbeb'], 'Confirmed': ['Đã xác nhận','#3b82f6','#eff6ff'],
                    'Shipping': ['Đang giao','#8b5cf6','#f5f3ff'], 'Completed': ['Hoàn tất','#10b981','#ecfdf5'],
                    'Cancelled': ['Đã hủy','#ef4444','#fef2f2']
                };
                const payMap = { 'Pending': ['Chưa thanh toán','#f59e0b','#fffbeb'], 'Paid': ['Đã thanh toán','#10b981','#ecfdf5'], 'Failed': ['Thất bại','#ef4444','#fef2f2'] };
                const [stxt, sc, sbg] = statusMap[d.status] || [d.status,'#888','#f5f5f5'];
                const st = document.getElementById('aoStatus'); st.textContent = stxt; st.style.color = sc; st.style.background = sbg;
                const [ptxt, pc, pbg] = payMap[d.paymentStatus] || [d.paymentStatus,'#888','#f5f5f5'];
                const ps = document.getElementById('aoPayStatus'); ps.textContent = ptxt; ps.style.color = pc; ps.style.background = pbg;

                document.getElementById('aoCode').textContent = '#' + d.orderCode;
                document.getElementById('aoDate').textContent = d.createdAt;
                document.getElementById('aoName').textContent = d.receiverName;
                document.getElementById('aoPhone').textContent = d.receiverPhone;
                document.getElementById('aoAddr').textContent = d.shippingAddress;
                document.getElementById('aoShipMethod').textContent = (d.shippingMethod || '').toUpperCase();
                document.getElementById('aoPayMethod').textContent = (d.paymentMethod || '').toUpperCase();
                document.getElementById('aoNote').textContent = d.note ? '📝 ' + d.note : '';

                const fmt = v => Number(v).toLocaleString('vi-VN') + '₫';
                document.getElementById('aoSubtotal').textContent = fmt(d.subtotal);
                document.getElementById('aoShipping').textContent = d.shippingFee > 0 ? fmt(d.shippingFee) : 'Miễn phí';
                document.getElementById('aoTotal').textContent = fmt(d.totalAmount);
                const vRow = document.getElementById('aoVoucherRow');
                if (d.voucherDiscount > 0) {
                    document.getElementById('aoVoucherDiscount').textContent = '-' + fmt(d.voucherDiscount);
                    document.getElementById('aoVoucherCode').textContent = d.voucherCode ? '(' + d.voucherCode + ')' : '';
                    vRow.style.display = 'flex';
                } else vRow.style.display = 'none';

                const itemsEl = document.getElementById('aoItems');
                itemsEl.innerHTML = (d.items || []).map(it => `
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;padding:10px 0;border-bottom:1px solid #f5f5f5;">
                        <div style="flex:1;">
                            <div style="font-weight:600;font-size:14px;">${it.productName}</div>
                            ${it.variantInfo ? `<div style="color:#888;font-size:12px;margin-top:2px;">${it.variantInfo}</div>` : ''}
                        </div>
                        <div style="text-align:right;min-width:140px;">
                            <div style="font-size:13px;color:#888;">${Number(it.unitPrice).toLocaleString('vi-VN')}₫ × ${it.quantity}</div>
                            <div style="font-weight:600;">${Number(it.lineTotal).toLocaleString('vi-VN')}₫</div>
                        </div>
                    </div>`).join('') || '<div style="color:#999;padding:10px;">Không có sản phẩm</div>';
            } catch {
                document.getElementById('aoItems').innerHTML = '<div style="padding:16px;text-align:center;color:#e55;">Lỗi kết nối</div>';
            }
        }
        function closeAdminOrderModal() {
            document.getElementById('adminOrderModal').style.display = 'none';
            document.body.style.overflow = '';
        }
        document.getElementById('adminOrderModal').addEventListener('click', e => {
            if (e.target === document.getElementById('adminOrderModal')) closeAdminOrderModal();
        });

        // ===== Sidebar switching =====
        function switchPanel(section) {
            document.querySelectorAll('.sb-item[data-section]').forEach(i => i.classList.toggle('active', i.dataset.section === section));
            document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
            const target = document.querySelector(`[data-panel="${section}"]`);
            if (target) target.classList.add('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
            if (window.innerWidth <= 900) document.getElementById('sidebar').classList.remove('open');
            // Tải dữ liệu khi mở section đánh giá
            if (section === 'reviews') { loadAdminReviews(); loadAdminQuestions(); }
            // Tải thống kê khi mở section analytics
            if (section === 'analytics') { loadStats(document.getElementById('statsPeriod')?.value || 'thismonth'); }
            // Tải combo khi mở section combos
            if (section === 'combos') { loadCombos(); }
        }

        // ===== Quản lý Combo (Admin) =====
        const COMBO_PRODUCTS = [
            @{
                var cbProds = ViewBag.AllProducts as List<ThoiTrang.Models.Entities.Product>;
            }
            @if (cbProds != null)
            {
                foreach (var p in cbProds)
                {
                    @Html.Raw($"{{id:{p.ProductId},name:\"{System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(p.Name ?? "")}\",price:{p.Price}}},")
                }
            }
        ];
        let editingComboId = 0;
        function comboEsc(s){return (s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));}

        async function loadCombos() {
            const body = document.getElementById('comboTableBody');
            try {
                const r = await fetch('/Home/GetCombos');
                const list = await r.json();
                if (!list.length) { body.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#999;padding:20px;">Chưa có combo nào</td></tr>'; return; }
                body.innerHTML = list.map(c => `
                    <tr>
                        <td><strong>${comboEsc(c.name)}</strong></td>
