// ============================================================
// EXCEL EXPORT
// ============================================================
function csvCell(s) {
    s = (s == null ? '' : String(s)).replace(/\s+/g, ' ').trim();
    return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
}
function exportExcel() {
    const rows = document.querySelectorAll('[data-panel="orders"] table.data-table tbody tr[data-oid]');
    if (!rows.length) { showToast('info','Không có dữ liệu','Chưa có đơn hàng để xuất'); return; }
    const statusMap = { Pending:'Chờ xử lý', Confirmed:'Đã xác nhận', Shipping:'Đang giao', Completed:'Hoàn tất', Cancelled:'Đã hủy' };
    let csv = 'Mã đơn,Khách hàng,SĐT,Sản phẩm,Tổng tiền,Thanh toán,Ngày đặt,Trạng thái\n';
    rows.forEach(r => {
        const code = (r.querySelector('td:nth-child(1)')?.textContent || '').replace('#','').trim();
        const name = (r.querySelector('.tbl-customer-name')?.textContent || '').trim();
        const phone = (r.querySelector('.tbl-customer-email')?.textContent || '').trim();
        const prod = (r.querySelector('td:nth-child(3)')?.textContent || '').trim();
        const total = (r.querySelector('td:nth-child(4)')?.textContent || '').replace(/[₫.,]/g,'').trim();
        const pay = (r.querySelector('td:nth-child(5)')?.textContent || '').trim();
        const date = (r.querySelector('td:nth-child(6)')?.textContent || '').trim();
        const status = statusMap[r.getAttribute('data-status')] || r.getAttribute('data-status');
        csv += [code,name,phone,prod,total,pay,date,status].map(csvCell).join(',') + '\n';
    });
    const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8;'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url;
    a.download = `MONOWEAR_DonHang_${new Date().toISOString().slice(0,10)}.csv`;
    a.click(); URL.revokeObjectURL(url);
    showToast('success','Đã xuất Excel',`Đã xuất ${rows.length} đơn hàng ra file CSV`);
}

