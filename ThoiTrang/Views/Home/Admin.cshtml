function deleteVoucher(voucherId, btn) {
    if(!confirm('Bạn có chắc muốn xóa voucher này không?')) return;
    const fd = new FormData(); fd.append('voucherId', voucherId);
    fetch('/Home/DeleteVoucher', { method: 'POST', body: fd })
