                <div style="width: 60px; height: 60px; background: #fbeaea; color: #e63946; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 16px;">
                    <i class="ti ti-logout"></i>
