                            <div class="setting-subpanel" data-subpanel="permissions">
                                @{
                                    var admins = ViewBag.Admins as List<ThoiTrang.Models.Entities.User> ?? new List<ThoiTrang.Models.Entities.User>();
                                    var curAdminEmail = ViewBag.CurrentAdminEmail as string;
                                    bool isSuper = admins.Any(a => a.Email == curAdminEmail && a.AdminTitle == "SuperAdmin");
                                    string[] adAvs = { "av-1", "av-2", "av-3", "av-4" };
                                    (string cls, string ic, string label, string perm) TitleInfo(string? t) => t switch
                                    {
                                        "SuperAdmin" => ("tier-platinum", "ti-crown", "SUPER ADMIN", "Toàn quyền"),
                                        "Manager" => ("tier-gold", "ti-shield", "MANAGER", "Sản phẩm + Đơn hàng"),
                                        _ => ("tier-silver", "", "STAFF", "Đơn hàng + Hỗ trợ KH")
                                    };
                                }
                                <div class="card">
                                    <div class="card-head">
                                        <div class="card-title"><i class="ti ti-users-group"></i>Danh sách người quản trị (@admins.Count)</div>
                                        @if (isSuper)
                                        {
                                            <button class="btn btn-primary btn-sm" onclick="openAdminModal()"><i class="ti ti-user-plus"></i>Thêm admin</button>
                                        }
                                    </div>
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>ADMIN</th>
                                                <th>VAI TRÒ</th>
                                                <th>QUYỀN HẠN</th>
                                                <th>NGÀY TẠO</th>
                                                <th>HÀNH ĐỘNG</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{ int adi = 0; }
                                            @foreach (var a in admins)
                                            {
                                                var (tcls, tic, tlabel, tperm) = TitleInfo(a.AdminTitle);
                                                var isMe = a.Email == curAdminEmail;
                                                var isRoot = a.Email == "admin@monowear.vn";
                                                var ainit = string.IsNullOrEmpty(a.FullName) ? "A" : a.FullName.Trim().Substring(0,1).ToUpper();
                                                <tr data-aid="@a.UserId" data-title="@a.AdminTitle">
                                                    <td><div class="tbl-customer"><div class="tbl-avatar @adAvs[adi % 4]">@ainit</div><div class="tbl-customer-info"><div class="tbl-customer-name">@a.FullName @(isMe ? Html.Raw("<span style=\"background:linear-gradient(135deg,#d4537e,#e2856b);color:#fff;font-size:9px;padding:2px 6px;border-radius:5px;margin-left:6px;\">BẠN</span>") : Html.Raw(""))</div><div class="tbl-customer-email">@a.Email</div></div></div></td>
                                                    <td><span class="tier-badge @tcls">@(string.IsNullOrEmpty(tic) ? "" : Html.Raw($"<i class='ti {tic}'></i>"))@tlabel</span></td>
                                                    <td>@tperm</td>
                                                    <td>@a.CreatedAt.ToString("dd/MM/yyyy")</td>
                                                    <td><div class="tbl-actions">
                                                        @if (isMe || isRoot || !isSuper)
                                                        {
                                                            <button class="action-btn" title="@(isMe ? "Chính bạn" : "Không thể sửa")" disabled><i class="ti ti-user-check"></i></button>
                                                        }
                                                        else
                                                        {
                                                            <button class="action-btn" title="Sửa quyền" onclick="editAdmin(@a.UserId, '@a.AdminTitle', '@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(a.FullName)')"><i class="ti ti-pencil"></i></button>
                                                            <button class="action-btn danger" title="Xóa" onclick="deleteAdmin(@a.UserId, '@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(a.FullName)')"><i class="ti ti-trash"></i></button>
                                                        }
                                                    </div></td>
                                                </tr>
                                                adi++;
                                            }
                                        </tbody>
                                    </table>
                                    @if (!isSuper)
                                    {
                                        <div style="padding:12px;font-size:12px;color:#888;"><i class="ti ti-info-circle"></i> Chỉ Super Admin mới có thể thêm/sửa/xóa quản trị viên.</div>
                                    }
                                </div>

                                <div class="card">
                                    <div class="card-head">
                                        <div class="card-title"><i class="ti ti-lock"></i>Phân quyền theo vai trò</div>
                                    </div>
                                    <div style="display:flex; flex-direction:column; gap:10px;">
                                        <div style="padding:14px; background:linear-gradient(135deg,#fbeaf0,#fff); border-radius:10px;">
                                            <div style="font-weight:600; margin-bottom:6px;"><i class="ti ti-crown" style="color:#d4537e;"></i> SUPER ADMIN</div>
                                            <div style="font-size:12px; color:#666; line-height:1.6;">Toàn quyền trên hệ thống · Quản lý admin khác · Truy cập cài đặt bảo mật · Xóa dữ liệu vĩnh viễn</div>
                                        </div>
                                        <div style="padding:14px; background:#fafaf8; border-radius:10px;">
                                            <div style="font-weight:600; margin-bottom:6px;"><i class="ti ti-shield"></i> MANAGER</div>
                                            <div style="font-size:12px; color:#666; line-height:1.6;">Quản lý sản phẩm · Đơn hàng · Khách hàng · Voucher · Báo cáo · Không truy cập Cài đặt</div>
                                        </div>
                                        <div style="padding:14px; background:#fafaf8; border-radius:10px;">
