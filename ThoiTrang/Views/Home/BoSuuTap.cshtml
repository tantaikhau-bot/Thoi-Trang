@{
    ViewData["Title"] = "Bộ sưu tập - MONO.WEAR";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MONO.WEAR - Bộ sưu tập thời trang</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@2.47.0/tabler-icons.min.css" />
    <style>
        :root {
            --primary: #1a1a1a;
            --bg-light: #f7f7f7;
            --text-muted: #767676;
            --accent: #c49a82; /* Màu beige cổ điển phong cách Editorial */
            --transition-premium: cubic-bezier(0.25, 1, 0.5, 1);
            --transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--primary);
            background: #fff;
            line-height: 1.6;
            overflow-x: clip;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button {
            font-family: inherit;
            cursor: pointer;
            border: none;
            background: none;
        }

        img {
            max-width: 100%;
            display: block;
        }

        /* PREMIUM ANIMATIONS & REVEAL EFFECTS */
        @@keyframes scaleUp {
            from {
                transform: scale(1.1);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        @@keyframes slideUpText {
            from {
                transform: translateY(60px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        @@keyframes ripple {
            0% {
                box-shadow: 0 0 0 0 rgba(255,255,255,0.4), 0 0 0 10px rgba(255,255,255,0.2);
            }

            100% {
                box-shadow: 0 0 0 20px rgba(255,255,255,0), 0 0 0 40px rgba(255,255,255,0);
            }
        }

        @@keyframes marquee {
            0% {
                transform: translateX(0%);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        /* Smooth Reveal System */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 1.2s var(--transition-premium), transform 1.2s var(--transition-premium);
        }

            .reveal.active {
                opacity: 1;
                transform: translateY(0);
            }

        /* Image Mask Unveil Effect */
        .reveal-mask {
            position: relative;
            overflow: hidden;
        }

            .reveal-mask::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: var(--bg-light);
                transition: transform 1.2s cubic-bezier(0.77, 0, 0.175, 1);
                transform-origin: bottom;
                transform: scaleY(1);
                z-index: 2;
            }

            .reveal-mask.active::after {
                transform: scaleY(0);
            }

        /* FIXED LOGO & NAVIGATION */
        .editorial-header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 24px 60px;
            mix-blend-mode: difference;
            color: #fff;
            transition: padding 0.4s var(--transition), background 0.4s var(--transition);
        }

            .editorial-header.scrolled {
                padding: 16px 60px;
                background: rgba(255,255,255,0.98);
                mix-blend-mode: normal;
                color: var(--primary);
                box-shadow: 0 1px 0 rgba(0,0,0,0.03);
            }

        .logo {
            font-size: 22px;
            font-weight: 600;
            letter-spacing: 2px;
        }

            .logo span {
                font-weight: 300;
            }

        .nav-links {
            display: flex;
            gap: 40px;
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

            .nav-links a {
                position: relative;
                padding: 4px 0;
            }

                .nav-links a::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    width: 0;
                    height: 1px;
                    background: currentColor;
                    transition: width 0.3s;
                }

                .nav-links a:hover::after, .nav-links a.active::after {
                    width: 100%;
                }

        .nav-icons {
            display: flex;
            gap: 24px;
            font-size: 20px;
        }

        /* ================= HERO EDITORIAL SECTION ================= */
        .hero-magazine {
            height: 100vh;
            width: 100%;
            position: relative;
            background: #111;
            color: #fff;
            display: flex;
            align-items: center;
            overflow: hidden;
            padding: 0 60px;
        }

        .hero-bg-placeholder {
            position: absolute;
            top: 0;
            right: 0;
            width: 60%;
            height: 100%;
            background: linear-gradient(135deg, #2d2825, #141312);
            display: flex;
            align-items: center;
            justify-content: center;
            animation: scaleUp 2s var(--transition-premium);
        }

            .hero-bg-placeholder i {
                font-size: 260px;
                color: rgba(255,255,255,0.02);
                transform: rotate(-15deg);
            }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 650px;
            animation: slideUpText 1.5s var(--transition-premium) 0.2s both;
        }

        .hero-tag {
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 20px;
        }

        .hero-magazine h1 {
            font-size: 72px;
            font-weight: 400;
            line-height: 1.1;
            letter-spacing: -1px;
            margin-bottom: 30px;
        }

            .hero-magazine h1 span {
                font-family: Georgia, serif;
                font-style: italic;
            }

        .hero-desc {
            font-size: 15px;
            color: #aaa;
            max-width: 460px;
            margin-bottom: 40px;
            line-height: 1.8;
        }

        .editorial-btn {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #fff;
            padding: 16px 32px;
            border: 1px solid rgba(255,255,255,0.2);
            transition: var(--transition);
        }

            .editorial-btn:hover {
                background: #fff;
                color: var(--primary);
                border-color: #fff;
                transform: translateY(-2px);
            }

        /* ================= INFINITE MARQUEE TEXT ================= */
        .editorial-marquee {
            background: var(--bg-light);
            padding: 30px 0;
            border-top: 1px solid #eee;
            border-bottom: 1px solid #eee;
            overflow: hidden;
            display: flex;
            white-space: nowrap;
        }

        .marquee-track {
            display: flex;
            animation: marquee 25s linear infinite;
        }

            .marquee-track h2 {
                font-family: Georgia, serif;
                font-style: italic;
                font-size: 32px;
                font-weight: 400;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: #ccc;
                padding: 0 40px;
            }

                .marquee-track h2 span {
                    color: var(--primary);
                    font-family: -apple-system, sans-serif;
                    font-style: normal;
                    font-weight: 700;
                }

        /* ================= STORIES MASONRY (EXTENDED) ================= */
        .section-stories {
            padding: 140px 60px;
            background: #fff;
        }

        .section-title-wrap {
            max-width: 600px;
            margin-bottom: 100px;
        }

        .section-num {
            font-family: Georgia, serif;
            font-size: 40px;
            font-style: italic;
            color: var(--accent);
            margin-bottom: 10px;
        }

        .section-title-wrap h2 {
            font-size: 44px;
            font-weight: 400;
            letter-spacing: -0.5px;
        }

        .masonry-row {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 80px;
            align-items: center;
            margin-bottom: 140px;
        }

            .masonry-row.reverse {
                grid-template-columns: 0.8fr 1.2fr;
            }

        .story-img-container {
            width: 100%;
            aspect-ratio: 4/5;
            background: var(--bg-light);
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .story-img-container i {
                font-size: 120px;
                color: rgba(0,0,0,0.04);
                transition: transform 1s var(--transition-premium);
                z-index: 1;
            }

            .story-img-container:hover i {
                transform: scale(1.15) rotate(5deg);
            }

        .story-meta {
            padding: 40px 0;
            max-width: 440px;
        }

            .story-meta .year {
                font-size: 13px;
                font-weight: 600;
                color: var(--accent);
                letter-spacing: 2px;
                margin-bottom: 16px;
            }

            .story-meta h3 {
                font-size: 32px;
                font-weight: 400;
                margin-bottom: 20px;
                line-height: 1.3;
            }

            .story-meta p {
                color: var(--text-muted);
                font-size: 15px;
                margin-bottom: 30px;
                line-height: 1.8;
            }

        .text-link {
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding-bottom: 4px;
            border-bottom: 1px solid var(--primary);
            transition: var(--transition);
        }

            .text-link:hover {
                gap: 16px;
                color: var(--accent);
                border-color: var(--accent);
            }

        /* Background variations */
        .bg-concept-1 {
            background: #eae6e3;
        }

        .bg-concept-2 {
            background: #dfdfdf;
        }

        .bg-concept-3 {
            background: #e3eae9;
        }

        .bg-concept-4 {
            background: #e8e3ea;
        }

        /* ================= EDITORIAL MANIFESTO (PARALLAX EFFECT) ================= */
        .editorial-manifesto {
            position: relative;
            height: 70vh;
            background: #111;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 30px;
            overflow: hidden;
        }

        .manifesto-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 120%;
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=1200') no-repeat center center;
            background-size: cover;
            transform: translateY(0px);
            will-change: transform;
            z-index: 1;
        }

        .manifesto-content {
            position: relative;
            z-index: 2;
            max-width: 800px;
        }

            .manifesto-content blockquote {
                font-family: 'Arial Rounded MT';
                font-style: italic;
                font-size: 38px;
                line-height: 1.4;
                margin-bottom: 30px;
                font-weight: 300;
            }

        .manifesto-author {
            font-size: 12px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--accent);
        }

        /* ================= INTERACTIVE LOOKBOOK (SHOP THE LOOK) ================= */
        .section-lookbook {
            padding: 120px 60px;
            background: var(--bg-light);
        }

        .lookbook-showcase {
            display: grid;
            grid-template-columns: 1fr 1fr;
            background: #fff;
            box-shadow: 0 40px 100px rgba(0,0,0,0.04);
            min-height: 750px;
        }

        .lookbook-visual {
            position: relative;
            background: #e6e3df;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

            .lookbook-visual > i {
                font-size: 200px;
                color: rgba(0,0,0,0.02);
            }

        /* Hotspot markers */
        .hotspot {
            position: absolute;
            width: 24px;
            height: 24px;
            background: rgba(255,255,255,0.4);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 10;
            transition: var(--transition);
        }

            .hotspot::before {
                content: '';
                width: 10px;
                height: 10px;
                background: #fff;
                border-radius: 50%;
                box-shadow: 0 2px 6px rgba(0,0,0,0.3);
                transition: var(--transition);
            }

            .hotspot::after {
                content: '';
                position: absolute;
                width: 100%;
                height: 100%;
                border-radius: 50%;
                animation: ripple 2.5s infinite ease-in-out;
            }

            .hotspot:hover, .hotspot.active {
                background: var(--primary);
            }

                .hotspot:hover::before, .hotspot.active::before {
                    background: #fff;
                    transform: scale(1.2);
                }

            .hotspot.active {
                transform: rotate(45deg);
            }

        .spot-1 {
            top: 25%;
            left: 50%;
        }

        .spot-2 {
            top: 55%;
            left: 45%;
        }

        .spot-3 {
            top: 85%;
            left: 53%;
        }

        .lookbook-details {
            padding: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .lookbook-details h3 {
                font-size: 28px;
                font-weight: 400;
                margin-bottom: 8px;
            }

        .lookbook-sub {
            font-size: 13px;
            color: var(--text-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 40px;
        }

        .look-items-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .look-product-card {
            display: flex;
            align-items: center;
            gap: 24px;
            padding: 20px;
            border: 1px solid #eee;
            border-radius: 4px;
            transition: var(--transition);
            opacity: 0.5;
            transform: scale(0.98);
        }

            .look-product-card.highlight {
                opacity: 1;
                transform: scale(1);
                border-color: var(--primary);
                box-shadow: 0 15px 40px rgba(0,0,0,0.06);
            }

        .look-prod-icon {
            width: 64px;
            height: 64px;
            background: var(--bg-light);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #888;
        }

        .look-prod-info {
            flex: 1;
        }

        .look-prod-title {
            font-size: 15px;
            font-weight: 500;
            margin-bottom: 4px;
        }

        .look-prod-price {
            font-size: 14px;
            color: var(--text-muted);
            font-weight: 600;
        }

        .look-prod-action {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 1px solid #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
        }

        .look-product-card.highlight .look-prod-action {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
        }

        .look-prod-action:hover {
            transform: scale(1.1);
        }

        /* ================= HORIZONTAL HORIZON SLIDER ================= */
        .section-horizontal {
            padding: 140px 0 140px 60px;
            background: #1a1a1a;
            color: #fff;
            overflow: hidden;
        }

        .horiz-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            padding-right: 60px;
            margin-bottom: 60px;
        }

            .horiz-header h2 {
                font-size: 38px;
                font-weight: 400;
            }

        .horiz-nav-btns {
            display: flex;
            gap: 12px;
        }

        .horiz-btn {
            width: 50px;
            height: 50px;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            transition: var(--transition);
        }

            .horiz-btn:hover {
                background: #fff;
                color: var(--primary);
                border-color: #fff;
            }

        .horiz-track {
            display: flex;
            gap: 32px;
            overflow-x: auto;
            scrollbar-width: none;
            padding-bottom: 20px;
            scroll-behavior: smooth;
        }

            .horiz-track::-webkit-scrollbar {
                display: none;
            }

        .horiz-item {
            min-width: 400px;
            width: 400px;
            display: flex;
            flex-direction: column;
        }

        .horiz-img-box {
            width: 100%;
            aspect-ratio: 3/4;
            background: #2a2a2a;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 64px;
            color: rgba(255,255,255,0.04);
            margin-bottom: 20px;
            transition: var(--transition);
            position: relative;
        }

        .horiz-item:hover .horiz-img-box {
            transform: translateY(-10px);
        }

        .horiz-item h4 {
            font-size: 18px;
            font-weight: 400;
            margin-bottom: 6px;
            letter-spacing: 0.5px;
        }

        .horiz-item span {
            font-size: 13px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        /* ================= FOOTER EDITORIAL ================= */
        .editorial-footer {
            background: #000;
            color: #666;
            padding: 100px 60px 40px;
            font-size: 13px;
            letter-spacing: 0.5px;
        }

        .footer-main {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 80px;
        }

        .footer-brand h3 {
            font-size: 24px;
            font-weight: 500;
            color: #fff;
            margin-bottom: 16px;
            letter-spacing: 2px;
        }

        .footer-brand p {
            max-width: 300px;
            line-height: 1.8;
            color: #888;
        }

        .footer-navs {
            display: flex;
            gap: 100px;
        }

        .footer-col h4 {
            color: #fff;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 24px;
        }

        .footer-links {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

            .footer-links a {
                transition: color 0.3s;
            }

                .footer-links a:hover {
                    color: #fff;
                }

        .footer-bottom {
            border-top: 1px solid #111;
            padding-top: 40px;
            display: flex;
            justify-content: space-between;
            color: #444;
        }

        /* FLOATING ACTION UTILS */
        .scroll-top {
            position: fixed;
            bottom: 40px;
            right: 40px;
            width: 44px;
            height: 44px;
            background: var(--primary);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transform: translateY(10px);
            transition: var(--transition);
            z-index: 999;
        }

            .scroll-top.show {
                opacity: 1;
                transform: translateY(0);
            }

        /* RESPONSIVE DESIGN BREAKPOINTS */
        @@media (max-width: 992px) {
            .editorial-header, .hero-magazine, .section-stories, .section-lookbook, .section-horizontal, .editorial-footer {
                padding-left: 30px;
                padding-right: 30px;
            }

                .hero-magazine h1 {
                    font-size: 52px;
                }

            .hero-bg-placeholder {
                width: 50%;
            }

            .masonry-row, .masonry-row.reverse {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            .lookbook-showcase {
                grid-template-columns: 1fr;
            }

            .lookbook-details {
                padding: 40px;
            }

            .footer-main {
                flex-direction: column;
                gap: 50px;
            }
        }

        @@media (max-width: 768px) {
            .nav-links, .nav-icons a:not(:last-child) {
                display: none;
            }

            .hero-bg-placeholder {
                width: 100%;
                opacity: 0.15;
            }

            .hero-magazine h1 {
                font-size: 42px;
            }

            .horiz-item {
                min-width: 290px;
                width: 290px;
            }

            .footer-navs {
                gap: 40px;
                flex-wrap: wrap;
            }

            .editorial-manifesto hblockquote {
                font-size: 26px;
            }
        }


        .header-icons {
            display: flex;
            align-items: center;
            gap: 26px;
            font-size: 22px;
        }

            .header-icons a {
                position: relative;
             
                transition: transform 0.3s;
            }

                .header-icons a:hover {
                    transform: translateY(-3px);
                }

        .bell-icon {
            animation: ring 4s ease infinite;
            transform-origin: top center;
        }

        .cart-badge, .notif-badge {
            position: absolute;
            top: -6px;
            right: -8px;
            background: #d4537e;
            color: #fff;
            font-size: 10px;
            min-width: 16px;
            height: 16px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            font-family: sans-serif;
            animation: pulse 2s infinite;
        }

        .cart-badge {
            background: #1a1a1a;
        }
    </style>
</head>
<body>

    <header class="editorial-header" id="header">
        <a href="/" class="logo">MONO<span>.WEAR</span></a>
        <nav class="nav-links">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a>

            <a asp-controller="Home" asp-action="Nam" asp-route-id="nam">Nam</a>

            <a asp-controller="Home" asp-action="Nu" asp-route-id="nu">Nữ</a>

            <a asp-controller="Home" asp-action="MoiVe">Mới về</a>

            <a asp-controller="Home" asp-action="BoSuuTap" class="active">Bộ sưu tập</a>

            <a asp-controller="Home" asp-action="Sale">Sale</a>

            <a asp-controller="Home" asp-action="GioiThieu">Về chúng tôi</a>
        </nav>
        <div class="header-icons">
            <a asp-controller="Home" asp-action="ThongBao" aria-label="Thông báo">
                <i class="ti ti-bell bell-icon"></i>
                <span class="notif-badge">5</span>
            </a>

            <a asp-controller="Home" asp-action="TaiKhoan" aria-label="Tài khoản">
                <i class="ti ti-user"></i>
            </a>

            <a asp-controller="Home" asp-action="YeuThich" aria-label="Yêu thích">
                <i class="ti ti-heart"></i>
            </a>

