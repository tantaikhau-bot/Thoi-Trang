            </div>
            <div class="footer-navs">
                <div class="footer-col">
                    <h4>ĐIỀU HƯỚNG</h4>
                    <div class="footer-links">
                        <a href="#">Tất cả sản phẩm</a>
                        <a href="#">Bộ sưu tập lưu trữ</a>
                        <a href="#">Bài viết Editorial</a>
                    </div>
                </div>
                <div class="footer-col">
                    <h4>KẾT NỐI</h4>
                    <div class="footer-links">
                        <a href="#">Instagram</a>
                        <a href="#">Facebook Studio</a>
                        <a href="#">Pinterest Board</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div>&copy; 2026 MONO.WEAR STUDIO. Cấu trúc thiết kế thời trang hiện đại.</div>
            <div>Bản quyền thiết kế thuộc về MONO.WEAR</div>
        </div>
    </footer>

    <button class="scroll-top" id="scrollTopBtn" aria-label="Cuộn lên đầu trang">
        <i class="ti ti-arrow-up"></i>
    </button>

    <script>
        // Reveal elements and masks on scrolling smoothly
        const revealLayout = () => {
            const reveals = document.querySelectorAll('.reveal, .reveal-mask');
            reveals.forEach(item => {
                const triggerPoint = window.innerHeight - 80;
                const itemTop = item.getBoundingClientRect().top;
                if (itemTop < triggerPoint) item.classList.add('active');
            });
        };
        window.addEventListener('scroll', revealLayout);
        window.addEventListener('load', revealLayout);

        // NEW EFFECT: Smooth Parallax Calculation for Manifesto Section
        const parallaxBg = document.getElementById('parallaxBg');
        window.addEventListener('scroll', () => {
            if(!parallaxBg) return;
            let offset = window.scrollY;
            const parent = parallaxBg.parentElement;
            const parentTop = parent.offsetTop;
            const parentHeight = parent.offsetHeight;

            // Chỉ tính toán khi phân đoạn hiển thị trên khung nhìn
            if (offset + window.innerHeight >= parentTop && offset <= parentTop + parentHeight) {
                let speed = (offset - parentTop) * 0.4;
                parallaxBg.style.transform = `translateY(${speed}px)`;
            }
        });

        // Sticky Header shrink logic transitions
        const header = document.getElementById('header');
        const scrollTopBtn = document.getElementById('scrollTopBtn');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) header.classList.add('scrolled');
            else header.classList.remove('scrolled');

            if (window.scrollY > 500) scrollTopBtn.classList.add('show');
            else scrollTopBtn.classList.remove('show');
        });
        scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // Interactive Hotspots (Two-way Engine)
        const hotspots = document.querySelectorAll('.hotspot');
        const cards = document.querySelectorAll('.look-product-card');

        // Logic 1: Click Hotspot -> Active Card
        hotspots.forEach(spot => {
            spot.addEventListener('click', () => {
                hotspots.forEach(s => s.classList.remove('active'));
                spot.classList.add('active');

                const targetId = spot.getAttribute('data-target');
                cards.forEach(card => {
                    card.classList.remove('highlight');
                    if (card.id === targetId) {
                        card.classList.add('highlight');
                        card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    }
                });
            });
        });

        // NEW EFFECT: Hover Card -> Active Hotspot tương ứng ngược lại
        cards.forEach(card => {
            card.addEventListener('mouseenter', () => {
                cards.forEach(c => c.classList.remove('highlight'));
                card.classList.add('highlight');

                const targetSpotClass = card.getAttribute('data-spot');
                hotspots.forEach(spot => {
                    spot.classList.remove('active');
                    if (spot.classList.contains(targetSpotClass)) {
                        spot.classList.add('active');
                    }
                });
            });
        });

        // Horizontal Carousel sliding triggers
        const track = document.getElementById('horizTrack');
        document.getElementById('slideRightBtn').addEventListener('click', () => {
            track.scrollLeft += 430;
        });
        document.getElementById('slideLeftBtn').addEventListener('click', () => {
            track.scrollLeft -= 430;
        });
    </script>
    @await Html.PartialAsync("_ChatWidget")
</body>
</html>