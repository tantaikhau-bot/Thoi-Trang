                        </div>
                        <button class="look-prod-action" title="Mua ngay"><i class="ti ti-shopping-bag-plus"></i></button>
                    </div>

                    <div class="look-product-card" id="item3" data-spot="spot-3">
                        <div class="look-prod-icon"><i class="ti ti-shoe"></i></div>
                        <div class="look-prod-info">
                            <div class="look-prod-title">Giày Loafers Da Lộn Cao Cấp</div>
