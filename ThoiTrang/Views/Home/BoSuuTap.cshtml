        @{
            var collections = ViewBag.Collections as List<ThoiTrang.Models.Entities.Collection> ?? new List<ThoiTrang.Models.Entities.Collection>();
            int colIdx = 0;
        }
        @foreach (var col in collections)
        {
            var reverse = colIdx % 2 == 1;
            var cover = string.IsNullOrEmpty(col.CoverClass) ? "bg-concept-1" : col.CoverClass;
            var icon = string.IsNullOrEmpty(col.Icon) ? "ti-hanger" : col.Icon;
            var link = string.IsNullOrEmpty(col.LinkUrl) ? "#" : col.LinkUrl;
            var linkText = string.IsNullOrEmpty(col.LinkText) ? "Khám phá chi tiết" : col.LinkText;
            <div class="masonry-row @(reverse ? "reverse" : "") reveal">
                @if (!reverse)
                {
                    <div class="story-img-container @cover reveal-mask"><i class="ti @icon"></i></div>
                }
                <div class="story-meta">
                    <div class="year">@col.Label</div>
                    <h3>@col.Title</h3>
                    <p>@col.Description</p>
                    <a href="@link" class="text-link">@linkText <i class="ti ti-arrow-right"></i></a>
                </div>
                @if (reverse)
                {
                    <div class="story-img-container @cover reveal-mask"><i class="ti @icon"></i></div>
                }
            </div>
            colIdx++;
        }
