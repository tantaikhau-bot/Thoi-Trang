        <div class="horiz-track" id="horizTrack">
            <div class="horiz-item">
                <div class="horiz-img-box bg-concept-1"><i class="ti ti-sun"></i></div>
                <h4>01 // Hạ Vĩnh Cửu</h4>
                <span>Summer Drop 2026</span>
            </div>
            <div class="horiz-item">
                <div class="horiz-img-box bg-concept-2"><i class="ti ti-wind"></i></div>
