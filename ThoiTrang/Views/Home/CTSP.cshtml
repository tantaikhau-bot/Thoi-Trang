@model ThoiTrang.Models.Entities.Product
@{
    ViewData["Title"] = Model?.Name ?? "Chi tiết sản phẩm";
    var catName = Model?.Category?.Name ?? "Sản phẩm";
    var pName = Model?.Name ?? "Sản phẩm";
    var price = Model?.Price ?? 0;
    var oldPrice = Model?.OldPrice;
    int discountPct = 0;
    decimal saving = 0;
    if (oldPrice.HasValue && oldPrice > 0)
    {
        discountPct = (int)Math.Round((1 - (double)(price / oldPrice.Value)) * 100);
        saving = oldPrice.Value - price;
    }
    var colorList = Model?.Variants
        .Where(v => v.Color != null)
        .Select(v => v.Color!).GroupBy(c => c.ColorId).Select(g => g.First()).ToList()
        ?? new List<ThoiTrang.Models.Entities.Color>();
    var sizeList = Model?.Variants
        .Where(v => v.Size != null)
        .Select(v => v.Size!).GroupBy(s => s.SizeId).Select(g => g.First())
        .OrderBy(s => s.DisplayOrder).ToList()
        ?? new List<ThoiTrang.Models.Entities.Size>();

    // Dữ liệu biến thể cho JS (id màu/size + tồn kho)
    var variantData = (Model?.Variants ?? new List<ThoiTrang.Models.Entities.ProductVariant>())
        .Select(v => new {
            id = v.VariantId,
            colorId = v.ColorId,
            sizeId = v.SizeId,
            stock = v.Stock
        }).ToList();
    var variantsJson = System.Text.Json.JsonSerializer.Serialize(variantData);
    var productId = Model?.ProductId ?? 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MONO.WEAR - Áo thun cotton Essential</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@2.47.0/tabler-icons.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            overflow-x: clip; /* Chặn tuyệt đối việc tràn viền ngang */
            position: relative;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            color: #1a1a1a;
            background: #f5f5f3;
            line-height: 1.5;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button {
            font-family: inherit;
            cursor: pointer;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.08);
            }
        }

        @@keyframes shimmer {
            0% {
                background-position: -200% 0;
            }

            100% {
                background-position: 200% 0;
            }
        }

        @@keyframes heartBeat {
            0%, 100% {
                transform: scale(1);
            }

            25% {
                transform: scale(1.3);
            }

            50% {
                transform: scale(1.1);
            }

            75% {
                transform: scale(1.2);
            }
        }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-12px);
            }
        }

        @@keyframes ring {
            0%, 100% {
                transform: rotate(0);
            }

            10%, 30% {
                transform: rotate(-15deg);
            }

            20%, 40% {
                transform: rotate(15deg);
            }

            50% {
                transform: rotate(0);
            }
        }

        @@keyframes slideInRightToast {
            from {
                transform: translateX(120%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes slideOutRightToast {
            from {
                transform: translateX(0);
                opacity: 1;
            }

            to {
                transform: translateX(120%);
                opacity: 0;
            }
        }

        @@keyframes flyToCart {
            0% {
                transform: scale(1) translateY(0);
                opacity: 1;
            }

            70% {
                transform: scale(0.6) translateY(-100px);
                opacity: 0.7;
            }

            100% {
                transform: scale(0.2) translateY(-200px) translateX(300px);
                opacity: 0;
            }
        }

        @@keyframes scaleIn {
            from {
                transform: scale(0.95);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        .announce {
            background: #1a1a1a;
            color: #fff;
            text-align: center;
            padding: 10px 16px;
            font-size: 12px;
            letter-spacing: 0.5px;
            overflow: hidden;
            position: relative;
        }

            .announce::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
                animation: shimmer 4s infinite;
            }

        .header {
            background: #fff;
            border-bottom: 1px solid #eee;
            position: sticky;
            top: 0;
            z-index: 100;
            transition: box-shadow 0.3s ease;
        }

            .header.scrolled {
                box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            }

        .header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 60px;
        }

        .logo {
            font-size: 26px;
            font-weight: 500;
            letter-spacing: 1.5px;
            transition: transform 0.3s;
        }

            .logo:hover {
                transform: scale(1.05);
            }

            .logo span {
                font-weight: 300;
            }

        .search-box {
            flex: 1;
            max-width: 480px;
            margin: 0 60px;
            display: flex;
            align-items: center;
            background: #f5f5f3;
            border-radius: 10px;
            padding: 11px 16px;
        }

            .search-box i {
                font-size: 18px;
                color: #888;
            }

            .search-box input {
                border: none;
                background: transparent;
                outline: none;
                flex: 1;
                margin-left: 10px;
                font-size: 14px;
            }

        .header-icons {
            display: flex;
            align-items: center;
            gap: 24px;
            font-size: 22px;
        }

            .header-icons a {
                position: relative;
                color: #1a1a1a;
                transition: transform 0.3s;
            }

                .header-icons a:hover {
                    transform: translateY(-3px);
                }

        .bell-icon {
            animation: ring 4s ease infinite;
            transform-origin: top center;
        }

        .cart-badge, .notif-badge {
            position: absolute;
            top: -6px;
            right: -8px;
            background: #d4537e;
            color: #fff;
            font-size: 10px;
            min-width: 18px;
            height: 18px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            font-family: sans-serif;
            animation: pulse 2s infinite;
        }

        .cart-badge {
            background: #1a1a1a;
        }

        .nav {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 48px;
            padding: 14px 60px;
            border-top: 1px solid #f0f0f0;
            font-size: 14px;
            letter-spacing: 0.5px;
        }

            .nav a {
                color: #666;
                position: relative;
                padding: 4px 0;
                transition: color 0.3s;
            }

                .nav a::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 50%;
                    width: 0;
                    height: 2px;
                    background: #1a1a1a;
                    transition: all 0.3s;
                    transform: translateX(-50%);
                }

                .nav a:hover {
                    color: #1a1a1a;
                }

                    .nav a:hover::after {
                        width: 100%;
                    }

        .breadcrumb-bar {
            padding: 20px 60px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #888;
            animation: fadeIn 0.5s ease;
        }

            .breadcrumb-bar a {
                transition: color 0.3s;
            }

                .breadcrumb-bar a:hover {
                    color: #1a1a1a;
                }

            .breadcrumb-bar i {
                font-size: 14px;
            }

            .breadcrumb-bar .current {
                color: #1a1a1a;
            }

        .product-main {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            padding: 0 60px 60px;
            align-items: start;
        }

        /* GALLERY */
        .gallery {
            display: grid;
            grid-template-columns: 90px 1fr;
            gap: 16px;
            animation: slideInLeft 0.6s ease;
            position: sticky;
            top: 130px;
        }

        .thumb-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .thumb-item {
            width: 90px;
            height: 90px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s;
            border: 2px solid transparent;
            position: relative;
            overflow: hidden;
        }

            .thumb-item.dark i {
                color: rgba(255,255,255,0.25);
            }

            .thumb-item i {
                font-size: 36px;
                color: rgba(0,0,0,0.2);
                transition: transform 0.3s;
            }

            .thumb-item:hover {
                transform: translateY(-2px);
            }

                .thumb-item:hover i {
                    transform: scale(1.15);
                }

            .thumb-item.active {
                border-color: #1a1a1a;
                box-shadow: 0 0 0 3px rgba(26,26,26,0.08);
            }

        .main-image-wrap {
            position: relative;
            border-radius: 18px;
            overflow: hidden;
        }

        .main-image {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            transition: background 0.4s ease;
        }

            .main-image i.main-icon {
                font-size: 180px;
                color: rgba(0,0,0,0.18);
                transition: transform 0.5s ease;
                animation: scaleIn 0.5s ease;
            }

            .main-image.dark i.main-icon {
                color: rgba(255,255,255,0.2);
            }

            .main-image:hover i.main-icon {
                transform: scale(1.08);
            }

        .bg-cream {
            background: #f1efe8;
        }

        .bg-dark {
            background: #2c2c2a;
        }

        .bg-gray {
            background: #d3d1c7;
        }

        .bg-blue {
            background: #2c3e5e;
        }

        .bg-brown {
            background: #6b4423;
        }

        .bg-white {
            background: #fafaf6;
        }

        .image-badges {
            position: absolute;
            top: 16px;
            left: 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            z-index: 2;
        }

        .img-badge {
            font-size: 12px;
            font-weight: 500;
            padding: 5px 12px;
            border-radius: 7px;
            letter-spacing: 0.5px;
            width: fit-content;
        }

        .badge-new {
            background: #1a1a1a;
            color: #fff;
        }

        .badge-sale {
            background: #d4537e;
            color: #fff;
        }

        .zoom-hint {
            position: absolute;
            bottom: 16px;
            right: 16px;
            background: rgba(255,255,255,0.95);
            color: #555;
            padding: 7px 12px;
            border-radius: 8px;
            font-size: 12px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            z-index: 2;
        }

        .main-image.dark .zoom-hint {
            background: rgba(0,0,0,0.55);
            color: #fff;
        }

        .zoom-hint i {
            font-size: 14px;
        }

        .img-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.95);
            color: #1a1a1a;
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.3s;
            z-index: 2;
            opacity: 0;
        }

        .main-image-wrap:hover .img-nav {
            opacity: 1;
        }

        .img-nav:hover {
            background: #1a1a1a;
            color: #fff;
        }

        .img-nav.prev {
            left: 16px;
        }

        .img-nav.next {
            right: 16px;
        }

        .main-image.dark .img-nav {
            background: rgba(0,0,0,0.55);
            color: #fff;
        }

            .main-image.dark .img-nav:hover {
                background: #fff;
                color: #1a1a1a;
            }

        /* INFO */
        .product-info {
            animation: slideInRight 0.6s ease;
            padding-top: 8px;
        }

        .info-cat {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            letter-spacing: 2px;
            color: #888;
            margin-bottom: 12px;
            padding: 4px 12px;
            background: #fff;
            border-radius: 999px;
            border: 1px solid #ececec;
        }

            .info-cat i {
                font-size: 14px;
                color: #d4537e;
            }

        .product-title {
            font-size: 32px;
            font-weight: 500;
            letter-spacing: -0.5px;
            line-height: 1.2;
            margin-bottom: 14px;
        }

        .product-meta-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 18px;
            margin-bottom: 20px;
            font-size: 13px;
        }

        .meta-item {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            color: #666;
        }

            .meta-item.rating {
                color: #1a1a1a;
                font-weight: 500;
            }

                .meta-item.rating i {
                    color: #f0b400;
                    font-size: 16px;
                }

            .meta-item .gray {
                color: #999;
                font-weight: 400;
            }

            .meta-item i {
                font-size: 15px;
            }

        .meta-divider {
            width: 1px;
            height: 14px;
            background: #ddd;
        }

        .price-box {
            background: linear-gradient(135deg, #fefaf5, #fde8ee);
            border-radius: 16px;
            padding: 20px 22px;
            margin-bottom: 24px;
            border: 1px solid #f5e0d3;
            position: relative;
            overflow: hidden;
        }

            .price-box::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -10%;
                width: 200px;
                height: 200px;
                background: radial-gradient(circle, rgba(212,83,126,0.1), transparent 60%);
                filter: blur(30px);
                pointer-events: none;
            }

        .price-row {
            display: flex;
            align-items: baseline;
            gap: 12px;
            margin-bottom: 6px;
            position: relative;
            z-index: 2;
            flex-wrap: wrap;
        }

        .price-current {
            font-size: 32px;
            font-weight: 600;
            color: #1a1a1a;
            letter-spacing: -1px;
        }

        .price-old {
            font-size: 16px;
            color: #aaa;
            text-decoration: line-through;
        }

        .price-discount {
            background: #d4537e;
            color: #fff;
            font-size: 12px;
            font-weight: 500;
            padding: 3px 10px;
            border-radius: 6px;
        }

        .price-saving {
            font-size: 13px;
            color: #d4537e;
            font-weight: 500;
            position: relative;
            z-index: 2;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .price-saving i {
                font-size: 14px;
            }

        .picker-section {
            margin-bottom: 22px;
        }

        .picker-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 14px;
            margin-bottom: 12px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .picker-label-left {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .picker-label-title {
            font-weight: 500;
            color: #555;
        }

        .picker-label-value {
            color: #1a1a1a;
            font-weight: 500;
        }

        .picker-label-link {
            font-size: 12px;
            color: #d4537e;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            transition: opacity 0.3s;
        }

            .picker-label-link:hover {
                opacity: 0.7;
            }

        .color-options {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .color-option {
            position: relative;
            width: 44px;
            height: 44px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            border: 2px solid transparent;
            padding: 4px;
        }

            .color-option:hover {
                transform: translateY(-2px);
            }

            .color-option.active {
                border-color: #1a1a1a;
            }

                .color-option.active::after {
                    content: '✓';
                    position: absolute;
                    top: -6px;
                    right: -6px;
                    width: 18px;
                    height: 18px;
                    background: #1a1a1a;
                    color: #fff;
                    border-radius: 50%;
                    font-size: 11px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    border: 2px solid #fff;
                }

        .color-circle {
            width: 100%;
            height: 100%;
            border-radius: 8px;
            border: 1px solid rgba(0,0,0,0.08);
        }

        .swatch-black {
            background: #1a1a1a;
        }

        .swatch-white {
            background: #fafaf6;
        }

        .swatch-gray {
            background: #888;
        }

        .swatch-cream {
            background: #f1efe8;
        }

        .swatch-blue {
            background: #2c3e5e;
        }

        .size-grid {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .size-btn {
            min-width: 56px;
            padding: 12px 16px;
            border: 1.5px solid #e0e0db;
            background: #fff;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.25s;
            position: relative;
        }

            .size-btn:hover {
                border-color: #1a1a1a;
                transform: translateY(-2px);
            }

            .size-btn.active {
                background: #1a1a1a;
                color: #fff;
                border-color: #1a1a1a;
            }

            .size-btn.disabled {
                color: #ccc;
                cursor: not-allowed;
                background: #f5f5f3;
                border-color: #f5f5f3;
                position: relative;
            }

                .size-btn.disabled::before {
                    content: '';
                    position: absolute;
                    top: 50%;
                    left: 6px;
                    right: 6px;
                    height: 1px;
                    background: #ccc;
                    transform: rotate(-20deg);
                }

                .size-btn.disabled:hover {
                    transform: none;
                    border-color: #f5f5f3;
                }

        .stock-info {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 12px;
            font-size: 13px;
            padding: 8px 14px;
            border-radius: 10px;
            background: #e6f7ef;
            color: #2eb872;
        }

            .stock-info i {
                font-size: 15px;
            }

        .qty-action-row {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .qty-wrap {
            display: flex;
            align-items: center;
            border: 1.5px solid #e0e0db;
            border-radius: 12px;
            background: #fff;
            overflow: hidden;
        }

        .qty-btn {
            width: 44px;
            height: 48px;
            background: transparent;
            border: none;
            font-size: 16px;
            color: #555;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .qty-btn:hover {
                background: #1a1a1a;
                color: #fff;
            }

        .qty-input {
            width: 50px;
            height: 48px;
            border: none;
            text-align: center;
            font-size: 15px;
            font-weight: 500;
            outline: none;
            background: transparent;
        }

            .qty-input::-webkit-inner-spin-button {
                display: none;
            }

        .btn-action {
            flex: 1;
            padding: 0 22px;
            height: 48px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            border: 1.5px solid;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            position: relative;
            overflow: hidden;
            white-space: nowrap;
        }

            .btn-action.cart {
                background: #fff;
                color: #1a1a1a;
                border-color: #1a1a1a;
                min-width: 160px;
            }

                .btn-action.cart:hover {
                    background: #1a1a1a;
                    color: #fff;
                    transform: translateY(-2px);
                }

            .btn-action.buy {
                background: linear-gradient(135deg, #1a1a1a, #2c2c2a);
                color: #fff;
                border-color: transparent;
                min-width: 160px;
            }

                .btn-action.buy::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: -100%;
                    width: 100%;
                    height: 100%;
                    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
                    transition: left 0.6s;
                }

                .btn-action.buy:hover::before {
                    left: 100%;
                }

                .btn-action.buy:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 12px 28px rgba(0,0,0,0.2);
                }

            .btn-action.heart-btn {
                min-width: auto;
                width: 48px;
                padding: 0;
