        /* FOOTER */
        .footer {
            background: #111111;
            color: #ffffff;
            padding: 70px 0 0 0; /* Bỏ padding đáy để thanh marquee bám sát khít */
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            margin-top: 80px;
            width: 100%;
            overflow: hidden;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Lưới chia 4 cột */
        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
            gap: 40px;
            margin-bottom: 40px;
        }

        .footer-col-title {
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 24px;
            color: #ffffff;
        }

        /* Cột 1: Logo & Giới thiệu */
        .footer-brand .footer-logo {
            font-size: 22px;
            font-weight: 700;
            letter-spacing: 3px;
            margin-bottom: 16px;
        }

        .footer-brand p {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.6;
        }

        /* Các cột Link danh mục */
        .footer-links-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

            .footer-links-list a {
                font-size: 13px;
                color: rgba(255, 255, 255, 0.5);
                transition: all 0.25s ease;
                display: inline-block;
            }

                .footer-links-list a:hover {
                    color: #ffffff;
                    transform: translateX(4px);
                }

        /* Cột Newsletter */
        .footer-newsletter p {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 16px;
            line-height: 1.6;
        }

        .newsletter-form {
            display: flex;
            position: relative;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            overflow: hidden;
            transition: border-color 0.3s ease;
        }

            .newsletter-form:focus-within {
                border-color: rgba(255, 255, 255, 0.4);
            }

        .newsletter-input {
            flex: 1;
            background: transparent;
            border: none;
            padding: 12px 16px;
            color: #ffffff;
            font-size: 13px;
            outline: none;
        }

            .newsletter-input::placeholder {
                color: rgba(255, 255, 255, 0.3);
            }

        .newsletter-btn {
            background: transparent;
            border: none;
            color: #ffffff;
            padding: 0 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: color 0.2s ease;
        }

            .newsletter-btn:hover {
                color: rgba(255, 255, 255, 0.7);
            }

        /* Dòng thông tin bản quyền ở giữa */
        .footer-mid-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            padding-bottom: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 24px;
        }

        .footer-text {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.4);
        }

        .footer-payments {
            display: flex;
            gap: 16px;
            color: rgba(255, 255, 255, 0.3);
            font-size: 20px;
        }

        /* ============ THANH MARQUEE ĐEN TUYỀN CHẠY ĐÁY TRANG (FULL-WIDTH) ============ */
        .footer-bottom-marquee {
            width: 100vw;
            position: relative;
            left: 50%;
            right: 50%;
            margin-left: -50vw;
            margin-right: -50vw;
            background: #090909; /* Đen sẫm hơn hẳn tạo khối tương phản chân trang */
            padding: 14px 0;
            display: flex;
            overflow: hidden;
            white-space: nowrap;
            user-select: none;
        }

        .marquee-wrapper {
            display: flex;
            align-items: center;
            gap: 60px;
            animation: footerMarqueeScroll 28s linear infinite;
        }

        .footer-bottom-marquee:hover .marquee-wrapper {
            animation-play-state: paused; /* Rê chuột vào sẽ tạm dừng để đọc */
        }

        .marquee-text-item {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.75);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

            .marquee-text-item i {
                color: #e2856b; /* Icon màu cam ấm tinh tế */
                font-size: 13px;
            }

        @@keyframes footerMarqueeScroll {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-33.333%);
            }
        }

        /* Responsive */
        @@media (max-width: 992px) {
            .footer-grid {
                grid-template-columns: 1fr 1fr;
                gap: 30px;
            }
        }

        @@media (max-width: 576px) {
            .footer {
                padding-top: 50px;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .footer-mid-row {
                flex-direction: column;
                text-align: center;
            }
        }

        .scroll-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 50px;
            height: 50px;
            background: #1a1a1a;
            color: #fff;
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            cursor: pointer;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.3s ease;
            z-index: 99;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

            .scroll-top.show {
                opacity: 1;
                transform: translateY(0);
            }

            .scroll-top:hover {
                transform: translateY(-4px);
                background: #000;
            }

        .fly-clone {
            position: fixed;
            border-radius: 14px;
            pointer-events: none;
            z-index: 9999;
            animation: flyToCart 0.8s ease-in forwards;
        }

        .toast-container {
            position: fixed;
            top: 100px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
        }

        .toast {
            background: #fff;
            border-radius: 12px;
            padding: 14px 18px;
            box-shadow: 0 12px 32px rgba(0,0,0,0.15);
            display: flex;
            align-items: center;
            gap: 14px;
            min-width: 320px;
            max-width: 380px;
            border-left: 4px solid #1a1a1a;
            animation: slideInRightToast 0.4s ease forwards;
            pointer-events: auto;
        }

            .toast.success {
                border-left-color: #2eb872;
            }

            .toast.info {
                border-left-color: #378add;
            }

            .toast.warning {
                border-left-color: #d18800;
            }

            .toast.hide {
                animation: slideOutRightToast 0.4s ease forwards;
            }

        .toast-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
        }

        .toast.success .toast-icon {
            background: #e6f7ef;
            color: #2eb872;
        }

        .toast.info .toast-icon {
            background: #e8f3fc;
            color: #378add;
        }

        .toast.warning .toast-icon {
            background: #fff4e0;
            color: #d18800;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 2px;
        }

        .toast-desc {
            font-size: 12px;
            color: #666;
        }

        .toast-close {
            background: none;
            border: none;
            color: #aaa;
            font-size: 16px;
            cursor: pointer;
            padding: 4px;
        }

        @@media (max-width: 1280px) {
            .header-top, .nav, .breadcrumb-bar, .product-main, .footer {
                padding-left: 32px;
                padding-right: 32px;
            }

            .detail-section {
                margin: 0 32px 28px;
            }

            .related-section {
                margin: 0 32px 60px;
            }

            .related-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 1024px) {
            .product-main {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .gallery {
                position: static;
            }

            .related-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .specs-grid {
                grid-template-columns: 1fr;
            }

            .reviews-summary {
                grid-template-columns: 1fr;
                gap: 24px;
            }

            .feature-list {
                grid-template-columns: 1fr;
            }

            .search-box {
                display: none;
            }
        }

        @@media (max-width: 720px) {
            .header-top, .nav {
                padding-left: 16px;
                padding-right: 16px;
            }

            .nav {
                gap: 18px;
                overflow-x: auto;
            }

            .breadcrumb-bar, .product-main, .footer {
                padding-left: 16px;
                padding-right: 16px;
            }

            .detail-section {
                padding: 20px;
                margin: 0 16px 20px;
            }

            .related-section {
                margin: 0 16px 60px;
            }

            .gallery {
                grid-template-columns: 1fr;
            }

            .thumb-list {
                flex-direction: row;
                overflow-x: auto;
            }

            .thumb-item {
                flex-shrink: 0;
                width: 70px;
                height: 70px;
            }

            .product-title {
                font-size: 24px;
            }

            .price-current {
                font-size: 26px;
            }

            .trust-grid {
                grid-template-columns: 1fr 1fr;
            }

            .qty-action-row {
                flex-direction: column;
            }

            .qty-wrap {
                width: 100%;
                justify-content: center;
            }

            .btn-action.cart, .btn-action.buy {
                width: 100%;
            }

            .btn-action.heart-btn {
                width: 100%;
            }

            .related-grid {
                grid-template-columns: 1fr 1fr;
                gap: 12px;
            }

            .toast {
                min-width: auto;
                max-width: calc(100vw - 32px);
            }

            .toast-container {
                right: 16px;
                left: 16px;
            }
        }
    </style>
</head>
<body>

    <div class="announce">
        Miễn phí vận chuyển cho đơn hàng từ 500.000₫ · Đổi trả trong 30 ngày
    </div>

    <header class="header" id="header">
        <div class="header-top">
            <a href="/" class="logo">MONO<span>.WEAR</span></a>
            <div class="search-box">
                <i class="ti ti-search"></i>
                <input type="text" placeholder="Tìm sản phẩm..." />
            </div>
            <div class="header-icons">
                <a asp-controller="Home" asp-action="ThongBao" aria-label="Thông báo">
                    <i class="ti ti-bell bell-icon"></i>
                    <span class="notif-badge">5</span>
                </a>

                <a asp-controller="Home" asp-action="TaiKhoan" aria-label="Tài khoản">
                    <i class="ti ti-user"></i>
                </a>

                <a asp-controller="Home" asp-action="YeuThich" aria-label="Yêu thích">
                    <i class="ti ti-heart"></i>
                </a>

                <a asp-controller="Home" asp-action="GioHang" aria-label="Giỏ hàng">
                    <i class="ti ti-shopping-bag"></i>
                    <span class="cart-badge">3</span>
                </a>
            </div>
        </div>
        <nav class="nav">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a>

            <a asp-controller="Home" asp-action="Nam" asp-route-id="nam">Nam</a>

            <a asp-controller="Home" asp-action="Nu" asp-route-id="nu">Nữ</a>

            <a asp-controller="Home" asp-action="MoiVe">Mới về</a>

            <a asp-controller="Home" asp-action="BoSuuTap">Bộ sưu tập</a>

            <a asp-controller="Home" asp-action="Sale">Sale</a>

            <a asp-controller="Home" asp-action="GioiThieu">Về chúng tôi</a>
        </nav>
    </header>

    <div class="breadcrumb-bar">
        <a href="/">Trang chủ</a>
        <i class="ti ti-chevron-right"></i>
        <a href="#">@catName</a>
        <i class="ti ti-chevron-right"></i>
        <span class="current">@pName</span>
    </div>

    <section class="product-main">

        <div class="gallery">
            <div class="thumb-list">
                <div class="thumb-item dark active" data-bg="bg-dark" data-icon="ti-shirt" data-dark="true">
                    <i class="ti ti-shirt"></i>
                </div>
                <div class="thumb-item" data-bg="bg-cream" data-icon="ti-shirt" data-dark="false">
                    <i class="ti ti-shirt"></i>
                </div>
                <div class="thumb-item" data-bg="bg-gray" data-icon="ti-shirt" data-dark="false">
                    <i class="ti ti-shirt"></i>
                </div>
                <div class="thumb-item" data-bg="bg-white" data-icon="ti-shirt" data-dark="false">
                    <i class="ti ti-shirt"></i>
                </div>
                <div class="thumb-item dark" data-bg="bg-blue" data-icon="ti-hanger" data-dark="true">
                    <i class="ti ti-hanger"></i>
                </div>
            </div>

            <div class="main-image-wrap">
                <div class="main-image bg-dark dark" id="mainImage">
                    <div class="image-badges">
                        <span class="img-badge badge-new">MỚI</span>
                        <span class="img-badge badge-sale">BÁN CHẠY</span>
                    </div>
                    <i class="ti ti-shirt main-icon" id="mainIcon"></i>
                    <button class="img-nav prev" onclick="navImg(-1)"><i class="ti ti-chevron-left"></i></button>
                    <button class="img-nav next" onclick="navImg(1)"><i class="ti ti-chevron-right"></i></button>
                    <div class="zoom-hint"><i class="ti ti-zoom-in"></i>Click để xem to</div>
                </div>
            </div>
        </div>

        <div class="product-info">
            <div class="info-cat"><i class="ti ti-tag"></i>@catName.ToUpper()</div>

            <h1 class="product-title">@pName</h1>

            <div class="product-meta-row">
                <span class="meta-item rating"><i class="ti ti-star-filled"></i>@((Model?.RatingAvg ?? 0).ToString("0.0")) <span class="gray">(@(Model?.RatingCount ?? 0) đánh giá)</span></span>
                <span class="meta-divider"></span>
                <span class="meta-item"><i class="ti ti-shopping-cart"></i>Đã bán <strong>@(Model?.SoldCount ?? 0)</strong></span>
            </div>

            <div class="price-box">
                <div class="price-row">
                    <span class="price-current">@price.ToString("#,##0")₫</span>
                    @if (oldPrice.HasValue && oldPrice > 0)
                    {
                        <span class="price-old">@oldPrice.Value.ToString("#,##0")₫</span>
                        <span class="price-discount">-@discountPct%</span>
                    }
                </div>
                @if (saving > 0)
                {
                    <div class="price-saving"><i class="ti ti-confetti"></i>Bạn tiết kiệm @saving.ToString("#,##0")₫</div>
                }
            </div>

            <div class="picker-section">
                <div class="picker-label">
                    <span class="picker-label-left">
                        <span class="picker-label-title">Màu sắc:</span>
                        <span class="picker-label-value" id="colorValue">Đen</span>
                    </span>
                </div>
                <div class="color-options">
                    @{ var firstColor = true; }
                    @foreach (var c in colorList)
                    {
                        <div class="color-option @(firstColor ? "active" : "")" data-color-id="@c.ColorId" data-color="@c.Name">
                            <div class="color-circle" style="background:@c.HexCode;"></div>
                        </div>
                        firstColor = false;
                    }
                    @if (!colorList.Any())
                    {
                        <span style="color:#999;font-size:13px;">Đang cập nhật</span>
                    }
                </div>
            </div>

            <div class="picker-section">
                <div class="picker-label">
                    <span class="picker-label-left">
                        <span class="picker-label-title">Kích cỡ:</span>
                        <span class="picker-label-value" id="sizeValue">M</span>
                    </span>
                    <span class="picker-label-link" onclick="showToast('info','Hướng dẫn chọn size','Mở bảng kích cỡ chi tiết')">
                        <i class="ti ti-ruler-measure"></i>Hướng dẫn chọn size
                    </span>
                </div>
                <div class="size-grid">
                    @{ var firstSize = true; }
                    @foreach (var s in sizeList)
                    {
                        <button class="size-btn @(firstSize ? "active" : "")" data-size-id="@s.SizeId" data-size="@s.Name">@s.Name</button>
                        firstSize = false;
                    }
                    @if (!sizeList.Any())
                    {
                        <span style="color:#999;font-size:13px;">Đang cập nhật</span>
                    }
                </div>
                <div class="stock-info" id="stockInfo">
                    <i class="ti ti-circle-check"></i><span id="stockText">Chọn màu & size</span>
                </div>
            </div>

            <div class="qty-action-row">
                <div class="qty-wrap">
                    <button class="qty-btn" onclick="changeQty(-1)"><i class="ti ti-minus"></i></button>
                    <input type="number" class="qty-input" id="qtyInput" value="1" min="1" max="24" readonly />
                    <button class="qty-btn" onclick="changeQty(1)"><i class="ti ti-plus"></i></button>
                </div>
                @if (User.Identity!.IsAuthenticated)
                {
                    <button class="btn-action cart" onclick="addToCart()">
                        <i class="ti ti-shopping-bag-plus"></i>Thêm vào giỏ
                    </button>
                    <button class="btn-action buy" onclick="buyNow()">
                        <i class="ti ti-bolt"></i>Mua ngay
                    </button>
                }
                else
                {
                    <button class="btn-action cart" onclick="requireLogin('giỏ hàng')">
                        <i class="ti ti-shopping-bag-plus"></i>Thêm vào giỏ
                    </button>
                    <button class="btn-action buy" onclick="requireLogin('mua ngay')">
                        <i class="ti ti-bolt"></i>Mua ngay
                    </button>
                }
                <button class="btn-action heart-btn" id="wishBtn" onclick="toggleWish(this)">
                    <i class="ti ti-heart"></i>
                </button>
            </div>

            <div class="trust-grid">
                <div class="trust-item">
                    <i class="ti ti-truck-delivery"></i>
                    <div class="trust-text">Freeship<br />từ 500K</div>
                </div>
                <div class="trust-item">
                    <i class="ti ti-refresh"></i>
                    <div class="trust-text">Đổi trả<br />30 ngày</div>
                </div>
                <div class="trust-item">
                    <i class="ti ti-shield-check"></i>
                    <div class="trust-text">Bảo hành<br />trọn đời</div>
                </div>
                <div class="trust-item">
                    <i class="ti ti-headset"></i>
                    <div class="trust-text">Hỗ trợ<br />24/7</div>
                </div>
            </div>

            <div class="voucher-hint">
                <div class="voucher-hint-icon"><i class="ti ti-ticket"></i></div>
                <div class="voucher-hint-content">
                    <div class="voucher-hint-title">Giảm thêm 100K với mã SUMMER100</div>
                    <div class="voucher-hint-desc">Áp dụng cho đơn từ 800.000₫ · Hết hạn 15/06/2026</div>
                </div>
                <button class="voucher-hint-btn" onclick="copyVoucher()">Copy mã</button>
            </div>
        </div>
    </section>

    <section class="detail-section">
        <div class="tabs-nav">
            <button class="tab-btn active" data-tab="desc"><i class="ti ti-file-description"></i>Mô tả</button>
            <button class="tab-btn" data-tab="specs"><i class="ti ti-list-details"></i>Thông số</button>
            <button class="tab-btn" data-tab="reviews"><i class="ti ti-star"></i>Đánh giá <span class="count">@(Model?.Reviews?.Count ?? 0)</span></button>
            <button class="tab-btn" data-tab="qa"><i class="ti ti-message-circle-question"></i>Hỏi đáp <span class="count">@((ViewBag.Questions as List<ThoiTrang.Models.Entities.ProductQuestion>)?.Count ?? 0)</span></button>
            <button class="tab-btn" data-tab="shipping"><i class="ti ti-truck"></i>Vận chuyển</button>
        </div>

        <div class="tab-panel active" id="panel-desc">
            <div class="desc-content">
                <p><strong>Áo thun cotton Essential</strong> là sản phẩm chủ lực trong bộ sưu tập tối giản của MONO.WEAR. Được dệt từ 100% cotton hữu cơ cao cấp, áo mang đến cảm giác mềm mại, thoáng mát suốt cả ngày dài.</p>

                <p>Với thiết kế phi giới tính (unisex), form rộng vừa phải tôn dáng cả nam lẫn nữ. Phù hợp cho mọi hoàn cảnh từ đi học, đi làm cho đến dạo phố cuối tuần.</p>

                <h3>Đặc điểm nổi bật</h3>
                <ul class="feature-list">
                    <li><i class="ti ti-circle-check"></i>Chất liệu 100% cotton hữu cơ, không gây kích ứng</li>
                    <li><i class="ti ti-circle-check"></i>Form unisex, phù hợp mọi vóc dáng</li>
                    <li><i class="ti ti-circle-check"></i>Đường may chắc chắn, giặt nhiều không xù</li>
                    <li><i class="ti ti-circle-check"></i>Không bị bạc màu, không co rút sau giặt</li>
                    <li><i class="ti ti-circle-check"></i>Co giãn nhẹ, thoải mái vận động</li>
                    <li><i class="ti ti-circle-check"></i>Thân thiện môi trường, nhuộm tự nhiên</li>
                </ul>

                <h3>Hướng dẫn bảo quản</h3>
                <p>Giặt máy ở nhiệt độ <strong>dưới 30°C</strong> với chế độ nhẹ. Không sử dụng chất tẩy mạnh. <strong>Phơi trong bóng râm</strong> để giữ màu lâu hơn. Có thể là ủi ở nhiệt độ thấp khi cần.</p>
            </div>
        </div>

        <div class="tab-panel" id="panel-specs">
            <div class="specs-grid">
                <div class="spec-row"><span class="spec-label">Chất liệu</span><span class="spec-value">100% Cotton hữu cơ</span></div>
                <div class="spec-row"><span class="spec-label">Form dáng</span><span class="spec-value">Unisex, regular fit</span></div>
                <div class="spec-row"><span class="spec-label">Mật độ vải</span><span class="spec-value">220 GSM</span></div>
                <div class="spec-row"><span class="spec-label">Độ co giãn</span><span class="spec-value">Co giãn nhẹ 4 chiều</span></div>
                <div class="spec-row"><span class="spec-label">Xuất xứ</span><span class="spec-value">Việt Nam</span></div>
                <div class="spec-row"><span class="spec-label">Thương hiệu</span><span class="spec-value">MONO.WEAR</span></div>
                <div class="spec-row"><span class="spec-label">Kích cỡ</span><span class="spec-value">XS, S, M, L, XL, XXL</span></div>
                <div class="spec-row"><span class="spec-label">Số màu</span><span class="spec-value">5 màu</span></div>
                <div class="spec-row"><span class="spec-label">Mùa</span><span class="spec-value">All seasons</span></div>
                <div class="spec-row"><span class="spec-label">Phong cách</span><span class="spec-value">Tối giản, basic</span></div>
                <div class="spec-row"><span class="spec-label">Loại cổ</span><span class="spec-value">Cổ tròn</span></div>
                <div class="spec-row"><span class="spec-label">Tay áo</span><span class="spec-value">Tay ngắn</span></div>
            </div>
        </div>

        <div class="tab-panel" id="panel-reviews">
            @{
                var reviews = Model?.Reviews?.OrderByDescending(r => r.CreatedAt).ToList() ?? new List<ThoiTrang.Models.Entities.Review>();
                int totalRev = reviews.Count;
                double avgRating = totalRev > 0 ? reviews.Average(r => r.Rating) : 0;
                int[] starCounts = new int[6];
                foreach (var rv in reviews) starCounts[rv.Rating]++;
                string StarBar(int star) => totalRev > 0 ? $"{Math.Round(starCounts[star] * 100.0 / totalRev)}%" : "0%";
                string StarStr(double d) => string.Concat(Enumerable.Range(1, 5).Select(i => i <= Math.Round(d) ? "★" : "☆"));
                string avatarColors = "avatar-1 avatar-2 avatar-3 avatar-4 avatar-5";
                string[] avcls = avatarColors.Split(' ');
                bool hasBought = ViewBag.HasBought == true;
                bool alreadyReviewed = ViewBag.AlreadyReviewed == true;
            }
            <div class="reviews-summary">
                <div class="rating-big">
                    <div class="rating-num" style="@(totalRev == 0 ? "color:#ccc;" : "")">@(totalRev > 0 ? avgRating.ToString("0.0") : "0.0")</div>
                    <div class="rating-stars" style="@(totalRev == 0 ? "color:#ddd;" : "")">@(totalRev > 0 ? StarStr(avgRating) : "☆☆☆☆☆")</div>
                    <div class="rating-total">@totalRev đánh giá</div>
                </div>
                <div class="rating-bars">
                    @for (int s = 5; s >= 1; s--)
                    {
                        <div class="rating-bar-row">
                            <span class="rating-bar-label">@s<i class="ti ti-star-filled"></i></span>
                            <div class="rating-bar-track"><div class="rating-bar-fill" style="width: @StarBar(s);"></div></div>
                            <span class="rating-bar-count">@starCounts[s]</span>
                        </div>
                    }
                </div>
            </div>

            <div class="review-filters">
                <button class="review-filter active" onclick="filterReviews(0,this)">Tất cả (@totalRev)</button>
                <button class="review-filter" onclick="filterReviews(5,this)">5 sao (@starCounts[5])</button>
                <button class="review-filter" onclick="filterReviews(4,this)">4 sao (@starCounts[4])</button>
                <button class="review-filter" onclick="filterReviews(3,this)">3 sao (@starCounts[3])</button>
                <button class="review-filter" onclick="filterReviews(0,this,'verified')">Đã mua hàng (@reviews.Count(r => r.IsVerified))</button>
            </div>

            @if (hasBought && !alreadyReviewed)
            {
                <div class="write-review-box" style="background:#fafafa;border:1px solid #f0f0ec;border-radius:14px;padding:20px;margin-bottom:20px;">
                    <div style="font-weight:700;font-size:15px;margin-bottom:14px;"><i class="ti ti-edit" style="margin-right:6px;color:#d4537e;"></i>Viết đánh giá của bạn</div>
                    <div style="display:flex;gap:4px;margin-bottom:14px;align-items:center;" id="starPicker">
                        @for (int s = 1; s <= 5; s++)
                        {
                            <span style="font-size:32px;cursor:pointer;color:#ddd;transition:color .15s;" data-star="@s" onclick="pickStar(@s)" onmouseover="hoverStar(@s)" onmouseout="hoverStar(0)">★</span>
                        }
                        <span id="starLabel" style="margin-left:8px;font-size:13px;color:#888;"></span>
                    </div>
                    <textarea id="reviewContent" rows="3" placeholder="Chia sẻ cảm nhận của bạn về sản phẩm (chất liệu, form dáng, màu sắc...)..." style="width:100%;padding:12px;border:1px solid #e8e8e8;border-radius:10px;font-size:14px;resize:vertical;font-family:inherit;box-sizing:border-box;"></textarea>
                    <div style="margin-top:12px;">
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:#555;">
                            <div id="imgUploadArea" style="display:flex;align-items:center;gap:6px;background:#fff;border:1.5px dashed #d4537e;border-radius:10px;padding:10px 16px;cursor:pointer;transition:background .2s;" onclick="document.getElementById('reviewImgInput').click()">
                                <i class="ti ti-camera" style="color:#d4537e;font-size:18px;"></i>
                                <span style="color:#d4537e;font-weight:500;">Thêm ảnh</span>
                                <span style="color:#aaa;">(tối đa 3 ảnh, ≤5MB)</span>
                            </div>
                            <input type="file" id="reviewImgInput" accept="image/*" multiple style="display:none;" onchange="previewReviewImages(this)">
                        </label>
                        <div id="imgPreviews" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;"></div>
                    </div>
                    <div style="display:flex;gap:10px;margin-top:14px;align-items:center;">
                        <button onclick="submitReview(@(Model!.ProductId))" id="submitReviewBtn" style="background:#1a1a1a;color:#fff;border:none;padding:11px 28px;border-radius:10px;cursor:pointer;font-size:14px;font-weight:600;display:flex;align-items:center;gap:6px;">
                            <i class="ti ti-send"></i>Gửi đánh giá
                        </button>
                        <span style="font-size:12px;color:#aaa;"><i class="ti ti-shield-check" style="color:#10b981;"></i> Đánh giá của bạn sẽ được xét duyệt</span>
                    </div>
                </div>
            }
            @if (!hasBought && User.Identity!.IsAuthenticated)
            {
                <div style="background:#f9f9f9;border:1px solid #f0f0ec;border-radius:12px;padding:16px 20px;margin-bottom:18px;font-size:13px;color:#888;display:flex;align-items:center;gap:10px;">
                    <i class="ti ti-lock" style="font-size:18px;color:#ccc;"></i>
                    Chỉ khách hàng đã mua và hoàn tất đơn hàng mới có thể đánh giá sản phẩm này.
                </div>
            }
            @if (!User.Identity!.IsAuthenticated)
            {
                <div style="background:#fff8fb;border:1px solid #f5c6d8;border-radius:12px;padding:16px 20px;margin-bottom:18px;font-size:13px;color:#c04070;display:flex;align-items:center;gap:10px;">
                    <i class="ti ti-user-circle" style="font-size:18px;"></i>
                    <span>Vui lòng <a href="/Home/DangNhap" style="color:#d4537e;font-weight:600;text-decoration:underline;">đăng nhập</a> để đánh giá sản phẩm.</span>
                </div>
            }

            <div class="review-list" id="reviewList">
                @if (reviews.Count == 0)
                {
                    <div style="padding:40px;text-align:center;color:#999;">
                        <i class="ti ti-star" style="font-size:36px;color:#ccc;"></i>
                        <div style="margin-top:10px;">Chưa có đánh giá nào. Hãy là người đầu tiên!</div>
                    </div>
                }
                @{ int ri = 0; }
                @foreach (var r in reviews)
                {
                    var rname = r.User?.FullName ?? "Khách ẩn danh";
                    var rinitial = rname.Length > 0 ? rname.Substring(0, 1).ToUpper() : "K";
                    var rcls = avcls[ri % 5];
                    var rago = (DateTime.Now - r.CreatedAt).TotalDays < 1 ? "Hôm nay" :
                               (DateTime.Now - r.CreatedAt).TotalDays < 7 ? $"{(int)(DateTime.Now - r.CreatedAt).TotalDays} ngày trước" :
                               (DateTime.Now - r.CreatedAt).TotalDays < 30 ? $"{(int)((DateTime.Now - r.CreatedAt).TotalDays / 7)} tuần trước" :
                               r.CreatedAt.ToString("dd/MM/yyyy");
                    var rStars = string.Concat(Enumerable.Range(1, 5).Select(i => i <= r.Rating ? "★" : "☆"));
                    <div class="review-item" data-star="@r.Rating" data-verified="@r.IsVerified.ToString().ToLower()">
                        <div class="review-head">
                            <div class="review-avatar @rcls">@rinitial</div>
                            <div class="review-info">
                                <div class="review-name">@rname @(r.IsVerified ? Html.Raw("<span class=\"verified-badge\"><i class=\"ti ti-circle-check\"></i>Đã mua</span>") : Html.Raw(""))</div>
                                <div class="review-meta">
                                    <span class="review-stars">@rStars</span>
                                    <span>·</span>
                                    <span>@rago</span>
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(r.Content))
                        {
                            <div class="review-text">@r.Content</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(r.Images))
                        {
                            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;">
                                @foreach (var imgPath in r.Images.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <img src="@imgPath.Trim()" alt="Ảnh đánh giá"
                                         style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #f0f0ec;cursor:pointer;"
                                         onclick="openImgViewer('@imgPath.Trim()')" />
                                }
                            </div>
                        }
                        <div class="review-actions">
                            <button class="review-action" onclick="markHelpful(@r.ReviewId, this)"><i class="ti ti-thumb-up"></i>Hữu ích (@r.HelpfulCount)</button>
                        </div>
                    </div>
                    ri++;
                }
            </div>
        </div>

        <div class="tab-panel" id="panel-qa">
            @{
                var questions = ViewBag.Questions as List<ThoiTrang.Models.Entities.ProductQuestion> ?? new List<ThoiTrang.Models.Entities.ProductQuestion>();
            }
            @if (questions.Count == 0)
            {
                <div style="padding:30px;text-align:center;color:#999;">
                    <i class="ti ti-message-question" style="font-size:36px;color:#ccc;"></i>
                    <div style="margin-top:10px;">Chưa có câu hỏi nào. Hãy đặt câu hỏi đầu tiên!</div>
                </div>
            }
            @foreach (var q in questions)
            {
                var qname = q.User?.FullName ?? "Khách";
                var qago = (DateTime.Now - q.CreatedAt).TotalDays < 1 ? "Hôm nay" :
                           (DateTime.Now - q.CreatedAt).TotalDays < 7 ? $"{(int)(DateTime.Now - q.CreatedAt).TotalDays} ngày trước" :
                           (DateTime.Now - q.CreatedAt).TotalDays < 30 ? $"{(int)((DateTime.Now - q.CreatedAt).TotalDays / 7)} tuần trước" :
                           q.CreatedAt.ToString("dd/MM/yyyy");
                <div class="qa-item">
                    <div class="qa-question">
                        <div class="qa-q-icon">H</div>
                        <div>
                            <div class="qa-q-text">@q.Question</div>
                            <div class="qa-q-meta">@qname · @qago</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(q.Answer))
                    {
                        var ansago = q.AnsweredAt.HasValue ? q.AnsweredAt.Value.ToString("dd/MM/yyyy") : "";
                        <div class="qa-answer">
                            <div class="qa-a-icon">M</div>
                            <div>
                                <div class="qa-a-text">@q.Answer</div>
                                <div class="qa-a-meta">MONO.WEAR · @ansago</div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="ask-row">
                <input type="text" id="askInput" class="ask-input" placeholder="Đặt câu hỏi về sản phẩm này..." />
                <button class="ask-btn" onclick="submitQuestion(@(Model!.ProductId))">Gửi câu hỏi</button>
            </div>
        </div>

        <div class="tab-panel" id="panel-shipping">
            <div class="desc-content">
                <h3>Chính sách vận chuyển</h3>
                <ul class="feature-list">
                    <li><i class="ti ti-truck"></i><strong>Giao nhanh nội thành HCM/HN:</strong> 1-2 ngày</li>
                    <li><i class="ti ti-truck"></i><strong>Giao toàn quốc:</strong> 2-3 ngày làm việc</li>
                    <li><i class="ti ti-discount-2"></i><strong>Miễn phí vận chuyển</strong> cho đơn từ 500.000₫</li>
                    <li><i class="ti ti-cash"></i>Hỗ trợ <strong>COD toàn quốc</strong> (Thanh toán khi nhận)</li>
                </ul>

                <h3>Chính sách đổi trả</h3>
                <ul class="feature-list">
                    <li><i class="ti ti-refresh"></i><strong>Đổi trả trong 30 ngày</strong> không cần lý do</li>
                    <li><i class="ti ti-shield-check"></i>Hỗ trợ đổi size, đổi màu miễn phí</li>
                    <li><i class="ti ti-circle-check"></i>Hoàn 100% nếu sản phẩm có lỗi từ nhà sản xuất</li>
                    <li><i class="ti ti-headset"></i>Hotline hỗ trợ 24/7: <strong>1900 6868</strong></li>
                </ul>
            </div>
        </div>
    </section>

    @{
        var relatedProducts = ViewBag.Related as List<ThoiTrang.Models.Entities.Product> ?? new List<ThoiTrang.Models.Entities.Product>();
        string[] rbgs = { "bg-cream", "bg-dark dark", "bg-blue dark", "bg-brown dark", "bg-gray" };
