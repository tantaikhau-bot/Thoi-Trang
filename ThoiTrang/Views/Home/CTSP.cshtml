    </footer>

    <button class="scroll-top" id="scrollTop"><i class="ti ti-arrow-up"></i></button>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        const thumbs = document.querySelectorAll('.thumb-item');
        const mainImage = document.getElementById('mainImage');
        const mainIcon = document.getElementById('mainIcon');
        let currentIdx = 0;

        function applyImage(bg, icon, isDark) {
            mainImage.className = 'main-image ' + bg + (isDark ? ' dark' : '');
            mainIcon.className = 'ti ' + icon + ' main-icon';
            mainIcon.style.animation = 'none';
            void mainIcon.offsetWidth;
            mainIcon.style.animation = 'scaleIn 0.5s ease';
        }

        function setThumb(idx) {
            if (idx < 0) idx = thumbs.length - 1;
            if (idx >= thumbs.length) idx = 0;
            currentIdx = idx;
            thumbs.forEach((t, i) => t.classList.toggle('active', i === idx));
            const thumb = thumbs[idx];
            applyImage(thumb.dataset.bg, thumb.dataset.icon, thumb.dataset.dark === 'true');
        }

        thumbs.forEach((t, i) => t.addEventListener('click', () => setThumb(i)));
        function navImg(delta) { setThumb(currentIdx + delta); }

        // ===== Biến thể thật từ DB =====
        const VARIANTS = @Html.Raw(variantsJson);
        const PRODUCT_ID = @productId;
        let selColorId = null, selSizeId = null;

        var firstColorEl = document.querySelector('.color-option');
        if (firstColorEl) selColorId = parseInt(firstColorEl.dataset.colorId);
        var firstSizeEl = document.querySelector('.size-btn');
        if (firstSizeEl) selSizeId = parseInt(firstSizeEl.dataset.sizeId);

        function currentVariant() {
            return VARIANTS.find(v => v.colorId === selColorId && v.sizeId === selSizeId);
        }

        function refreshSizeAvailability() {
            // Vô hiệu hóa size không còn hàng theo màu đang chọn
            document.querySelectorAll('.size-btn').forEach(btn => {
                const sid = parseInt(btn.dataset.sizeId);
                const v = VARIANTS.find(x => x.colorId === selColorId && x.sizeId === sid);
                if (!v || v.stock <= 0) btn.classList.add('disabled');
                else btn.classList.remove('disabled');
            });
        }

        function updateStock() {
            const v = currentVariant();
            const txt = document.getElementById('stockText');
            const qtyInput = document.getElementById('qtyInput');
            if (!v) { txt.textContent = 'Phối màu/size này tạm hết'; if (qtyInput) qtyInput.max = 1; return; }
            txt.textContent = 'Còn ' + v.stock + ' sản phẩm';
            if (qtyInput) { qtyInput.max = v.stock; if (parseInt(qtyInput.value) > v.stock) qtyInput.value = Math.max(1, v.stock); }
        }

        document.querySelectorAll('.color-option').forEach(opt => {
            opt.addEventListener('click', () => {
                document.querySelectorAll('.color-option').forEach(o => o.classList.remove('active'));
                opt.classList.add('active');
                selColorId = parseInt(opt.dataset.colorId);
                document.getElementById('colorValue').textContent = opt.dataset.color;
                refreshSizeAvailability();
                updateStock();
            });
        });

        document.querySelectorAll('.size-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                if (btn.classList.contains('disabled')) return;
                document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                selSizeId = parseInt(btn.dataset.sizeId);
                document.getElementById('sizeValue').textContent = btn.dataset.size;
                updateStock();
            });
        });

        function changeQty(delta) {
            const input = document.getElementById('qtyInput');
            const max = parseInt(input.max) || 99;
            let val = parseInt(input.value) + delta;
            if (val < 1) val = 1;
            if (val > max) {
                showToast('warning', 'Đã đạt tối đa', `Chỉ còn ${max} sản phẩm trong kho`);
                return;
            }
            input.value = val;
        }

        function addToCart(goCheckout) {
            const v = currentVariant();
            if (!v) { showToast('error', 'Chưa chọn được biến thể', 'Vui lòng chọn màu và size còn hàng'); return; }
            const qty = parseInt(document.getElementById('qtyInput').value) || 1;
            const fd = new FormData();
            fd.append('variantId', v.id);
            fd.append('quantity', qty);
            fetch('/Home/AddToCart', { method: 'POST', body: fd })
                .then(r => {
                    if (r.status === 401) { window.location.href = '/Home/DangNhap'; return null; }
                    return r.ok ? r.json() : Promise.reject(r);
                })
                .then(d => {
                    if (!d) return;
                    const badge = document.getElementById('headerCartBadge');
                    if (badge) { badge.textContent = d.count; badge.style.animation = 'none'; void badge.offsetWidth; badge.style.animation = 'heartBeat 0.6s ease'; }
                    if (goCheckout) { window.location.href = '/Home/GioHang'; return; }
                    showToast('success', 'Đã thêm vào giỏ', qty + ' sản phẩm đã được thêm');
                })
                .catch(() => showToast('error', 'Lỗi', 'Không thể thêm vào giỏ'));
        }

        function buyNow() { addToCart(true); }

        function toggleWish(btn) {
            const fd = new FormData(); fd.append('productId', PRODUCT_ID);
            fetch('/Home/ToggleWishlist', { method: 'POST', body: fd })
                .then(r => { if (r.status === 401) { window.location.href = '/Home/DangNhap'; return null; } return r.ok ? r.json() : Promise.reject(r); })
                .then(d => {
                    if (!d) return;
                    const icon = btn.querySelector('i');
                    if (d.added) { btn.classList.add('active'); icon.classList.remove('ti-heart'); icon.classList.add('ti-heart-filled'); showToast('success', 'Đã thêm yêu thích', ''); }
                    else { btn.classList.remove('active'); icon.classList.remove('ti-heart-filled'); icon.classList.add('ti-heart'); showToast('info', 'Đã bỏ yêu thích', ''); }
                })
                .catch(() => showToast('error', 'Lỗi', 'Thử lại sau'));
        }

        // Khởi tạo trạng thái biến thể
        refreshSizeAvailability();
        updateStock();

        function copyVoucher() {
            const code = 'SUMMER100';
            if (navigator.clipboard) {
                navigator.clipboard.writeText(code).then(() => {
                    showToast('success', 'Đã sao chép mã', `Mã ${code} đã được copy`);
                }).catch(() => {
                    showToast('info', 'Mã voucher', code);
                });
            } else {
                showToast('info', 'Mã voucher', code);
            }
        }

        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
            });
        });

        // Lọc reviews
        function filterReviews(star, btn, mode) {
            document.querySelectorAll('.review-filter').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll('#reviewList .review-item').forEach(item => {
                if (star === 0 && !mode) { item.style.display = ''; return; }
                if (mode === 'verified') { item.style.display = item.dataset.verified === 'true' ? '' : 'none'; return; }
                item.style.display = parseInt(item.dataset.star) === star ? '' : 'none';
            });
        }

        // Chặn khi chưa đăng nhập
        function requireLogin(action) {
            showToast('info', 'Cần đăng nhập', `Vui lòng đăng nhập để ${action}`);
            setTimeout(() => { window.location.href = '/Home/DangNhap?returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search); }, 1400);
        }

        // Chọn sao đánh giá
        let selectedStar = 0;
        const starLabels = ['', 'Rất tệ', 'Tệ', 'Trung bình', 'Tốt', 'Tuyệt vời'];
        function hoverStar(s) {
            const n = s || selectedStar;
            document.querySelectorAll('#starPicker span').forEach(el => {
                el.style.color = parseInt(el.dataset.star) <= n ? '#f4a321' : '#ddd';
            });
            const lbl = document.getElementById('starLabel');
            if (lbl) lbl.textContent = s ? starLabels[s] : (selectedStar ? starLabels[selectedStar] : '');
        }
        function pickStar(s) {
            selectedStar = s;
            hoverStar(s);
        }

        // Preview ảnh trước khi gửi
        function previewReviewImages(input) {
            const wrap = document.getElementById('imgPreviews');
            wrap.innerHTML = '';
            const files = Array.from(input.files).slice(0, 3);
            files.forEach(f => {
                const reader = new FileReader();
                reader.onload = e => {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.cssText = 'width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #f0f0ec;';
                    const del = document.createElement('button');
                    del.innerHTML = '<i class="ti ti-x"></i>';
                    del.style.cssText = 'position:absolute;top:2px;right:2px;background:#1a1a1a99;color:#fff;border:none;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:11px;padding:0;';
                    const box = document.createElement('div');
                    box.style.cssText = 'position:relative;display:inline-block;';
                    box.appendChild(img); box.appendChild(del);
                    del.onclick = () => { box.remove(); };
                    wrap.appendChild(box);
                };
                reader.readAsDataURL(f);
            });
        }

        // Xem ảnh fullscreen
        function openImgViewer(src) {
            const overlay = document.createElement('div');
            overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.88);display:flex;align-items:center;justify-content:center;cursor:zoom-out;';
            overlay.innerHTML = `<img src="${src}" style="max-width:90vw;max-height:90vh;border-radius:10px;box-shadow:0 20px 60px rgba(0,0,0,0.5);" />`;
            overlay.onclick = () => overlay.remove();
            document.body.appendChild(overlay);
        }

        // Gửi đánh giá (multipart để có ảnh)
        async function submitReview(productId) {
            if (!selectedStar) { showToast('info', 'Chọn số sao', 'Vui lòng chọn số sao đánh giá'); return; }
            const content = document.getElementById('reviewContent').value.trim();
            const btn = document.getElementById('submitReviewBtn');
            btn.disabled = true; btn.textContent = 'Đang gửi...';

            const fd = new FormData();
            fd.append('productId', productId);
            fd.append('rating', selectedStar);
            fd.append('content', content);
            const imgInput = document.getElementById('reviewImgInput');
            if (imgInput && imgInput.files.length > 0) {
                Array.from(imgInput.files).slice(0, 3).forEach(f => fd.append('reviewImages', f));
            }
            const res = await fetch('/Home/AddReview', { method: 'POST', body: fd });
            if (res.ok) {
                showToast('success', 'Đã gửi đánh giá', 'Cảm ơn bạn đã đánh giá sản phẩm!');
                setTimeout(() => location.reload(), 1400);
            } else if (res.status === 401) {
                showToast('info', 'Cần đăng nhập', 'Vui lòng đăng nhập để gửi đánh giá');
                setTimeout(() => location.href = '/Home/DangNhap', 1200);
            } else { btn.disabled = false; btn.innerHTML = '<i class="ti ti-send"></i>Gửi đánh giá'; showToast('error', 'Lỗi', 'Không thể gửi đánh giá, thử lại sau'); }
        }

        // Đánh dấu hữu ích
        async function markHelpful(reviewId, btn) {
            const res = await fetch(`/Home/HelpfulReview?reviewId=${reviewId}`, { method: 'POST' });
            if (res.ok) {
                const d = await res.json();
                btn.innerHTML = `<i class="ti ti-thumb-up"></i>Hữu ích (${d.count})`;
                btn.disabled = true;
            }
        }

        // Gửi câu hỏi
        async function submitQuestion(productId) {
            const q = document.getElementById('askInput').value.trim();
            if (!q) { showToast('info', 'Nhập câu hỏi', 'Vui lòng nhập câu hỏi trước khi gửi'); return; }
            const params = new URLSearchParams({ productId, question: q });
            const res = await fetch('/Home/AddQuestion', { method: 'POST', body: params });
            if (res.ok) {
                showToast('success', 'Đã gửi câu hỏi', 'Chúng tôi sẽ trả lời trong vòng 24 giờ');
                document.getElementById('askInput').value = '';
            } else if (res.status === 401) {
                showToast('info', 'Cần đăng nhập', 'Vui lòng đăng nhập để đặt câu hỏi');
                setTimeout(() => location.href = '/Home/DangNhap', 1200);
            } else { showToast('error', 'Lỗi', 'Không thể gửi câu hỏi, thử lại sau'); }
        }

        function toggleRelatedHeart(e, btn, productId) {
            e.stopPropagation();
            fetch('/Home/ToggleWishlist', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId })
            }).then(r => {
                if (r.status === 401) { showToast('info', 'Cần đăng nhập', 'Vui lòng đăng nhập để lưu yêu thích'); return; }
                btn.classList.toggle('active');
                const icon = btn.querySelector('i');
                if (btn.classList.contains('active')) {
                    icon.classList.replace('ti-heart', 'ti-heart-filled');
                    showToast('success', 'Đã thêm yêu thích', 'Sản phẩm đã được lưu');
                } else {
                    icon.classList.replace('ti-heart-filled', 'ti-heart');
                }
            });
        }

        const header = document.getElementById('header');
        const scrollTopBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) header.classList.add('scrolled');
            else header.classList.remove('scrolled');
            if (window.scrollY > 400) scrollTopBtn.classList.add('show');
            else scrollTopBtn.classList.remove('show');
        });
        scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icons = { success: 'ti-circle-check', info: 'ti-info-circle', warning: 'ti-alert-circle' };
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
                <button class="toast-close"><i class="ti ti-x"></i></button>
            `;
            container.appendChild(toast);
            const closeBtn = toast.querySelector('.toast-close');
            const removeToast = () => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            };
            closeBtn.addEventListener('click', removeToast);
            setTimeout(removeToast, 3500);
        }
    </script>

    <script src="/js/search.js"></script>
    @await Html.PartialAsync("_ChatWidget")
</body>
</html>
