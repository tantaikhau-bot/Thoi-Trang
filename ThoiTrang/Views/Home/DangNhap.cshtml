@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập / Đăng ký";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MONO.WEAR - Đăng nhập</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@2.47.0/tabler-icons.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            color: #1a1a1a;
            background: #fafafa;
            line-height: 1.5;
            overflow-x: clip;
            min-height: 100vh;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button {
            font-family: inherit;
            cursor: pointer;
        }

        input {
            font-family: inherit;
        }

        /* ============ ANIMATIONS ============ */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-15px);
            }
        }

        @@keyframes floatSlow {
            0%, 100% {
                transform: translateY(0) rotate(0);
            }

            50% {
                transform: translateY(-25px) rotate(8deg);
            }
        }

        @@keyframes rotate {
            from {
                transform: rotate(0);
            }

            to {
                transform: rotate(360deg);
            }
        }

        @@keyframes shimmer {
            0% {
                background-position: -200% 0;
            }

            100% {
                background-position: 200% 0;
            }
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.08);
            }
        }

        @@keyframes morphBlob {
            0%, 100% {
                border-radius: 50% 50% 50% 50% / 50% 50% 50% 50%;
            }

            33% {
                border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
            }

            66% {
                border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
            }
        }

        @@keyframes shake {
            0%, 100% {
                transform: translateX(0);
            }

            25% {
                transform: translateX(-8px);
            }

            75% {
                transform: translateX(8px);
            }
        }

        @@keyframes checkPop {
            0% {
                transform: scale(0);
            }

            50% {
                transform: scale(1.2);
            }

            100% {
                transform: scale(1);
            }
        }

        @@keyframes slideInRightToast {
            from {
                transform: translateX(120%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes slideOutRightToast {
            from {
                transform: translateX(0);
                opacity: 1;
            }

            to {
                transform: translateX(120%);
                opacity: 0;
            }
        }

        @@keyframes typewriter {
            from {
                width: 0;
            }

            to {
                width: 100%;
            }
        }

        @@keyframes blinkCursor {
            0%, 100% {
                border-color: transparent;
            }

            50% {
                border-color: #fff;
            }
        }

        @@keyframes flipIn {
            from {
                opacity: 0;
                transform: rotateY(-90deg);
            }

            to {
                opacity: 1;
                transform: rotateY(0);
            }
        }

        /* ============ PAGE LAYOUT ============ */
        .auth-page {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }


        /* ============ LEFT - BRAND PANEL ============ */
        .brand-panel {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #2c2c2a 100%);
            color: #fff;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 48px 60px;
        }

        .brand-bg-text {
            position: absolute;
            font-size: 30vw;
            font-weight: 700;
            color: rgba(255,255,255,0.025);
            white-space: nowrap;
            user-select: none;
            pointer-events: none;
            letter-spacing: -1vw;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: float 10s ease-in-out infinite;
        }

        .blob {
            position: absolute;
            filter: blur(60px);
            animation: morphBlob 15s ease-in-out infinite, floatSlow 10s ease-in-out infinite;
            pointer-events: none;
        }

        .blob-1 {
            top: -10%;
            left: -10%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(212,83,126,0.5), transparent 70%);
        }

        .blob-2 {
            bottom: -10%;
            right: -10%;
            width: 450px;
            height: 450px;
            background: radial-gradient(circle, rgba(226,133,107,0.4), transparent 70%);
            animation-delay: -5s;
        }

        .blob-3 {
            top: 40%;
            left: 30%;
            width: 280px;
            height: 280px;
            background: radial-gradient(circle, rgba(74,93,154,0.35), transparent 70%);
            animation-delay: -7s;
        }

        .brand-top {
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .brand-logo {
            font-size: 28px;
            font-weight: 500;
            letter-spacing: 1.5px;
        }

            .brand-logo span {
                font-weight: 300;
            }

        .back-link {
            margin-left: auto;
            font-size: 13px;
            color: rgba(255,255,255,0.6);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 999px;
            transition: all 0.3s;
        }

            .back-link:hover {
                color: #fff;
                border-color: #fff;
                background: rgba(255,255,255,0.05);
            }

        .brand-center {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            justify-content: center;
            flex: 1;
            padding: 40px 0;
        }

        .brand-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 999px;
            font-size: 11px;
            letter-spacing: 2px;
            margin-bottom: 28px;
            backdrop-filter: blur(10px);
            width: fit-content;
            animation: fadeInUp 0.8s ease;
        }

            .brand-eyebrow .dot {
                width: 6px;
                height: 6px;
                background: #2eb872;
                border-radius: 50%;
                animation: pulse 1.5s infinite;
            }

        .brand-title {
            font-size: clamp(36px, 4.5vw, 56px);
            font-weight: 500;
            line-height: 1.1;
            margin-bottom: 24px;
            letter-spacing: -1px;
            max-width: 480px;
            animation: fadeInUp 0.8s ease 0.1s both;
        }

            .brand-title .accent {
                background: linear-gradient(90deg, #d4537e, #e2856b);
                -webkit-background-clip: text;
                background-clip: text;
                -webkit-text-fill-color: transparent;
                font-style: italic;
            }

        .brand-subtitle {
            font-size: 16px;
            line-height: 1.7;
            color: rgba(255,255,255,0.65);
            max-width: 440px;
            margin-bottom: 40px;
            animation: fadeInUp 0.8s ease 0.2s both;
        }

        .brand-features {
            display: flex;
            flex-direction: column;
            gap: 16px;
            animation: fadeInUp 0.8s ease 0.3s both;
        }

        .brand-feature {
            display: flex;
            align-items: center;
            gap: 14px;
            font-size: 14px;
            color: rgba(255,255,255,0.85);
        }

        .feature-icon {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #d4537e;
            flex-shrink: 0;
            backdrop-filter: blur(10px);
            transition: all 0.3s;
        }

        .brand-feature:hover .feature-icon {
            background: linear-gradient(135deg, #d4537e, #e2856b);
            color: #fff;
            transform: scale(1.1) rotate(-5deg);
        }

        .brand-bottom {
            position: relative;
            z-index: 2;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 12px;
            color: rgba(255,255,255,0.4);
            flex-wrap: wrap;
            gap: 12px;
        }

        .brand-socials {
            display: flex;
            gap: 12px;
            font-size: 18px;
        }

            .brand-socials a {
                color: rgba(255,255,255,0.4);
                transition: all 0.3s;
            }

                .brand-socials a:hover {
                    color: #d4537e;
                    transform: translateY(-3px);
                }

        /* ============ RIGHT - FORM PANEL ============ */
        .form-panel {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 60px;
            background: #fafafa;
            position: relative;
            overflow: hidden;
        }

            .form-panel::before {
                content: '';
                position: absolute;
                top: -100px;
                right: -100px;
                width: 300px;
                height: 300px;
                background: radial-gradient(circle, rgba(212,83,126,0.08), transparent 70%);
                filter: blur(30px);
            }

            .form-panel::after {
                content: '';
                position: absolute;
                bottom: -100px;
                left: -100px;
                width: 250px;
                height: 250px;
                background: radial-gradient(circle, rgba(226,133,107,0.06), transparent 70%);
                filter: blur(30px);
            }

        .form-wrapper {
            width: 100%;
            max-width: 440px;
            position: relative;
            z-index: 2;
        }

        /* Tabs */
        .form-tabs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            background: #fff;
            border-radius: 12px;
            padding: 4px;
            margin-bottom: 32px;
            position: relative;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }

        .form-tab {
            padding: 12px;
            border: none;
            background: transparent;
            font-size: 14px;
            font-weight: 500;
            color: #888;
            border-radius: 8px;
            cursor: pointer;
            transition: color 0.3s;
            position: relative;
            z-index: 2;
        }

            .form-tab.active {
                color: #fff;
            }

        .form-tab-indicator {
            position: absolute;
            top: 4px;
            left: 4px;
            width: calc(50% - 4px);
            height: calc(100% - 8px);
            background: linear-gradient(135deg, #1a1a1a, #2c2c2a);
            border-radius: 8px;
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .form-tabs.signup-active .form-tab-indicator {
            transform: translateX(100%);
        }

        /* Form */
        .form-container {
            position: relative;
            min-height: 720px;
        }

        .form {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            opacity: 1;
            visibility: visible;
            transition: opacity 0.4s ease, transform 0.4s ease, visibility 0s;
        }

            .form.hidden {
                opacity: 0;
                visibility: hidden;
                transform: translateX(20px);
                transition: opacity 0.3s ease, transform 0.3s ease, visibility 0s 0.3s;
            }

        .form-header {
            margin-bottom: 24px;
            animation: fadeInUp 0.5s ease;
        }

        .form-title {
            font-size: 28px;
            font-weight: 500;
            margin-bottom: 6px;
            letter-spacing: -0.5px;
        }

        .form-subtitle {
            font-size: 14px;
            color: #888;
        }

            .form-subtitle a {
                color: #d4537e;
                font-weight: 500;
                transition: opacity 0.3s;
                cursor: pointer;
            }

                .form-subtitle a:hover {
                    opacity: 0.7;
                }

        /* Social buttons */
        .social-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
        }

        .social-btn {
            padding: 12px;
            background: #fff;
            border: 1px solid #eee;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #555;
            transition: all 0.3s;
            cursor: pointer;
        }

            .social-btn:hover {
                border-color: #1a1a1a;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.06);
            }

            .social-btn i {
                font-size: 18px;
            }

            .social-btn .ti-brand-google {
                color: #ea4335;
            }

            .social-btn .ti-brand-facebook {
                color: #1877f2;
            }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 14px;
            margin: 20px 0;
            color: #aaa;
            font-size: 11px;
            letter-spacing: 2px;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #eee;
            }

        /* Input */
        .form-group {
            margin-bottom: 16px;
            animation: fadeInUp 0.5s ease;
        }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 8px;
            color: #555;
        }

        .input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

            .input-wrap i.input-icon {
                position: absolute;
                left: 16px;
                font-size: 18px;
                color: #aaa;
                transition: color 0.3s;
                pointer-events: none;
            }

            .input-wrap input {
                width: 100%;
                padding: 14px 16px 14px 48px;
                border: 1px solid #e0e0e0;
                background: #fff;
                border-radius: 10px;
                font-size: 14px;
                outline: none;
                transition: all 0.3s;
            }

                .input-wrap input::placeholder {
                    color: #bbb;
                }

                .input-wrap input:focus {
                    border-color: #1a1a1a;
                    box-shadow: 0 0 0 4px rgba(26,26,26,0.05);
                }

            .input-wrap:focus-within i.input-icon {
                color: #1a1a1a;
            }

            .input-wrap.has-error input {
                border-color: #d44;
                animation: shake 0.4s;
            }

            .input-wrap.has-error i.input-icon {
                color: #d44;
            }

            .input-wrap.has-success input {
                border-color: #2eb872;
            }

            .input-wrap.has-success::after {
                content: '✓';
                position: absolute;
                right: 16px;
                color: #2eb872;
                font-size: 18px;
                font-weight: 700;
                animation: checkPop 0.4s;
            }

        .toggle-pwd {
            position: absolute;
            right: 16px;
            background: none;
            border: none;
            color: #aaa;
            font-size: 18px;
            cursor: pointer;
            padding: 4px;
            transition: color 0.3s;
        }

            .toggle-pwd:hover {
                color: #1a1a1a;
            }

        .input-hint {
            font-size: 11px;
            color: #aaa;
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .input-hint i {
                font-size: 13px;
            }

            .input-hint.error {
                color: #d44;
            }

            .input-hint.success {
                color: #2eb872;
            }

        /* Password strength */
        .pwd-strength {
            display: flex;
            gap: 4px;
            margin-top: 8px;
        }

        .strength-bar {
            flex: 1;
            height: 4px;
            background: #eee;
            border-radius: 2px;
            transition: background 0.3s;
        }

            .strength-bar.weak {
                background: #d44;
            }

            .strength-bar.medium {
                background: #f0b400;
            }

            .strength-bar.strong {
                background: #2eb872;
            }

        .strength-text {
            font-size: 11px;
            margin-top: 6px;
            color: #aaa;
        }

            .strength-text.weak {
                color: #d44;
            }

            .strength-text.medium {
                color: #f0b400;
            }

            .strength-text.strong {
                color: #2eb872;
            }

        /* Form row (2 cols) */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        /* Remember & forgot */
        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 8px 0 20px;
            font-size: 13px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .checkbox-wrap {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            color: #555;
            user-select: none;
        }

            .checkbox-wrap input {
                display: none;
            }

        .checkbox-box {
            width: 18px;
            height: 18px;
            border: 2px solid #ccc;
            border-radius: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            background: #fff;
            flex-shrink: 0;
        }

        .checkbox-wrap input:checked ~ .checkbox-box {
            background: #1a1a1a;
            border-color: #1a1a1a;
        }

        .checkbox-box::after {
            content: '✓';
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            transform: scale(0);
            transition: transform 0.2s;
        }

        .checkbox-wrap input:checked ~ .checkbox-box::after {
            transform: scale(1);
        }

        .forgot-link {
            color: #d4537e;
            font-weight: 500;
            transition: opacity 0.3s;
        }

            .forgot-link:hover {
                opacity: 0.7;
            }

        /* Submit button */
        .submit-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #1a1a1a, #2c2c2a);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .submit-btn::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
                transition: left 0.6s;
            }

            .submit-btn:hover::before {
                left: 100%;
            }

            .submit-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.2);
            }

            .submit-btn:active {
                transform: translateY(0);
            }

            .submit-btn.loading {
                pointer-events: none;
                opacity: 0.85;
            }

                .submit-btn.loading::after {
                    content: '';
                    width: 16px;
                    height: 16px;
                    border: 2px solid rgba(255,255,255,0.3);
                    border-top-color: #fff;
                    border-radius: 50%;
                    animation: rotate 0.8s linear infinite;
                    margin-left: 4px;
                }

                .submit-btn.loading .btn-text {
                    display: none;
                }

                .submit-btn.loading .btn-arrow {
                    display: none;
                }

        /* Terms */
        .terms-text {
            font-size: 11px;
            color: #999;
            text-align: center;
            margin-top: 16px;
            line-height: 1.6;
        }

            .terms-text a {
                color: #1a1a1a;
                text-decoration: underline;
            }

        /* TOAST */
        .toast-container {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
        }

        .toast {
            background: #fff;
            border-radius: 12px;
            padding: 14px 18px;
            box-shadow: 0 12px 32px rgba(0,0,0,0.15);
            display: flex;
            align-items: center;
            gap: 14px;
            min-width: 300px;
            max-width: 380px;
            border-left: 4px solid #1a1a1a;
            animation: slideInRightToast 0.4s ease forwards;
            pointer-events: auto;
        }

            .toast.success {
                border-left-color: #2eb872;
            }

            .toast.info {
                border-left-color: #378add;
            }

            .toast.error {
                border-left-color: #d44;
            }

            .toast.hide {
                animation: slideOutRightToast 0.4s ease forwards;
            }

        .toast-icon {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: #f5f5f5;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .toast.success .toast-icon {
            background: #e6f7ef;
            color: #2eb872;
        }

        .toast.info .toast-icon {
            background: #e8f3fc;
            color: #378add;
        }

        .toast.error .toast-icon {
            background: #fbeaea;
            color: #d44;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 2px;
        }

        .toast-desc {
            font-size: 12px;
            color: #666;
        }

        .toast-close {
            background: none;
            border: none;
            color: #aaa;
            font-size: 16px;
            cursor: pointer;
            padding: 4px;
        }

        /* RESPONSIVE */
        @@media (max-width: 1024px) {
            .auth-page {
                grid-template-columns: 1fr;
            }

            .brand-panel {
                min-height: 320px;
                padding: 32px;
            }

            .brand-center {
                padding: 20px 0;
            }

            .brand-features {
                display: none;
            }

            .form-panel {
                padding: 40px 32px;
            }
        }

        @@media (max-width: 640px) {
            .brand-panel {
                padding: 24px 20px;
                min-height: 240px;
            }

            .brand-bottom {
                display: none;
            }

            .brand-title {
                font-size: 28px;
            }

            .brand-subtitle {
                font-size: 14px;
                margin-bottom: 16px;
            }

            .form-panel {
                padding: 32px 20px;
            }

            .form-title {
                font-size: 24px;
            }

            .social-buttons {
                grid-template-columns: 1fr;
            }

            .form-row {
                grid-template-columns: 1fr;
            }

            .toast {
                min-width: auto;
                max-width: calc(100vw - 32px);
            }

            .toast-container {
                right: 16px;
                left: 16px;
            }
        }


    </style>
</head>
<body>

    <div class="auth-page">

        <!-- ============ LEFT BRAND PANEL ============ -->
        <div class="brand-panel">
            <div class="brand-bg-text">MONO</div>
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
            <div class="blob blob-3"></div>

            <div class="brand-top">
                <div class="brand-logo">MONO<span>.WEAR</span></div>
                <a href="/" class="back-link">
                    <i class="ti ti-arrow-left"></i>Quay lại
                </a>
            </div>

            <div class="brand-center">
                <div class="brand-eyebrow">
                    <span class="dot"></span>
                    <span>WELCOME BACK</span>
                </div>
                <h1 class="brand-title">
                    Hành trình thời trang <span class="accent">tối giản</span> bắt đầu từ đây.
                </h1>
                <p class="brand-subtitle">
                    Tham gia cộng đồng hơn 120.000 thành viên đang yêu thích phong cách tinh tế của MONO.WEAR.
                </p>
                <div class="brand-features">
                    <div class="brand-feature">
                        <div class="feature-icon"><i class="ti ti-gift"></i></div>
                        <span>Tặng voucher 100K cho thành viên mới</span>
                    </div>
                    <div class="brand-feature">
                        <div class="feature-icon"><i class="ti ti-truck-delivery"></i></div>
                        <span>Miễn phí vận chuyển cho đơn từ 500K</span>
                    </div>
                    <div class="brand-feature">
                        <div class="feature-icon"><i class="ti ti-discount-2"></i></div>
                        <span>Tích điểm đổi quà với mỗi đơn hàng</span>
                    </div>
                    <div class="brand-feature">
                        <div class="feature-icon"><i class="ti ti-shield-check"></i></div>
                        <span>Đổi trả không cần lý do trong 30 ngày</span>
                    </div>
                </div>
            </div>

            <div class="brand-bottom">
                <div>© 2026 MONO.WEAR · Made with ♥ in Vietnam</div>
                <div class="brand-socials">
                    <a href="#"><i class="ti ti-brand-facebook"></i></a>
                    <a href="#"><i class="ti ti-brand-instagram"></i></a>
                    <a href="#"><i class="ti ti-brand-tiktok"></i></a>
                </div>
            </div>
        </div>

        <!-- ============ RIGHT FORM PANEL ============ -->
        <div class="form-panel">
            <div class="form-wrapper">

                <!-- Tabs -->
                <div class="form-tabs" id="formTabs">
                    <button class="form-tab active" data-tab="login">Đăng nhập</button>
                    <button class="form-tab" data-tab="signup">Đăng ký</button>
                    <div class="form-tab-indicator"></div>
                </div>

                <!-- Forms -->
                <div class="form-container">

                    <!-- LOGIN FORM -->
                    <form class="form" id="loginForm" method="post" asp-controller="Home" asp-action="Login">
                        @Html.AntiForgeryToken()
                        <div class="form-header">
                            <div class="form-title">Chào mừng trở lại 👋</div>
                            <div class="form-subtitle">
                                Chưa có tài khoản? <a onclick="switchTab('signup')">Đăng ký ngay</a>
                            </div>
                        </div>

                        <div class="social-buttons">
                            <button type="button" class="social-btn" onclick="socialAuth('Google')">
                                <i class="ti ti-brand-google"></i>Google
                            </button>
                            <button type="button" class="social-btn" onclick="socialAuth('Facebook')">
                                <i class="ti ti-brand-facebook"></i>Facebook
                            </button>
                        </div>

                        <div class="divider">HOẶC</div>

                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <div class="input-wrap">
                                <i class="ti ti-mail input-icon"></i>
                                <input type="email" id="loginEmail" name="email" placeholder="your@email.com" required />
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Mật khẩu</label>
                            <div class="input-wrap">
                                <i class="ti ti-lock input-icon"></i>
                                <input type="password" id="loginPwd" name="password" placeholder="••••••••" required />
                                <button type="button" class="toggle-pwd" onclick="togglePwd('loginPwd', this)">
                                    <i class="ti ti-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="form-options">
                            <label class="checkbox-wrap">
                                <input type="checkbox" checked />
                                <span class="checkbox-box"></span>
                                <span>Ghi nhớ đăng nhập</span>
                            </label>
                            <a class="forgot-link" onclick="openForgotModal()">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="submit-btn">
                            <span class="btn-text">Đăng nhập</span>
                            <i class="ti ti-arrow-right btn-arrow"></i>
                        </button>
                    </form>

                    <!-- SIGNUP FORM -->
                    <form class="form hidden" id="signupForm" method="post" asp-controller="Home" asp-action="Register">
                        @Html.AntiForgeryToken()
                        <div class="form-header">
                            <div class="form-title">Tạo tài khoản mới ✨</div>
                            <div class="form-subtitle">
                                Đã có tài khoản? <a onclick="switchTab('login')">Đăng nhập</a>
                            </div>
                        </div>

                        <div class="social-buttons">
                            <button type="button" class="social-btn" onclick="socialAuth('Google')">
                                <i class="ti ti-brand-google"></i>Google
                            </button>
                            <button type="button" class="social-btn" onclick="socialAuth('Facebook')">
                                <i class="ti ti-brand-facebook"></i>Facebook
                            </button>
                        </div>

                        <div class="divider">HOẶC</div>

                        <div class="form-group">
                            <label class="form-label">Họ và tên</label>
                            <div class="input-wrap">
                                <i class="ti ti-user input-icon"></i>
                                <input type="text" name="fullName" placeholder="Trần Minh Khôi" required />
                            </div>
                        </div>

                        <div class="form-group" style="margin-top: 16px;">
                            <label class="form-label">Email</label>
                            <div class="input-wrap" id="emailWrap">
                                <i class="ti ti-mail input-icon"></i>
                                <input type="email" id="signupEmail" name="email" placeholder="your@email.com" required />
                            </div>
                            <div class="input-hint" id="emailHint" style="display: none;"></div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Số điện thoại</label>
                            <div class="input-wrap">
                                <i class="ti ti-phone input-icon"></i>
                                <input type="tel" name="phone" placeholder="0901 234 567" required />
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Mật khẩu</label>
                            <div class="input-wrap">
                                <i class="ti ti-lock input-icon"></i>
                                <input type="password" id="signupPwd" name="password" placeholder="Tối thiểu 8 ký tự" required oninput="checkPwdStrength(this.value)" />
                                <button type="button" class="toggle-pwd" onclick="togglePwd('signupPwd', this)">
                                    <i class="ti ti-eye"></i>
                                </button>
                            </div>
                            <div class="pwd-strength" id="pwdStrength">
                                <div class="strength-bar"></div>
                                <div class="strength-bar"></div>
                                <div class="strength-bar"></div>
                                <div class="strength-bar"></div>
                            </div>
                            <div class="strength-text" id="strengthText">Mật khẩu cần ít nhất 8 ký tự</div>
                        </div>

                        <div class="form-options">
                            <label class="checkbox-wrap">
                                <input type="checkbox" required />
                                <span class="checkbox-box"></span>
                                <span>Tôi đồng ý với <a href="#" style="color:#d4537e;">điều khoản</a> & <a href="#" style="color:#d4537e;">bảo mật</a></span>
                            </label>
                        </div>

                        <button type="submit" class="submit-btn">
                            <span class="btn-text">Tạo tài khoản</span>
                            <i class="ti ti-sparkles btn-arrow"></i>
                        </button>

                        <div class="terms-text">
                            Bằng việc đăng ký, bạn đồng ý nhận email khuyến mãi từ MONO.WEAR.<br />
                            Bạn có thể hủy bất cứ lúc nào.
                        </div>
                    </form>

                </div>
            </div>
        </div>

    </div>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        // ============ Tab switching ============
        const formTabs = document.getElementById('formTabs');
        const loginForm = document.getElementById('loginForm');
        const signupForm = document.getElementById('signupForm');

        function switchTab(tab) {
            document.querySelectorAll('.form-tab').forEach(t => t.classList.remove('active'));
            document.querySelector(`.form-tab[data-tab="${tab}"]`).classList.add('active');

            if (tab === 'signup') {
                formTabs.classList.add('signup-active');
                loginForm.classList.add('hidden');
                signupForm.classList.remove('hidden');
            } else {
                formTabs.classList.remove('signup-active');
                signupForm.classList.add('hidden');
                loginForm.classList.remove('hidden');
            }
        }

        document.querySelectorAll('.form-tab').forEach(tab => {
            tab.addEventListener('click', () => switchTab(tab.dataset.tab));
        });

        // ============ Toggle password ============
        function togglePwd(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('ti-eye');
                icon.classList.add('ti-eye-off');
            } else {
                input.type = 'password';
                icon.classList.remove('ti-eye-off');
                icon.classList.add('ti-eye');
            }
        }

        // ============ Password strength ============
        function checkPwdStrength(pwd) {
            const bars = document.querySelectorAll('#pwdStrength .strength-bar');
            const text = document.getElementById('strengthText');
            let score = 0;

            if (pwd.length >= 8) score++;
            if (/[a-z]/.test(pwd) && /[A-Z]/.test(pwd)) score++;
            if (/[0-9]/.test(pwd)) score++;
            if (/[^a-zA-Z0-9]/.test(pwd)) score++;

            bars.forEach(b => b.className = 'strength-bar');
            text.className = 'strength-text';

            if (pwd.length === 0) {
                text.textContent = 'Mật khẩu cần ít nhất 8 ký tự';
                return;
            }
            if (score === 1) {
                bars[0].classList.add('weak');
                text.classList.add('weak');
                text.textContent = 'Yếu — Thêm chữ in hoa, số';
            } else if (score === 2) {
                bars[0].classList.add('weak'); bars[1].classList.add('weak');
                text.classList.add('weak');
                text.textContent = 'Yếu — Thêm số hoặc ký tự đặc biệt';
            } else if (score === 3) {
                bars[0].classList.add('medium'); bars[1].classList.add('medium'); bars[2].classList.add('medium');
                text.classList.add('medium');
                text.textContent = 'Trung bình — Có thể mạnh hơn';
            } else if (score >= 4) {
                bars.forEach(b => b.classList.add('strong'));
                text.classList.add('strong');
                text.textContent = 'Mạnh — Mật khẩu an toàn ✓';
            }
        }

        // ============ Email validation ============
        const signupEmail = document.getElementById('signupEmail');
        const emailWrap = document.getElementById('emailWrap');
        const emailHint = document.getElementById('emailHint');
        signupEmail.addEventListener('blur', () => {
            const val = signupEmail.value.trim();
            if (!val) return;
            const valid = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(val);
            emailWrap.classList.remove('has-error', 'has-success');
            emailHint.style.display = 'flex';
            if (!valid) {
                emailWrap.classList.add('has-error');
                emailHint.className = 'input-hint error';
                emailHint.innerHTML = '<i class="ti ti-alert-circle"></i>Email không hợp lệ';
            } else {
                emailWrap.classList.add('has-success');
                emailHint.className = 'input-hint success';
                emailHint.innerHTML = '<i class="ti ti-circle-check"></i>Email hợp lệ';
            }
        });

        // ============ Submit handlers ============
        function handleLogin(e) {
            e.preventDefault();
            const btn = e.target.querySelector('.submit-btn');
            btn.classList.add('loading');
            btn.querySelector('.btn-text').textContent = 'Đang đăng nhập...';
            setTimeout(() => {
                btn.classList.remove('loading');
                btn.querySelector('.btn-text').textContent = 'Đăng nhập';
                showToast('success', 'Đăng nhập thành công!', 'Đang chuyển đến trang chủ...');
                setTimeout(() => {
                    // window.location.href = '/';
                    showToast('info', 'Demo', 'Trong thực tế sẽ chuyển trang ở đây');
                }, 1200);
            }, 1500);
        }

        function handleSignup(e) {
            e.preventDefault();
            const btn = e.target.querySelector('.submit-btn');
            btn.classList.add('loading');
            btn.querySelector('.btn-text').textContent = 'Đang tạo tài khoản...';
            setTimeout(() => {
                btn.classList.remove('loading');
                btn.querySelector('.btn-text').textContent = 'Tạo tài khoản';
                showToast('success', 'Tạo tài khoản thành công!', 'Voucher 100K đã được gửi vào email');
                setTimeout(() => {
                    showToast('info', 'Chào mừng đến với MONO.WEAR', 'Khám phá bộ sưu tập mới ngay');
                    switchTab('login');
                }, 1500);
            }, 1800);
        }

        // ============ Toast ============
        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icons = {
                success: 'ti-circle-check',
                info: 'ti-info-circle',
                error: 'ti-alert-circle'
            };
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
                <button class="toast-close"><i class="ti ti-x"></i></button>
            `;
            container.appendChild(toast);
            const closeBtn = toast.querySelector('.toast-close');
            const removeToast = () => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            };
            closeBtn.addEventListener('click', removeToast);
            setTimeout(removeToast, 3500);
        }

        // ============ Thông báo từ server (TempData) ============
    @if (TempData["AuthError"] != null)
    {
        <text>
        showToast('error', 'Lỗi', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["AuthError"]?.ToString())));
        switchTab('login');
        </text>
    }
    @if (TempData["AuthSuccess"] != null)
    {
        <text>
        showToast('success', 'Thành công', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["AuthSuccess"]?.ToString())));
        </text>
    }

        // ============ Đăng ký / đăng nhập qua mạng xã hội ============
        function socialAuth(provider) {
            const email = prompt('Đăng ký/đăng nhập bằng ' + provider + '\\nNhập email ' + provider + ' của bạn:');
            if (!email) return;
            if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email.trim())) { showToast('error', 'Email không hợp lệ', 'Vui lòng nhập đúng định dạng email'); return; }
            let name = prompt('Tên hiển thị của bạn (có thể bỏ trống):') || '';
            const fd = new FormData();
            fd.append('provider', provider);
            fd.append('email', email.trim());
            fd.append('name', name.trim());
            showToast('info', 'Đang kết nối ' + provider, 'Vui lòng chờ...');
            fetch('/Home/SocialAuth', { method: 'POST', body: fd })
                .then(r => r.ok ? r.json() : Promise.reject(r))
                .then(d => {
                    showToast('success', d.isNew ? 'Tạo tài khoản thành công' : 'Đăng nhập thành công', 'Đang chuyển đến tài khoản...');
                    setTimeout(() => { window.location.href = '/Home/TaiKhoan'; }, 900);
                })
                .catch(() => showToast('error', 'Lỗi', 'Không thể đăng nhập bằng ' + provider));
        }

        // ============ Parallax blobs theo mouse ============
        document.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth - 0.5) * 30;
            const y = (e.clientY / window.innerHeight - 0.5) * 30;
            document.querySelectorAll('.blob').forEach((blob, i) => {
                const factor = (i + 1) * 0.4;
                blob.style.translate = `${x * factor}px ${y * factor}px`;
            });
        });
    </script>

    <!-- Modal Quên mật khẩu -->
    <div id="forgotModal" style="display:none;position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,0.55);align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:18px;padding:32px;width:min(440px,95vw);position:relative;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
            <button onclick="closeForgotModal()" style="position:absolute;top:16px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#666;"><i class="ti ti-x"></i></button>
            <div style="font-size:20px;font-weight:700;margin-bottom:6px;">Đặt lại mật khẩu</div>
            <div style="font-size:13px;color:#888;margin-bottom:20px;">Nhập email và SĐT đã đăng ký để đặt lại mật khẩu mới.</div>
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div>
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Email</label>
                    <input type="email" id="fp-email" placeholder="email@example.com" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                </div>
                <div>
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Số điện thoại <span style="color:#aaa;font-weight:400;">(nếu tài khoản có)</span></label>
                    <input type="tel" id="fp-phone" placeholder="0901234567" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                </div>
                <div>
                    <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">Mật khẩu mới</label>
                    <input type="password" id="fp-newpass" placeholder="Tối thiểu 8 ký tự" style="width:100%;padding:11px 14px;border:1px solid #e2e2e2;border-radius:10px;font-size:14px;box-sizing:border-box;" />
                </div>
                <button onclick="submitForgot()" id="fp-btn" style="background:#1a1a1a;color:#fff;border:none;padding:12px;border-radius:10px;cursor:pointer;font-size:14px;font-weight:600;margin-top:4px;">Đặt lại mật khẩu</button>
            </div>
        </div>
    </div>

    <script>
        function openForgotModal() {
            document.getElementById('forgotModal').style.display = 'flex';
            const le = document.getElementById('email');
            if (le && le.value) document.getElementById('fp-email').value = le.value;
        }
        function closeForgotModal() { document.getElementById('forgotModal').style.display = 'none'; }
        document.getElementById('forgotModal').addEventListener('click', e => {
            if (e.target === document.getElementById('forgotModal')) closeForgotModal();
        });
        async function submitForgot() {
            const email = document.getElementById('fp-email').value.trim();
            const phone = document.getElementById('fp-phone').value.trim();
            const np    = document.getElementById('fp-newpass').value;
            if (!email || !np) { showToast('warning','Thiếu thông tin','Vui lòng nhập email và mật khẩu mới'); return; }
            if (np.length < 8) { showToast('warning','Mật khẩu yếu','Mật khẩu mới phải có ít nhất 8 ký tự'); return; }
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const fd = new FormData();
            fd.append('email', email);
            fd.append('phone', phone);
            fd.append('newPassword', np);
            fd.append('__RequestVerificationToken', token);
            const btn = document.getElementById('fp-btn');
            btn.disabled = true; btn.textContent = 'Đang xử lý...';
            try {
                const r = await fetch('/Home/ForgotPassword', { method:'POST', body: fd });
                if (r.ok) {
                    showToast('success','Đặt lại thành công','Bạn có thể đăng nhập bằng mật khẩu mới');
                    closeForgotModal();
                } else {
                    const d = await r.json().catch(()=>({}));
                    showToast('error','Không thành công', d.message || 'Vui lòng kiểm tra lại thông tin');
                }
            } catch { showToast('error','Lỗi','Thử lại sau'); }
            btn.disabled = false; btn.textContent = 'Đặt lại mật khẩu';
        }
    </script>

</body>
</html>
