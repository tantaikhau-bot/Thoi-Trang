    <script>
        // ============ Update qty & recalc ============
        function changeQty(btn, delta) {
            const input = btn.parentElement.querySelector('.qty-input');
            const max = parseInt(input.max);
            let val = parseInt(input.value) + delta;
            if (val < 1) val = 1;
            if (val > max) {
                showToast('warning', 'Đã đạt số lượng tối đa', `Chỉ còn ${max} sản phẩm trong kho`);
                return;
            }
            input.value = val;

            // Cập nhật giá item
            const item = btn.closest('.cart-item');
            const unit = parseInt(item.querySelector('.cart-price').dataset.unit);
            const priceEl = item.querySelector('.cart-price');
            const newTotal = unit * val;
            priceEl.textContent = newTotal.toLocaleString('vi-VN') + '₫';
            priceEl.style.animation = 'none';
            void priceEl.offsetWidth;
            priceEl.style.animation = 'numberPop 0.4s ease';

            recalcTotal();

            // Lưu số lượng vào DB
            const cartId = item.dataset.cartid;
            if (cartId) {
                const fd = new FormData(); fd.append('cartItemId', cartId); fd.append('quantity', val);
                fetch('/Home/UpdateCartQty', { method: 'POST', body: fd });
            }
        }

        // ============ Remove item ============
        function removeItem(btn) {
            const item = btn.closest('.cart-item');
            const cartId = item.dataset.cartid;
            const done = () => {
                item.classList.add('removing');
                setTimeout(() => {
                    item.remove();
                    recalcTotal();
                    if (typeof updateCount === 'function') updateCount();
                    showToast('info', 'Đã xóa sản phẩm', 'Sản phẩm đã được loại khỏi giỏ hàng');
                }, 400);
            };
            if (cartId) {
                const fd = new FormData(); fd.append('cartItemId', cartId);
                fetch('/Home/RemoveCartItem', { method: 'POST', body: fd }).then(done).catch(done);
            } else { done(); }
        }

        // ============ Heart toggle ============
        function toggleHeart(btn) {
            btn.classList.toggle('active');
            const icon = btn.querySelector('i');
            if (btn.classList.contains('active')) {
                icon.classList.remove('ti-heart');
                icon.classList.add('ti-heart-filled');
                showToast('success', 'Đã thêm yêu thích', 'Sản phẩm đã được lưu vào danh sách');
            } else {
                icon.classList.remove('ti-heart-filled');
                icon.classList.add('ti-heart');
            }
        }

        // ============ Select all ============
        document.getElementById('selectAll').addEventListener('change', (e) => {
            document.querySelectorAll('.item-check').forEach(cb => cb.checked = e.target.checked);
            recalcTotal();
        });
        document.addEventListener('change', (e) => {
            if (e.target.classList.contains('item-check')) {
                recalcTotal();
                const all = document.querySelectorAll('.item-check');
                const checked = document.querySelectorAll('.item-check:checked');
                document.getElementById('selectAll').checked = all.length === checked.length;
            }
        });

        // ============ Recalculate total ============
        let appliedVoucher = null;
        function recalcTotal() {
            let subtotal = 0;
            let savings = 0;
            document.querySelectorAll('.cart-item').forEach(item => {
                const cb = item.querySelector('.item-check');
                if (!cb || !cb.checked) return;
                const unit = parseInt(item.querySelector('.cart-price').dataset.unit);
                const qty = parseInt(item.querySelector('.qty-input').value);
                subtotal += unit * qty;
            });

            document.getElementById('subtotal').textContent = subtotal.toLocaleString('vi-VN') + '₫';

            // Voucher (theo dữ liệu thật)
            let voucherDiscount = calcVoucherDiscount(subtotal);
            if (voucherDiscount > subtotal) voucherDiscount = subtotal;
            if (appliedVoucherData) {
                document.getElementById('voucherAmount').textContent = '-' + voucherDiscount.toLocaleString('vi-VN') + '₫';
            }

            const shipping = subtotal >= 3000000 ? 0 : 30000;
            const total = subtotal - voucherDiscount + shipping;

            document.getElementById('shipping').textContent = shipping === 0 ? 'Miễn phí' : '30.000₫';
            document.getElementById('totalAmount').textContent = total.toLocaleString('vi-VN') + '₫';

            // Freeship progress
            const remain = 3000000 - subtotal;
            const fill = document.getElementById('freeshipFill');
            const text = document.getElementById('freeshipText');
            if (remain <= 0 || appliedVoucher === 'FREESHIP') {
                fill.style.width = '100%';
                text.innerHTML = '🎉 Chúc mừng! Bạn được <strong>miễn phí vận chuyển</strong>';
            } else {
                const percent = (subtotal / 3000000) * 100;
                fill.style.width = percent + '%';
                text.innerHTML = `Mua thêm <strong>${remain.toLocaleString('vi-VN')}₫</strong> nữa để được <strong>miễn phí vận chuyển</strong>`;
            }

            // Update count
            const count = document.querySelectorAll('.item-check:checked').length;
            document.getElementById('selectedCount').textContent = count;
        }

        function updateCount() {
            const total = document.querySelectorAll('.cart-item').length;
            document.getElementById('itemCountLabel').textContent = total + ' sản phẩm';
            document.getElementById('headerCartBadge').textContent = total;

            if (total === 0) {
                document.getElementById('cartCard').style.display = 'none';
                document.getElementById('emptyCart').classList.add('show');
            }
        }

        // ============ Apply voucher ============
        // Thêm sản phẩm gợi ý vào giỏ
        function addSuggestToCart(productId, btn) {
            const fd = new FormData(); fd.append('productId', productId);
            fetch('/Home/AddProductToCart', { method: 'POST', body: fd })
                .then(r => { if (r.status === 401) { window.location.href = '/Home/DangNhap'; return null; } return r.ok ? r.json() : Promise.reject(r); })
                .then(d => { if (!d) return; showToast('success', 'Đã thêm vào giỏ', 'Tải lại giỏ hàng...'); setTimeout(() => location.reload(), 700); })
                .catch(() => showToast('error', 'Lỗi', 'Không thêm được'));
        }

        // Lưu voucher vào tài khoản (mỗi tài khoản 1 lần, phải đăng nhập)
        function saveVoucherToAccount(voucherId, btn) {
            const fd = new FormData(); fd.append('voucherId', voucherId);
            fetch('/Home/SaveUserVoucher', { method: 'POST', body: fd })
                .then(r => {
                    if (r.status === 401) { showToast('warning', 'Cần đăng nhập', 'Vui lòng đăng nhập để lưu voucher'); setTimeout(() => window.location.href = '/Home/DangNhap', 900); return null; }
                    return r.ok ? r.json() : Promise.reject(r);
                })
                .then(d => {
                    if (!d) return;
                    if (d.success) { btn.textContent = 'Đã lưu'; btn.style.background = '#e6f7ef'; btn.style.color = '#2eb872'; showToast('success', 'Đã lưu voucher', 'Voucher đã được thêm vào tài khoản của bạn'); }
                    else { showToast('info', 'Đã lưu trước đó', d.message || 'Bạn đã lưu voucher này rồi'); btn.textContent = 'Đã lưu'; btn.style.background = '#e6f7ef'; btn.style.color = '#2eb872'; }
                })
                .catch(() => showToast('error', 'Lỗi', 'Không thể lưu voucher'));
        }

        // Chọn voucher (chưa áp dụng) — bấm "Áp dụng" mới tính giảm giá
        function selectVoucher(code, el) {
            document.querySelectorAll('.voucher-line').forEach(l => {
                l.style.borderColor = '#f0d5df';
                l.style.background = '#fff7fa';
                const r = l.querySelector('.voucher-radio');
                if (r) { r.style.borderColor = '#ccc'; r.style.background = 'transparent'; r.style.boxShadow = 'none'; }
            });
            el.style.borderColor = '#d4537e';
            el.style.background = '#fdeef3';
            const radio = el.querySelector('.voucher-radio');
            if (radio) { radio.style.borderColor = '#d4537e'; radio.style.background = '#d4537e'; radio.style.boxShadow = 'inset 0 0 0 3px #fff'; }
            document.getElementById('voucherInput').value = code;
            showToast('info', 'Đã chọn voucher', `Bấm "Áp dụng" để dùng mã ${code}`);
        }

        function applyVoucher() {
            const code = document.getElementById('voucherInput').value.trim().toUpperCase();
            if (!code) { showToast('warning', 'Chưa chọn voucher', 'Hãy chọn hoặc nhập một mã voucher'); return; }
            useVoucherChip(code);
        }
        let appliedVoucherData = null;
        function useVoucherChip(code) {
            code = (code || '').trim().toUpperCase();
            const line = document.querySelector('.voucher-line[data-code="' + code + '"]');
            if (!line) {
                showToast('error', 'Mã không hợp lệ', 'Mã này không có hoặc không khả dụng');
                return;
            }
            const min = parseInt(line.dataset.min) || 0;
            const subtotal = parseInt(document.getElementById('subtotal').textContent.replace(/\D/g, '')) || 0;
            if (subtotal < min) {
                showToast('warning', 'Chưa đủ điều kiện', `Đơn tối thiểu ${min.toLocaleString('vi-VN')}₫ để dùng ${code}`);
                return;
            }
            appliedVoucher = code;
            appliedVoucherData = {
                code: code,
                type: line.dataset.type,
                value: parseFloat(line.dataset.value) || 0,
                max: parseFloat(line.dataset.max) || 0
            };
            document.getElementById('voucherInput').value = code;
            document.getElementById('voucherCode').textContent = code;
            document.getElementById('voucherRow').style.display = 'flex';
            recalcTotal();
            showToast('success', 'Áp dụng thành công', `Đã dùng voucher ${code}`);
        }

        // Tính số tiền giảm từ voucher đang áp dụng
        function calcVoucherDiscount(subtotal) {
            if (!appliedVoucherData) return 0;
            let amt = 0;
            if (appliedVoucherData.type === 'percent') {
                amt = Math.floor(subtotal * appliedVoucherData.value / 100);
                if (appliedVoucherData.max > 0 && amt > appliedVoucherData.max) amt = appliedVoucherData.max;
            } else {
                amt = appliedVoucherData.value;
            }
            return amt;
        }

        // ============ Add to cart (fly animation) ============
        function addToCart(btn, name) {
            const img = btn.parentElement;
            const rect = img.getBoundingClientRect();
            const targetBadge = document.getElementById('headerCartBadge').getBoundingClientRect();

            const clone = img.cloneNode(true);
            clone.querySelector('.suggest-add').remove();
            clone.classList.add('fly-clone');
            clone.style.left = rect.left + 'px';
            clone.style.top = rect.top + 'px';
            clone.style.width = rect.width + 'px';
            clone.style.height = rect.height + 'px';
            document.body.appendChild(clone);

            setTimeout(() => {
                clone.remove();
                const badge = document.getElementById('headerCartBadge');
                badge.textContent = parseInt(badge.textContent) + 1;
                badge.style.animation = 'none';
                void badge.offsetWidth;
                badge.style.animation = 'heartBeat 0.6s ease, pulse 2s infinite 0.6s';
            }, 800);

            showToast('success', 'Thêm vào giỏ thành công', `${name} đã được thêm`);
        }

        // ============ Clear cart ============
        function clearCart() {
            const items = document.querySelectorAll('.cart-item');
            const checked = Array.from(items).filter(i => i.querySelector('.item-check').checked);
            if (checked.length === 0) {
                showToast('warning', 'Chưa chọn sản phẩm', 'Hãy chọn ít nhất 1 sản phẩm để xóa');
                return;
            }
            const tasks = checked.map(item => {
                const cartId = item.dataset.cartid;
                if (!cartId) return Promise.resolve();
                const fd = new FormData(); fd.append('cartItemId', cartId);
                return fetch('/Home/RemoveCartItem', { method: 'POST', body: fd }).then(() => { item.remove(); });
            });
            Promise.all(tasks).then(() => {
                recalcTotal();
                if (typeof updateCount === 'function') updateCount();
                showToast('info', `Đã xóa ${checked.length} sản phẩm`, 'Các sản phẩm đã được loại khỏi giỏ');
            });
        }

        // ============ Lưu để mua sau → đưa vào Yêu thích ============
        function saveForLater() {
            const items = document.querySelectorAll('.cart-item');
            const checked = Array.from(items).filter(i => i.querySelector('.item-check') && i.querySelector('.item-check').checked);
            if (checked.length === 0) { showToast('warning', 'Chưa chọn sản phẩm', 'Hãy chọn sản phẩm để lưu'); return; }
            const tasks = checked.map(item => {
                const pid = item.dataset.pid, cartId = item.dataset.cartid;
                if (!pid) return Promise.resolve();
                const fw = new FormData(); fw.append('productId', pid);
                return fetch('/Home/ToggleWishlist', { method: 'POST', body: fw })
                    .then(r => r.ok ? r.json() : null)
                    .then(() => {
                        if (cartId) { const fd = new FormData(); fd.append('cartItemId', cartId); return fetch('/Home/RemoveCartItem', { method: 'POST', body: fd }); }
                    })
                    .then(() => { item.remove(); });
            });
            Promise.all(tasks).then(() => {
                recalcTotal();
                if (typeof updateCount === 'function') updateCount();
                showToast('success', `Đã lưu ${checked.length} sản phẩm`, 'Đã chuyển vào danh sách Yêu thích');
            });
        }

        // ============ Checkout ============
        function checkout() {
            const checkedItems = document.querySelectorAll('.cart-item');
            const selected = [];
            checkedItems.forEach(item => {
                const cb = item.querySelector('.item-check');
                if (!cb || !cb.checked) return;
                const name = item.querySelector('.cart-name').textContent.trim();
                const cat = item.querySelector('.cart-cat') ? item.querySelector('.cart-cat').textContent.trim() : '';
                const metaTags = item.querySelectorAll('.cart-meta-tag');
                let variant = [];
                metaTags.forEach(t => variant.push(t.textContent.trim()));
                const unit = parseInt(item.querySelector('.cart-price').dataset.unit);
                const qty = parseInt(item.querySelector('.qty-input').value);
                // Lấy class màu nền ảnh
                const imgEl = item.querySelector('.cart-img');
                let bgClass = 'bg-cream';
                imgEl.classList.forEach(c => { if (c.startsWith('bg-')) bgClass = c; });
                const iconEl = item.querySelector('.cart-img i');
                let icon = 'ti-shirt';
                iconEl.classList.forEach(c => { if (c.startsWith('ti-') && c !== 'ti') icon = c; });
                const vid = parseInt(item.dataset.vid) || null;
                selected.push({ variantId: vid, name, cat, variant: variant.join(' · '), unit, qty, bgClass, icon });
            });

            if (selected.length === 0) {
                showToast('warning', 'Chưa chọn sản phẩm', 'Hãy chọn ít nhất 1 sản phẩm để thanh toán');
                return;
            }

            // Tính toán tổng tiền
            const subtotal = parseInt(document.getElementById('subtotal').textContent.replace(/\D/g, ''));
            const productDiscount = 0;
            let voucherDiscount = calcVoucherDiscount(subtotal);
            if (voucherDiscount > subtotal) voucherDiscount = subtotal;
            const shipping = (subtotal >= 3000000) ? 0 : 30000;
            const total = subtotal - voucherDiscount + shipping;

            const orderData = {
                items: selected,
                subtotal: subtotal,
                productDiscount: productDiscount,
                voucher: appliedVoucher || '',
                voucherDiscount: voucherDiscount,
                shipping: shipping,
                total: total
            };

            // Lưu vào sessionStorage để trang Checkout đọc
            try {
                sessionStorage.setItem('monoOrder', JSON.stringify(orderData));
            } catch (e) { /* fallback */ }

            showToast('success', 'Đang chuyển đến thanh toán', `Thanh toán ${selected.length} sản phẩm...`);
            setTimeout(() => {
                window.location.href = '/Home/Checkout';
            }, 900);
        }

        // ============ Header + scroll top ============
        const header = document.getElementById('header');
        const scrollTopBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) header.classList.add('scrolled');
            else header.classList.remove('scrolled');
            if (window.scrollY > 400) scrollTopBtn.classList.add('show');
            else scrollTopBtn.classList.remove('show');
        });
        scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // ============ Toast ============
        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icons = {
                success: 'ti-circle-check',
                info: 'ti-info-circle',
                warning: 'ti-alert-circle',
                error: 'ti-x'
            };
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
                <button class="toast-close"><i class="ti ti-x"></i></button>
            `;
            container.appendChild(toast);
            const closeBtn = toast.querySelector('.toast-close');
            const removeToast = () => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            };
            closeBtn.addEventListener('click', removeToast);
            setTimeout(removeToast, 3500);
        }

        // ============ Khởi tạo ============
        recalcTotal();
    </script>

    <script src="/js/search.js"></script>
    @await Html.PartialAsync("_ChatWidget")
</body>
</html>
