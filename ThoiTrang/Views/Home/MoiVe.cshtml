                    <i class="ti ti-brand-visa" title="Visa"></i>
                    <i class="ti ti-brand-mastercard" title="Mastercard"></i>
                    <i class="ti ti-credit-card" title="COD"></i>
                    <i class="ti ti-shield-check" title="Bảo mật"></i>
                </div>
