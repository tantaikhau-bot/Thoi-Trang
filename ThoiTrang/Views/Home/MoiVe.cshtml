    <button class="scroll-top" id="scrollTop" aria-label="Lên đầu trang">
        <i class="ti ti-arrow-up"></i>
    </button>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        // ===== Countdown đến drop tiếp theo =====
        const dropTarget = new Date();
        dropTarget.setDate(dropTarget.getDate() + 2);
        dropTarget.setHours(18, 0, 0, 0);

        function updateCountdown() {
            const now = new Date();
            const diff = dropTarget - now;
            if (diff <= 0) {
                document.getElementById('dDays').textContent = '00';
                document.getElementById('dHours').textContent = '00';
                document.getElementById('dMinutes').textContent = '00';
                document.getElementById('dSeconds').textContent = '00';
                return;
            }
            const days = Math.floor(diff / 86400000);
            const hours = Math.floor((diff % 86400000) / 3600000);
            const minutes = Math.floor((diff % 3600000) / 60000);
            const seconds = Math.floor((diff % 60000) / 1000);
            document.getElementById('dDays').textContent = String(days).padStart(2, '0');
            document.getElementById('dHours').textContent = String(hours).padStart(2, '0');
            document.getElementById('dMinutes').textContent = String(minutes).padStart(2, '0');
            document.getElementById('dSeconds').textContent = String(seconds).padStart(2, '0');
        }
        setInterval(updateCountdown, 1000);
        updateCountdown();

        // ===== Filter pills =====
        document.querySelectorAll('.filter-pill').forEach(pill => {
            pill.addEventListener('click', () => {
                document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
                pill.classList.add('active');
                const name = pill.textContent.replace(/\d+/g, '').trim();
                showToast('info', 'Đã lọc', `Đang xem: ${name}`);
            });
        });

        // ===== Week tabs =====
        document.querySelectorAll('.week-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.week-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const week = tab.querySelector('.week-num').textContent;
                showToast('info', 'Đã chuyển tuần', `Đang xem sản phẩm ${week}`);
            });
        });

        // ===== Heart toggle (product cards) =====
        document.querySelectorAll('.icon-heart').forEach(icon => {
            icon.addEventListener('click', (e) => {
                e.stopPropagation();
                if (icon.classList.contains('ti-bell')) {
                    notifyMe();
                    return;
                }
                icon.classList.toggle('active');
                if (icon.classList.contains('active')) {
                    showToast('success', 'Đã thêm yêu thích', 'Sản phẩm đã được lưu vào danh sách');
                }
            });
        });

        function toggleFavBtn(btn) {
            btn.classList.toggle('active');
            const icon = btn.querySelector('i');
            if (btn.classList.contains('active')) {
                icon.classList.remove('ti-heart');
                icon.classList.add('ti-heart-filled');
                showToast('success', 'Đã thêm yêu thích', 'Sản phẩm đã được lưu vào danh sách');
            } else {
                icon.classList.remove('ti-heart-filled');
                icon.classList.add('ti-heart');
            }
        }

        // ===== Add to cart =====
        function addToCart() {
            const badge = document.querySelector('.cart-badge');
            badge.textContent = parseInt(badge.textContent) + 1;
            badge.style.animation = 'none';
            void badge.offsetWidth;
            badge.style.animation = 'heartBeat 0.6s ease, pulse 2s infinite 0.6s';
            showToast('success', 'Đã thêm vào giỏ', 'Sản phẩm đã được thêm thành công');
        }

        // ===== Notify me (coming soon) =====
        function notifyMe() {
            showToast('success', 'Đã đặt nhắc', 'Chúng tôi sẽ thông báo khi sản phẩm ra mắt');
        }

        // ===== Newsletter =====
        function subscribeNewsletter() {
            const email = document.getElementById('newsletterEmail').value.trim();
            if (!email || !email.includes('@@')) {
                showToast('info', 'Email không hợp lệ', 'Vui lòng nhập đúng định dạng email');
                return;
            }
            document.getElementById('newsletterEmail').value = '';
            showToast('success', 'Đăng ký thành công', 'Bạn sẽ nhận drop mới sớm nhất qua email');
        }

        // ===== Load more =====
        document.getElementById('loadMoreBtn').addEventListener('click', () => {
            const btn = document.getElementById('loadMoreBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="ti ti-loader-2"></i> Đang tải...';
            setTimeout(() => {
                btn.disabled = false;
                btn.innerHTML = '<i class="ti ti-refresh"></i> Xem thêm 26 sản phẩm mới';
                showToast('info', 'Đã tải thêm 8 sản phẩm', 'Cuộn xuống để xem');
            }, 1500);
        });

        // ===== Header scroll =====
        const header = document.getElementById('header');
        const scrollTopBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) header.classList.add('scrolled');
            else header.classList.remove('scrolled');
            if (window.scrollY > 400) scrollTopBtn.classList.add('show');
            else scrollTopBtn.classList.remove('show');
        });
        scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // ===== Toast =====
        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icons = { success: 'ti-circle-check', info: 'ti-info-circle' };
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
                <button class="toast-close"><i class="ti ti-x"></i></button>
            `;
            container.appendChild(toast);
            const closeBtn = toast.querySelector('.toast-close');
            const removeToast = () => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            };
            closeBtn.addEventListener('click', removeToast);
            setTimeout(removeToast, 3500);
        }
    </script>

    <script src="~/js/filter.js" asp-append-version="true"></script>

    <script src="/js/search.js"></script>
    @await Html.PartialAsync("_ChatWidget")
</body>
</html>
