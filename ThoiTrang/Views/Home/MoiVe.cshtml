                    <div class="footer-col-title">Hỗ trợ</div>
                    <ul class="footer-links-list">
                        <li><a href="#">Chính sách giao hàng</a></li>
                        <li><a href="#">Đổi trả 30 ngày</a></li>
                        <li><a href="#">Hướng dẫn size</a></li>
                        <li><a href="#">Liên hệ</a></li>
                    </ul>
