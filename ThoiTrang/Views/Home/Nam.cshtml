                    <label class="filter-check"><input type="checkbox" /> Denim <span class="count">52</span></label>
                    <label class="filter-check"><input type="checkbox" /> Len pha <span class="count">29</span></label>
                    <label class="filter-check"><input type="checkbox" /> Polyester <span class="count">76</span></label>
                </div>
            </div>

            <div class="filter-group">
                <h4>ĐÁNH GIÁ <i class="ti ti-chevron-down"></i></h4>
                <div class="filter-options">
                    <label class="filter-check"><input type="checkbox" /> ★★★★★ 5 sao <span class="count">142</span></label>
                    <label class="filter-check"><input type="checkbox" /> ★★★★ 4 sao trở lên <span class="count">298</span></label>
                    <label class="filter-check"><input type="checkbox" /> ★★★ 3 sao trở lên <span class="count">386</span></label>
                </div>
            </div>
        </aside>

        <!-- Product list -->
        <div class="product-list reveal">

            <!-- Active filter chips -->
            <div class="active-filters">
                <div class="filter-chip">Áo thun <i class="ti ti-x"></i></div>
                <div class="filter-chip">Size M <i class="ti ti-x"></i></div>
                <div class="filter-chip">Màu Đen <i class="ti ti-x"></i></div>
                <div class="filter-chip">Dưới 2tr <i class="ti ti-x"></i></div>
