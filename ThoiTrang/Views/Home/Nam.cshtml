    <script>
        // Sub-nav pills
        document.querySelectorAll('.sub-pill').forEach(pill => {
            pill.addEventListener('click', () => {
                document.querySelectorAll('.sub-pill').forEach(p => p.classList.remove('active'));
                pill.classList.add('active');
                const name = pill.textContent.trim();
                showToast('info', 'Đã lọc danh mục', `Đang xem: ${name}`);
            });
        });

        // Filter group collapse
        document.querySelectorAll('.filter-group h4').forEach(h => {
            h.addEventListener('click', () => h.parentElement.classList.toggle('collapsed'));
        });

        // Size buttons
        document.querySelectorAll('.size-btn').forEach(btn => {
            btn.addEventListener('click', () => btn.classList.toggle('active'));
        });

        // Color swatches
        document.querySelectorAll('.color-swatch').forEach(sw => {
            sw.addEventListener('click', () => sw.classList.toggle('active'));
        });

        // Price slider
        const slider = document.getElementById('priceSlider');
        const priceMax = document.getElementById('priceMax');
        slider.addEventListener('input', () => {
            const val = parseInt(slider.value);
            priceMax.textContent = val.toLocaleString('vi-VN') + '₫';
        });

        // View toggle
        document.querySelectorAll('.view-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });

        // Filter chip remove
        document.querySelectorAll('.filter-chip i').forEach(x => {
            x.addEventListener('click', (e) => {
                e.stopPropagation();
                x.parentElement.style.opacity = '0';
                x.parentElement.style.transform = 'scale(0.8)';
                setTimeout(() => x.parentElement.remove(), 300);
            });
        });

        // Clear all filters
        document.getElementById('clearFilter').addEventListener('click', () => {
            document.querySelectorAll('.filter-chip').forEach(c => c.remove());
            document.querySelectorAll('.filter-check input').forEach(i => i.checked = false);
            document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
            showToast('info', 'Đã xóa bộ lọc', 'Tất cả bộ lọc đã được đặt lại');
        });

        // Pagination
        document.querySelectorAll('.page-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                if (btn.disabled || btn.querySelector('i')) return;
                document.querySelectorAll('.page-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                window.scrollTo({ top: 400, behavior: 'smooth' });
            });
        });

        // Heart toggle
        document.querySelectorAll('.icon-heart').forEach(icon => {
            icon.addEventListener('click', (e) => {
                e.stopPropagation();
                icon.classList.toggle('active');
                if (icon.classList.contains('active')) {
                    showToast('success', 'Đã thêm yêu thích', 'Sản phẩm đã được lưu vào danh sách');
                }
            });
        });

        // Quick actions
        document.querySelectorAll('.quick-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                if (btn.querySelector('.ti-plus')) {
                    const badge = document.querySelector('.cart-badge');
                    badge.textContent = parseInt(badge.textContent) + 1;
                    badge.style.animation = 'none';
                    void badge.offsetWidth;
                    badge.style.animation = 'heartBeat 0.6s ease, pulse 2s infinite 0.6s';
                    showToast('success', 'Thêm vào giỏ thành công', 'Sản phẩm đã được thêm');
                } else if (btn.querySelector('.ti-eye')) {
                    showToast('info', 'Xem nhanh', 'Tính năng đang phát triển');
                }
            });
        });

        // Mobile filter toggle
        document.getElementById('filterToggle').addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('open');
        });

        // Reveal animation
        const reveals = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('active');
            });
        }, { threshold: 0.1 });
        reveals.forEach(r => observer.observe(r));

        // Header + scroll top
        const header = document.getElementById('header');
        const scrollTopBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) header.classList.add('scrolled');
            else header.classList.remove('scrolled');
            if (window.scrollY > 400) scrollTopBtn.classList.add('show');
            else scrollTopBtn.classList.remove('show');
        });
        scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // Toast
        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icons = { success: 'ti-circle-check', info: 'ti-info-circle' };
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
                <button class="toast-close"><i class="ti ti-x"></i></button>
            `;
            container.appendChild(toast);
            const closeBtn = toast.querySelector('.toast-close');
            const removeToast = () => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            };
            closeBtn.addEventListener('click', removeToast);
            setTimeout(removeToast, 3500);
        }
    </script>

