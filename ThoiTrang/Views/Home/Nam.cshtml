        <div class="sub-pill"><i class="ti ti-hanger"></i>Quần kaki</div>
        <div class="sub-pill"><i class="ti ti-hanger"></i>Quần short</div>
        <div class="sub-pill"><i class="ti ti-shoe"></i>Giày</div>
        <div class="sub-pill"><i class="ti ti-shopping-bag"></i>Túi</div>
        <div class="sub-pill"><i class="ti ti-sunglasses"></i>Phụ kiện</div>
    </div>

    <div class="main">
        <!-- Sidebar Filter -->
