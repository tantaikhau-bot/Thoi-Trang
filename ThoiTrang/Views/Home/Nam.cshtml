            <!-- Toolbar -->
            <div class="list-toolbar">
                <div class="result-count">Tìm thấy <strong>248</strong> sản phẩm</div>
                <div class="toolbar-right">
                    <button class="filter-toggle-mobile" id="filterToggle">
