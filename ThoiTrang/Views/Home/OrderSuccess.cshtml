@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MONO.WEAR - Đặt hàng thành công</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@2.47.0/tabler-icons.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            overflow-x: clip; /* Chặn tuyệt đối việc tràn viền ngang */
            position: relative;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            color: #1a1a1a;
            background: #f5f5f3;
            line-height: 1.5;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button {
            font-family: inherit;
            cursor: pointer;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes checkDraw {
            0% {
                stroke-dashoffset: 100;
            }

            100% {
                stroke-dashoffset: 0;
            }
        }

        @@keyframes circleScale {
            0% {
                transform: scale(0);
            }

            60% {
                transform: scale(1.1);
            }

            100% {
                transform: scale(1);
            }
        }

        @@keyframes confettiFall {
            0% {
                transform: translateY(-20px) rotate(0);
                opacity: 1;
            }

            100% {
                transform: translateY(100vh) rotate(720deg);
                opacity: 0;
            }
        }

        @@keyframes shimmer {
            0% {
                background-position: -200% 0;
            }

            100% {
                background-position: 200% 0;
            }
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.06);
            }
        }

        @@keyframes slideInRightToast {
            from {
                transform: translateX(120%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .announce {
            background: #1a1a1a;
            color: #fff;
            text-align: center;
            padding: 10px 16px;
            font-size: 12px;
            letter-spacing: 0.5px;
        }

        .header {
            background: #fff;
            border-bottom: 1px solid #eee;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 60px;
        }

        .logo {
            font-size: 26px;
            font-weight: 500;
            letter-spacing: 1.5px;
        }

            .logo span {
                font-weight: 300;
            }

        .header-icons {
            display: flex;
            align-items: center;
            gap: 24px;
            font-size: 22px;
        }

            .header-icons a {
                color: #1a1a1a;
                transition: transform 0.3s;
                position: relative;
            }

                .header-icons a:hover {
                    transform: translateY(-3px);
                }

        .cart-badge {
            position: absolute;
            top: -6px;
            right: -8px;
            background: #1a1a1a;
            color: #fff;
            font-size: 10px;
            min-width: 18px;
            height: 18px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        /* STEPS */
        .page-header {
            padding: 28px 60px 0;
        }

        .steps {
            display: flex;
            align-items: center;
            justify-content: center;
            max-width: 600px;
            margin: 0 auto;
        }

        .step {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: #aaa;
        }

        .step-num {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #e8e8e4;
            color: #999;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
        }

        .step.done .step-num {
            background: #2eb872;
            color: #fff;
        }

        .step.done {
            color: #2eb872;
        }

        .step.active .step-num {
            background: #2eb872;
            color: #fff;
        }

        .step.active {
            color: #2eb872;
            font-weight: 500;
        }

        .step-divider {
            width: 60px;
            height: 2px;
            background: #e8e8e4;
            margin: 0 16px;
        }

            .step-divider.done {
                background: #2eb872;
            }

        /* SUCCESS HERO */
        .success-hero {
            text-align: center;
            padding: 50px 60px 36px;
            max-width: 600px;
            margin: 0 auto;
        }

        .success-circle {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #2eb872, #4ad295);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            animation: circleScale 0.6s ease;
            box-shadow: 0 12px 32px rgba(46,184,114,0.35);
        }

            .success-circle svg {
                width: 50px;
                height: 50px;
            }

                .success-circle svg path {
                    stroke: #fff;
                    stroke-width: 4;
                    fill: none;
                    stroke-linecap: round;
                    stroke-linejoin: round;
                    stroke-dasharray: 100;
                    animation: checkDraw 0.6s ease 0.3s both;
                }

        .success-title {
            font-size: 28px;
            font-weight: 500;
            margin-bottom: 10px;
            animation: fadeInUp 0.5s ease 0.2s both;
        }

        .success-desc {
            font-size: 15px;
            color: #888;
            line-height: 1.7;
            animation: fadeInUp 0.5s ease 0.3s both;
        }

        .success-orderid {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #fff;
            padding: 10px 20px;
            border-radius: 999px;
            margin-top: 18px;
            font-size: 14px;
            box-shadow: 0 4px 14px rgba(0,0,0,0.06);
            animation: fadeInUp 0.5s ease 0.4s both;
        }

            .success-orderid strong {
                font-family: 'Courier New', monospace;
                color: #1a1a1a;
            }

            .success-orderid i {
                color: #2eb872;
                font-size: 17px;
            }

        /* MAIN */
        .main-container {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 28px;
            padding: 12px 60px 80px;
            align-items: start;
            max-width: 1200px;
            margin: 0 auto;
        }

        .card {
            background: #fff;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            animation: fadeInUp 0.5s ease 0.5s both;
        }

        .card-title {
            font-size: 17px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 24px;
        }

            .card-title i {
                width: 34px;
                height: 34px;
                background: #1a1a1a;
                color: #fff;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 18px;
            }

        /* TIMELINE TRACKING */
        .tracking {
            position: relative;
            padding-left: 8px;
        }

        .track-step {
            display: flex;
            gap: 18px;
            position: relative;
            padding-bottom: 28px;
        }

            .track-step:last-child {
                padding-bottom: 0;
            }

            .track-step::before {
                content: '';
                position: absolute;
                left: 19px;
                top: 40px;
                bottom: -4px;
                width: 2px;
                background: #e8e8e4;
            }

            .track-step:last-child::before {
                display: none;
            }

            .track-step.done::before {
                background: #2eb872;
            }

        .track-dot {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #f0f0ec;
            color: #bbb;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
            flex-shrink: 0;
            z-index: 2;
            transition: all 0.3s;
        }

        .track-step.done .track-dot {
            background: #2eb872;
            color: #fff;
        }

        .track-step.active .track-dot {
            background: #1a1a1a;
            color: #fff;
            animation: pulse 2s infinite;
        }

        .track-content {
            flex: 1;
            padding-top: 4px;
        }

        .track-name {
            font-size: 15px;
            font-weight: 500;
            margin-bottom: 3px;
        }

        .track-step.done .track-name, .track-step.active .track-name {
            color: #1a1a1a;
        }

        .track-step:not(.done):not(.active) .track-name {
            color: #aaa;
        }

        .track-time {
            font-size: 12px;
            color: #999;
        }

        .track-desc {
            font-size: 13px;
            color: #888;
            margin-top: 4px;
        }

        .track-current-tag {
            display: inline-block;
            background: #1a1a1a;
            color: #fff;
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 5px;
            letter-spacing: 0.5px;
            margin-left: 8px;
        }

        /* INFO GRID */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 4px;
        }

        .info-block {
            background: #f9f8f4;
            border-radius: 14px;
            padding: 18px;
        }

        .info-block-title {
            font-size: 12px;
            color: #999;
            letter-spacing: 1px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .info-block-title i {
                font-size: 15px;
            }

        .info-block-content {
            font-size: 14px;
            line-height: 1.7;
        }

            .info-block-content strong {
                font-weight: 500;
            }

            .info-block-content .muted {
                color: #888;
                font-size: 13px;
            }

        .pay-status {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            font-weight: 500;
            padding: 3px 10px;
            border-radius: 6px;
            margin-top: 6px;
        }

            .pay-status.paid {
                background: #e6f7ef;
                color: #2eb872;
            }

            .pay-status.pending {
                background: #fff4e0;
                color: #d18800;
            }

        /* ACTION BUTTONS */
        .success-actions {
            display: flex;
            gap: 12px;
            margin-top: 24px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 14px 24px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary {
            flex: 1;
            background: linear-gradient(135deg, #1a1a1a, #2c2c2a);
            color: #fff;
            position: relative;
            overflow: hidden;
        }

            .btn-primary::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
                transition: left 0.6s;
            }

            .btn-primary:hover::before {
                left: 100%;
            }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 28px rgba(0,0,0,0.2);
            }

        .btn-outline {
            background: #fff;
            color: #1a1a1a;
            border: 1px solid #e0e0db;
        }

            .btn-outline:hover {
                border-color: #1a1a1a;
            }

        .btn i {
            font-size: 17px;
        }

        /* RIGHT SUMMARY */
        .summary-card {
            background: #fff;
            border-radius: 20px;
            padding: 26px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            position: sticky;
            top: 110px;
            animation: fadeInUp 0.5s ease 0.6s both;
        }

        .summary-title {
            font-size: 17px;
            font-weight: 500;
            margin-bottom: 18px;
        }

        .mini-items {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 18px;
            padding-bottom: 18px;
            border-bottom: 1px solid #f0f0ec;
            max-height: 260px;
            overflow-y: auto;
        }

        .mini-item {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .mini-img {
            width: 52px;
            height: 52px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            flex-shrink: 0;
        }

            .mini-img i {
                font-size: 24px;
                color: rgba(0,0,0,0.2);
            }

            .mini-img.dark i {
                color: rgba(255,255,255,0.25);
            }

        .mini-qty {
            position: absolute;
            top: -6px;
            right: -6px;
            background: #1a1a1a;
            color: #fff;
            font-size: 10px;
            min-width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        .bg-cream {
            background: #f1efe8;
        }

        .bg-dark {
            background: #2c2c2a;
        }

        .bg-gray {
            background: #d3d1c7;
        }

        .bg-blue {
            background: #2c3e5e;
        }

        .bg-brown {
            background: #6b4423;
        }

        .bg-green {
            background: #4a5d3a;
        }

        .mini-info {
            flex: 1;
            min-width: 0;
        }

        .mini-name {
            font-size: 13px;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .mini-variant {
            font-size: 11px;
            color: #999;
        }

        .mini-price {
            font-size: 13px;
            font-weight: 600;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            margin-bottom: 10px;
        }

            .summary-row .label {
                color: #888;
            }

            .summary-row.discount .value {
                color: #d4537e;
            }

            .summary-row.total {
                font-size: 16px;
                font-weight: 600;
                padding-top: 14px;
                border-top: 1px solid #f0f0ec;
                margin-top: 14px;
                margin-bottom: 0;
            }

                .summary-row.total .value {
                    color: #d4537e;
                    font-size: 22px;
                }

        /* SUPPORT CARD */
        .support-card {
            background: linear-gradient(135deg, #1a1a1a, #2c2c2a);
            color: #fff;
            border-radius: 20px;
            padding: 22px;
            margin-top: 20px;
            text-align: center;
            animation: fadeInUp 0.5s ease 0.7s both;
        }

            .support-card i {
                font-size: 28px;
                color: #d4537e;
                margin-bottom: 10px;
            }

        .support-title {
            font-size: 15px;
            font-weight: 500;
            margin-bottom: 6px;
        }

        .support-desc {
            font-size: 12px;
            color: rgba(255,255,255,0.6);
            margin-bottom: 14px;
        }

        .support-btn {
            background: #fff;
            color: #1a1a1a;
            padding: 10px 20px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            transition: transform 0.3s;
        }

            .support-btn:hover {
                transform: translateY(-2px);
            }

        /* FOOTER */
        .footer {
            background: #111111;
            color: #ffffff;
            padding: 70px 0 0 0; /* Bỏ padding đáy để thanh marquee bám sát khít */
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            margin-top: 80px;
            width: 100%;
            overflow: hidden;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Lưới chia 4 cột */
        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
            gap: 40px;
            margin-bottom: 40px;
        }

        .footer-col-title {
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 24px;
            color: #ffffff;
        }

        /* Cột 1: Logo & Giới thiệu */
        .footer-brand .footer-logo {
            font-size: 22px;
            font-weight: 700;
            letter-spacing: 3px;
            margin-bottom: 16px;
        }

        .footer-brand p {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.6;
        }

        /* Các cột Link danh mục */
        .footer-links-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

            .footer-links-list a {
                font-size: 13px;
                color: rgba(255, 255, 255, 0.5);
                transition: all 0.25s ease;
                display: inline-block;
            }

                .footer-links-list a:hover {
                    color: #ffffff;
                    transform: translateX(4px);
                }

        /* Cột Newsletter */
        .footer-newsletter p {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 16px;
            line-height: 1.6;
        }

        .newsletter-form {
            display: flex;
            position: relative;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            overflow: hidden;
            transition: border-color 0.3s ease;
        }

            .newsletter-form:focus-within {
                border-color: rgba(255, 255, 255, 0.4);
            }

        .newsletter-input {
            flex: 1;
            background: transparent;
            border: none;
            padding: 12px 16px;
            color: #ffffff;
            font-size: 13px;
            outline: none;
        }

            .newsletter-input::placeholder {
                color: rgba(255, 255, 255, 0.3);
            }

        .newsletter-btn {
            background: transparent;
            border: none;
            color: #ffffff;
            padding: 0 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: color 0.2s ease;
        }

            .newsletter-btn:hover {
                color: rgba(255, 255, 255, 0.7);
            }

        /* Dòng thông tin bản quyền ở giữa */
        .footer-mid-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            padding-bottom: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 24px;
        }

        .footer-text {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.4);
        }

        .footer-payments {
            display: flex;
            gap: 16px;
            color: rgba(255, 255, 255, 0.3);
            font-size: 20px;
        }

        /* ============ THANH MARQUEE ĐEN TUYỀN CHẠY ĐÁY TRANG (FULL-WIDTH) ============ */
        .footer-bottom-marquee {
            width: 100vw;
            position: relative;
            left: 50%;
            right: 50%;
            margin-left: -50vw;
            margin-right: -50vw;
            background: #090909; /* Đen sẫm hơn hẳn tạo khối tương phản chân trang */
            padding: 14px 0;
            display: flex;
            overflow: hidden;
            white-space: nowrap;
            user-select: none;
        }

        .marquee-wrapper {
            display: flex;
            align-items: center;
            gap: 60px;
            animation: footerMarqueeScroll 28s linear infinite;
        }

        .footer-bottom-marquee:hover .marquee-wrapper {
            animation-play-state: paused; /* Rê chuột vào sẽ tạm dừng để đọc */
        }

        .marquee-text-item {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.75);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

            .marquee-text-item i {
                color: #e2856b; /* Icon màu cam ấm tinh tế */
                font-size: 13px;
            }

        @@keyframes footerMarqueeScroll {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-33.333%);
            }
        }

        /* Responsive */
        @@media (max-width: 992px) {
            .footer-grid {
                grid-template-columns: 1fr 1fr;
                gap: 30px;
            }
        }

        @@media (max-width: 576px) {
            .footer {
                padding-top: 50px;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .footer-mid-row {
                flex-direction: column;
                text-align: center;
            }
        }

        /* TOAST */
        .toast-container {
            position: fixed;
            top: 100px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
        }

        .toast {
            background: #fff;
            border-radius: 12px;
            padding: 14px 18px;
            box-shadow: 0 12px 32px rgba(0,0,0,0.15);
            display: flex;
            align-items: center;
            gap: 14px;
            min-width: 300px;
            max-width: 360px;
            border-left: 4px solid #2eb872;
            animation: slideInRightToast 0.4s ease forwards;
        }

        .toast-icon {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #e6f7ef;
            color: #2eb872;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .toast-title {
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 2px;
        }

        .toast-desc {
            font-size: 12px;
            color: #666;
        }

        @@media (max-width: 1100px) {
            .header-top, .page-header, .success-hero, .footer {
                padding-left: 32px;
                padding-right: 32px;
            }

            .main-container {
                grid-template-columns: 1fr;
                padding-left: 32px;
                padding-right: 32px;
            }

            .summary-card {
                position: static;
            }
        }

        @@media (max-width: 640px) {
            .header-top, .page-header, .success-hero, .footer {
                padding-left: 16px;
                padding-right: 16px;
            }

            .main-container {
                padding-left: 16px;
                padding-right: 16px;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }

            .step span:not(.step-num) {
                display: none;
            }

            .step-divider {
                width: 40px;
                margin: 0 8px;
            }

            .success-actions {
                flex-direction: column;
            }

            .toast {
                min-width: auto;
                max-width: calc(100vw - 32px);
            }

            .toast-container {
                right: 16px;
                left: 16px;
            }
        }
    </style>
</head>
<body>

    <div class="announce">Cảm ơn bạn đã mua sắm tại MONO.WEAR · Đơn hàng của bạn đang được xử lý</div>

    <header class="header">
        <div class="header-top">
            <a href="/" class="logo">MONO<span>.WEAR</span></a>
            <div class="header-icons">
                <a href="/Home/TaiKhoan"><i class="ti ti-user"></i></a>
                <a href="/Home/Cart"><i class="ti ti-shopping-bag"></i><span class="cart-badge" id="headerCartBadge">0</span></a>
            </div>
        </div>
    </header>

    <section class="page-header">
        <div class="steps">
            <div class="step done">
                <span class="step-num"><i class="ti ti-check"></i></span>
                <span>Giỏ hàng</span>
            </div>
            <div class="step-divider done"></div>
            <div class="step done">
                <span class="step-num"><i class="ti ti-check"></i></span>
                <span>Thanh toán</span>
            </div>
            <div class="step-divider done"></div>
            <div class="step active">
                <span class="step-num"><i class="ti ti-check"></i></span>
                <span>Hoàn tất</span>
            </div>
        </div>
    </section>

    <!-- SUCCESS HERO -->
    <section class="success-hero">
        <div class="success-circle">
            <svg viewBox="0 0 52 52">
                <path d="M14 27 L22 35 L38 18" />
            </svg>
        </div>
        <h1 class="success-title">Đặt hàng thành công!</h1>
        <p class="success-desc">Cảm ơn bạn đã tin tưởng MONO.WEAR. Chúng tôi đã nhận được đơn hàng và sẽ xử lý trong thời gian sớm nhất.</p>
        <div class="success-orderid">
            <i class="ti ti-receipt"></i>
            Mã đơn hàng: <strong id="orderIdDisplay">#MNW0000000000</strong>
        </div>
    </section>

    <div class="main-container">

        <!-- LEFT -->
        <div style="display: flex; flex-direction: column; gap: 20px;">

            <!-- TRACKING TIMELINE -->
            <div class="card">
                <div class="card-title"><i class="ti ti-route"></i>Trạng thái đơn hàng</div>
                <div class="tracking">
                    <div class="track-step done">
                        <div class="track-dot"><i class="ti ti-circle-check"></i></div>
                        <div class="track-content">
                            <div class="track-name">Đơn hàng đã đặt</div>
                            <div class="track-time" id="trackTime1">Vừa xong</div>
                            <div class="track-desc">Đơn hàng của bạn đã được tiếp nhận thành công</div>
                        </div>
                    </div>
                    <div class="track-step active">
                        <div class="track-dot"><i class="ti ti-package"></i></div>
                        <div class="track-content">
                            <div class="track-name">Đang chuẩn bị hàng <span class="track-current-tag">HIỆN TẠI</span></div>
                            <div class="track-time">Dự kiến trong 24 giờ</div>
                            <div class="track-desc">Shop đang đóng gói và kiểm tra chất lượng sản phẩm</div>
                        </div>
                    </div>
                    <div class="track-step">
                        <div class="track-dot"><i class="ti ti-truck"></i></div>
                        <div class="track-content">
                            <div class="track-name">Đang giao hàng</div>
                            <div class="track-time">Dự kiến 2-3 ngày</div>
                            <div class="track-desc">Đơn vị vận chuyển sẽ giao hàng đến địa chỉ của bạn</div>
                        </div>
                    </div>
                    <div class="track-step">
                        <div class="track-dot"><i class="ti ti-home-check"></i></div>
                        <div class="track-content">
                            <div class="track-name">Giao hàng thành công</div>
                            <div class="track-time">Dự kiến 21-22/05/2026</div>
                            <div class="track-desc">Nhận hàng và đánh giá để tích điểm thưởng</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ORDER INFO -->
            <div class="card">
                <div class="card-title"><i class="ti ti-info-circle"></i>Thông tin đơn hàng</div>
                <div class="info-grid">
                    <div class="info-block">
                        <div class="info-block-title"><i class="ti ti-map-pin"></i>GIAO ĐẾN</div>
                        <div class="info-block-content">
                            <strong id="recvName">Trần Minh Khôi</strong><br />
                            <span class="muted" id="recvPhone">0901 234 567</span><br />
                            <span class="muted" id="recvAddress">123 Nguyễn Huệ, Q1, TP.HCM</span>
                        </div>
                    </div>
                    <div class="info-block">
                        <div class="info-block-title"><i class="ti ti-credit-card"></i>THANH TOÁN</div>
                        <div class="info-block-content">
                            <strong id="payMethodLabel">Chuyển khoản ngân hàng</strong><br />
                            <span class="pay-status paid" id="payStatus"><i class="ti ti-circle-check"></i>Đã thanh toán</span>
                        </div>
                    </div>
                    <div class="info-block">
                        <div class="info-block-title"><i class="ti ti-calendar"></i>NGÀY ĐẶT</div>
                        <div class="info-block-content">
                            <strong id="orderDate">28/05/2026</strong><br />
                            <span class="muted">Đơn hàng tiêu chuẩn</span>
                        </div>
                    </div>
                    <div class="info-block">
                        <div class="info-block-title"><i class="ti ti-note"></i>GHI CHÚ</div>
                        <div class="info-block-content">
                            <span class="muted" id="orderNote">Không có ghi chú</span>
                        </div>
                    </div>
                </div>

                <div class="success-actions">
                    <button class="btn btn-primary" onclick="window.location.href='/Home/TaiKhoan'">
                        <i class="ti ti-package"></i>Theo dõi đơn hàng
                    </button>
                    <button class="btn btn-outline" onclick="window.location.href='/'">
                        <i class="ti ti-home"></i>Tiếp tục mua sắm
                    </button>
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <aside>
            <div class="summary-card">
                <div class="summary-title">Sản phẩm đã đặt</div>
                <div class="mini-items" id="miniItems"></div>

                <div class="summary-row">
                    <span class="label">Tạm tính</span>
                    <span class="value" id="sumSubtotal">0₫</span>
                </div>
                <div class="summary-row discount">
                    <span class="label">Giảm giá</span>
                    <span class="value" id="sumDiscount">0₫</span>
                </div>
                <div class="summary-row">
                    <span class="label">Vận chuyển</span>
                    <span class="value" id="sumShipping">0₫</span>
                </div>
                <div class="summary-row total">
                    <span class="label">Tổng cộng</span>
                    <span class="value" id="sumTotal">0₫</span>
                </div>
            </div>

            <div class="support-card">
                <i class="ti ti-headset"></i>
                <div class="support-title">Cần hỗ trợ?</div>
                <div class="support-desc">Liên hệ với chúng tôi nếu bạn có thắc mắc về đơn hàng</div>
                <button class="support-btn" onclick="window.location.href='/Home/TaiKhoan'">
                    Trung tâm hỗ trợ
                </button>
            </div>
        </aside>

    </div>

    <footer class="footer">
        <div class="footer-container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="footer-logo">MONO.WEAR</div>
                    <p>Thương hiệu thời trang tối giản, mang lại sự tự tin và định hình phong cách sống hiện đại qua từng sợi vải tinh tế.</p>
                </div>

                <div>
                    <div class="footer-col-title">Mua sắm</div>
                    <ul class="footer-links-list">
                        <li><a href="/Products">Tất cả sản phẩm</a></li>
                        <li><a href="#">Bộ sưu tập mới</a></li>
                        <li><a href="#">Áo thun & Polo</a></li>
                        <li><a href="#">Quần & Accessories</a></li>
                    </ul>
                </div>

                <div>
                    <div class="footer-col-title">Hỗ trợ chăm sóc</div>
                    <ul class="footer-links-list">
                        <li><a href="#">Chính sách giao hàng</a></li>
                        <li><a href="#">Chính sách đổi trả 30 ngày</a></li>
                        <li><a href="#">Hướng dẫn chọn Size</a></li>
                        <li><a href="#">Liên hệ phản hồi</a></li>
                    </ul>
                </div>

                <div class="footer-newsletter">
                    <div class="footer-col-title">Đăng ký nhận tin</div>
                    <p>Để lại email của bạn để cập nhật sớm nhất các ưu đãi đặc quyền và bộ sưu tập mới độc quyền.</p>
                    <div class="newsletter-form">
                        <input type="email" class="newsletter-input" placeholder="Địa chỉ email của bạn..." />
                        <button class="newsletter-btn" type="button" aria-label="Đăng ký">
                            <i class="ti ti-arrow-narrow-right"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="footer-mid-row">
                <div class="footer-text">
                    &copy; 2026 MONO.WEAR · Phát triển trên nền tảng ASP.NET Core
                </div>
                <div class="footer-payments">
                    <i class="ti ti-brand-visa" title="Visa"></i>
                    <i class="ti ti-brand-mastercard" title="Mastercard"></i>
                    <i class="ti ti-credit-card" title="Thanh toán COD"></i>
                    <i class="ti ti-shield-check" title="Bảo mật"></i>
                </div>
            </div>
        </div>


    </footer>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        // ===== Đọc order =====
        let order = null;
        try { order = JSON.parse(sessionStorage.getItem('monoOrder')); } catch (e) {}
        if (!order || !order.items) {
            order = {
                items: [
                    { name: 'Áo sơ mi linen oversize', variant: 'Kem · Size M', unit: 525000, qty: 2, bgClass: 'bg-cream', icon: 'ti-shirt' },
                    { name: 'Quần tailored khaki', variant: 'Nâu · Size 30', unit: 620000, qty: 1, bgClass: 'bg-brown', icon: 'ti-hanger' }
                ],
                subtotal: 1670000, productDiscount: 585000, voucherDiscount: 0, shipFee: 30000,
                finalTotal: 1115000,
                orderId: 'MNW' + Date.now().toString().slice(-10),
                payMethod: 'cod',
                receiver: { name: 'Trần Minh Khôi', phone: '0901 234 567', address: '123 Nguyễn Huệ, Q1, TP.HCM' }
            };
        }

        const orderId = order.orderId || ('MNW' + Date.now().toString().slice(-10));
        document.getElementById('orderIdDisplay').textContent = '#' + orderId;

        // Receiver
        if (order.receiver) {
            document.getElementById('recvName').textContent = order.receiver.name;
            document.getElementById('recvPhone').textContent = order.receiver.phone;
            document.getElementById('recvAddress').textContent = order.receiver.address;
        }

        // Payment method label + status
        const payLabels = {
            bank: 'Chuyển khoản ngân hàng',
            momo: 'Ví Momo',
            vnpay: 'VNPAY',
            visa: 'Thẻ Visa/Master',
            cod: 'Thanh toán khi nhận (COD)'
        };
        document.getElementById('payMethodLabel').textContent = order.payMethodLabel || payLabels[order.payMethod] || 'Chuyển khoản ngân hàng';

        const payStatusEl = document.getElementById('payStatus');
        if (order.payMethod === 'cod') {
            payStatusEl.className = 'pay-status pending';
            payStatusEl.innerHTML = '<i class="ti ti-clock"></i>Thanh toán khi nhận';
        } else if (order.status === 'paid') {
            payStatusEl.className = 'pay-status paid';
            payStatusEl.innerHTML = '<i class="ti ti-circle-check"></i>Đã thanh toán';
        } else {
            payStatusEl.className = 'pay-status pending';
            payStatusEl.innerHTML = '<i class="ti ti-clock"></i>Chờ xác nhận';
        }

        // Order date
        document.getElementById('orderDate').textContent = order.orderDate ? order.orderDate.split(' ')[0] || order.orderDate : new Date().toLocaleDateString('vi-VN');

        // Note
        if (order.note && order.note.trim()) {
            document.getElementById('orderNote').textContent = order.note;
        }

        // Track time
        document.getElementById('trackTime1').textContent = order.orderDate || new Date().toLocaleString('vi-VN');

        // Mini items
        const miniContainer = document.getElementById('miniItems');
        order.items.forEach(it => {
            const isDark = ['bg-dark','bg-blue','bg-brown','bg-green'].includes(it.bgClass);
            const div = document.createElement('div');
            div.className = 'mini-item';
            div.innerHTML = `
                <div class="mini-img ${it.bgClass || 'bg-cream'} ${isDark ? 'dark' : ''}">
                    <i class="ti ${it.icon || 'ti-shirt'}"></i>
                    <span class="mini-qty">${it.qty}</span>
                </div>
                <div class="mini-info">
                    <div class="mini-name">${it.name}</div>
                    <div class="mini-variant">${it.variant || ''}</div>
                </div>
                <div class="mini-price">${(it.unit * it.qty).toLocaleString('vi-VN')}₫</div>
            `;
            miniContainer.appendChild(div);
        });

        // Summary
        document.getElementById('sumSubtotal').textContent = order.subtotal.toLocaleString('vi-VN') + '₫';
        const totalDiscount = (order.productDiscount || 0) + (order.voucherDiscount || 0);
        document.getElementById('sumDiscount').textContent = '-' + totalDiscount.toLocaleString('vi-VN') + '₫';
        const shipFee = order.shipFee != null ? order.shipFee : (order.shipping || 0);
        document.getElementById('sumShipping').textContent = shipFee === 0 ? 'Miễn phí' : shipFee.toLocaleString('vi-VN') + '₫';
        const finalTotal = order.finalTotal || (order.subtotal - totalDiscount + shipFee);
        document.getElementById('sumTotal').textContent = finalTotal.toLocaleString('vi-VN') + '₫';

        // ===== Confetti =====
        function triggerConfetti() {
            const colors = ['#2eb872', '#4ad295', '#d4537e', '#e2856b', '#f0b400', '#1a1a1a'];
            for (let i = 0; i < 60; i++) {
                const c = document.createElement('div');
                c.style.position = 'fixed';
                c.style.width = (Math.random() * 8 + 6) + 'px';
                c.style.height = (Math.random() * 8 + 6) + 'px';
                c.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                c.style.left = Math.random() * 100 + 'vw';
                c.style.top = '-20px';
                c.style.zIndex = '9999';
                c.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                c.style.pointerEvents = 'none';
                c.style.animation = `confettiFall ${Math.random() * 2 + 2}s linear forwards`;
                document.body.appendChild(c);
                setTimeout(() => c.remove(), 4000);
            }
        }

        // ===== Toast =====
        function showToast(title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ti-circle-check"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
            `;
            container.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 400); }, 4000);
        }

        // ===== Khởi tạo =====
        setTimeout(triggerConfetti, 400);
        setTimeout(() => {
            showToast('Đơn hàng đã xác nhận', 'Email xác nhận đã được gửi đến bạn');
        }, 1000);

        // Xóa giỏ hàng sau khi đặt thành công (badge về 0)
        document.getElementById('headerCartBadge').textContent = '0';
    </script>

    @await Html.PartialAsync("_ChatWidget")
</body>
</html>
