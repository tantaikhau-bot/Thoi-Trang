        .toast.info .toast-icon-wrap {
            background: #e8f3fc;
            color: #378add;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .toast-desc {
            font-size: 12px;
            color: #666;
        }

        /* FOOTER */
        .footer {
            background: #111111;
            color: #ffffff;
            padding: 70px 0 0 0; /* Bỏ padding đáy để thanh marquee bám sát khít */
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            margin-top: 80px;
            width: 100%;
            overflow: hidden;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Lưới chia 4 cột */
        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
            gap: 40px;
            margin-bottom: 40px;
        }

        .footer-col-title {
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 24px;
            color: #ffffff;
        }

        /* Cột 1: Logo & Giới thiệu */
        .footer-brand .footer-logo {
            font-size: 22px;
            font-weight: 700;
            letter-spacing: 3px;
            margin-bottom: 16px;
        }

        .footer-brand p {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.6;
        }

        /* Các cột Link danh mục */
        .footer-links-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

            .footer-links-list a {
                font-size: 13px;
                color: rgba(255, 255, 255, 0.5);
                transition: all 0.25s ease;
                display: inline-block;
            }

                .footer-links-list a:hover {
                    color: #ffffff;
                    transform: translateX(4px);
                }

        /* Cột Newsletter */
        .footer-newsletter p {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 16px;
            line-height: 1.6;
        }

        .newsletter-form {
            display: flex;
            position: relative;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            overflow: hidden;
            transition: border-color 0.3s ease;
        }

            .newsletter-form:focus-within {
                border-color: rgba(255, 255, 255, 0.4);
            }

        .newsletter-input {
            flex: 1;
            background: transparent;
            border: none;
            padding: 12px 16px;
            color: #ffffff;
            font-size: 13px;
            outline: none;
        }

            .newsletter-input::placeholder {
                color: rgba(255, 255, 255, 0.3);
            }

        .newsletter-btn {
            background: transparent;
            border: none;
            color: #ffffff;
            padding: 0 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: color 0.2s ease;
        }

            .newsletter-btn:hover {
                color: rgba(255, 255, 255, 0.7);
            }

        /* Dòng thông tin bản quyền ở giữa */
        .footer-mid-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            padding-bottom: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 24px;
        }

        .footer-text {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.4);
        }

        .footer-payments {
            display: flex;
            gap: 16px;
            color: rgba(255, 255, 255, 0.3);
            font-size: 20px;
        }

        /* ============ THANH MARQUEE ĐEN TUYỀN CHẠY ĐÁY TRANG (FULL-WIDTH) ============ */
        .footer-bottom-marquee {
            width: 100vw;
            position: relative;
            left: 50%;
            right: 50%;
            margin-left: -50vw;
            margin-right: -50vw;
            background: #090909; /* Đen sẫm hơn hẳn tạo khối tương phản chân trang */
            padding: 14px 0;
            display: flex;
            overflow: hidden;
            white-space: nowrap;
            user-select: none;
        }

        .marquee-wrapper {
            display: flex;
            align-items: center;
            gap: 60px;
            animation: footerMarqueeScroll 28s linear infinite;
        }

        .footer-bottom-marquee:hover .marquee-wrapper {
            animation-play-state: paused; /* Rê chuột vào sẽ tạm dừng để đọc */
        }

        .marquee-text-item {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.75);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

            .marquee-text-item i {
                color: #e2856b; /* Icon màu cam ấm tinh tế */
                font-size: 13px;
            }

        @@keyframes footerMarqueeScroll {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-33.333%);
            }
        }

        /* Responsive */
        @@media (max-width: 992px) {
            .footer-grid {
                grid-template-columns: 1fr 1fr;
                gap: 30px;
            }
        }

        @@media (max-width: 576px) {
            .footer {
                padding-top: 50px;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .footer-mid-row {
                flex-direction: column;
                text-align: center;
            }
        }

        /* RESPONSIVE */
        @@media (max-width: 1280px) {
            .header-top, .nav, .page-hero, .ads-combo-section, .lucky-zone, .vouchers-section, .combo-section, .donggia-section, .flash-section, .footer {
                padding-left: 32px;
                padding-right: 32px;
            }

            .lucky-zone {
                margin: 0 32px 24px;
            }

            .voucher-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .combo-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .donggia-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 1024px) {
            .page-hero-grid {
                grid-template-columns: 1fr;
            }

            .ads-combo-section {
                grid-template-columns: 1fr;
            }

            .lucky-zone {
                grid-template-columns: 1fr;
            }

            .main-grid {
                grid-template-columns: 1fr;
            }

            .filter-sidebar {
                position: static;
            }

            .products {
                grid-template-columns: repeat(2, 1fr);
            }

            .voucher-grid {
                grid-template-columns: 1fr;
            }

            .combo-grid {
                grid-template-columns: 1fr;
            }

            .donggia-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .search-box {
                display: none;
            }

            .page-hero h1 {
                font-size: 36px;
            }
        }

        @@media (max-width: 720px) {
            .header-top, .nav {
                padding-left: 16px;
                padding-right: 16px;
            }

            .nav {
                gap: 18px;
                overflow-x: auto;
            }

            .page-hero {
                padding: 40px 16px;
            }

            .ads-combo-section, .vouchers-section, .combo-section, .donggia-section, .flash-section, .footer {
                padding-left: 16px;
                padding-right: 16px;
            }

            .lucky-zone {
                margin: 0 16px 24px;
                padding: 24px 18px;
            }

            .wheel-container {
                width: 240px;
                height: 240px;
            }

            .products {
                grid-template-columns: 1fr 1fr;
                gap: 12px;
            }

            .donggia-grid {
                grid-template-columns: 1fr 1fr;
                gap: 12px;
            }

            .timer {
                gap: 8px;
            }

            .time-segment {
                min-width: 56px;
                padding: 10px 4px;
            }

            .time-num {
                font-size: 24px;
            }

            .flash-header {
                padding: 16px 18px;
            }

                .flash-header h2 {
                    font-size: 18px;
                }

            .toast-container {
                right: 16px;
                left: 16px;
                top: 80px;
            }

            .toast {
                min-width: auto;
                max-width: 100%;
            }
        }

        /* ===== Override thẻ sản phẩm dùng chung (_ProductCard) ===== */
        .products .product { display: block; background: #fff; border-radius: 16px; overflow: hidden; border: 1px solid #ececec; transition: transform .3s, box-shadow .3s; }
        .products .product:hover { transform: translateY(-6px); box-shadow: 0 14px 30px rgba(0,0,0,.08); }
        .products .product-image { aspect-ratio: 1; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
        .products .product-image i.product-icon { font-size: 100px; color: rgba(0,0,0,.15); transition: transform .6s ease; }
        .products .product:hover .product-icon { transform: scale(1.15) rotate(5deg); }
        .products .bg-cream { background: #f1efe8; } .products .bg-dark { background: #2c2c2a; } .products .bg-gray { background: #d3d1c7; } .products .bg-blue { background: #2c3e5e; } .products .bg-brown { background: #6b4423; }
        .products .bg-dark .product-icon, .products .bg-blue .product-icon, .products .bg-brown .product-icon { color: rgba(255,255,255,.15); }
        .products .quick-actions { position: absolute; bottom: -60px; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; transition: bottom .4s ease; }
        .products .product:hover .quick-actions { bottom: 16px; }
        .products .quick-btn { background: #fff; border: none; width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer; box-shadow: 0 4px 12px rgba(0,0,0,.15); }
        .products .badge-product { position: absolute; top: 14px; left: 14px; font-size: 11px; font-weight: 500; padding: 5px 10px; border-radius: 6px; z-index: 3; }
        .products .badge-new { background: #1a1a1a; color: #fff; } .products .badge-sale { background: #d4537e; color: #fff; } .products .badge-bestseller { background: #fff; color: #1a1a1a; border: 1px solid #eee; }
        .products .icon-heart { position: absolute; top: 14px; right: 14px; font-size: 18px; cursor: pointer; color: #1a1a1a; z-index: 3; background: rgba(255,255,255,.85); width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .products .bg-dark .icon-heart, .products .bg-blue .icon-heart, .products .bg-brown .icon-heart { background: rgba(0,0,0,.3); color: #fff; }
        .products .product-info { padding: 18px; }
        .products .product-cat { font-size: 11px; color: #888; letter-spacing: 1px; margin-bottom: 4px; text-transform: uppercase; }
        .products .product-name { font-size: 15px; font-weight: 500; margin-bottom: 6px; color: #1a1a1a; }
        .products .product-colors { display: flex; gap: 4px; margin-bottom: 10px; }
        .products .mini-color { width: 14px; height: 14px; border-radius: 50%; border: 1px solid #eee; }
        .products .product-price-row { display: flex; align-items: baseline; gap: 8px; justify-content: space-between; }
        .products .price-left { display: flex; align-items: baseline; gap: 6px; }
        .products .price-current { font-size: 17px; font-weight: 600; color: #1a1a1a; }
        .products .price-old { font-size: 13px; color: #aaa; text-decoration: line-through; }
        .products .rating-mini { display: flex; align-items: center; gap: 3px; font-size: 12px; color: #666; }
        .products .rating-mini i { color: #f0b400; font-size: 14px; }
    </style>
</head>
<body>

    <div class="live-ads-bar">
        <div class="marquee-inner">
            <span><i class="ti ti-bolt"></i>FLASH SALE 12H mỗi ngày — giảm đến 70%</span>
            <span><i class="ti ti-gift"></i>Nhập mã <strong>MONO150K</strong> giảm 150K cho đơn từ 800K</span>
            <span><i class="ti ti-truck-delivery"></i>FREESHIP toàn quốc cho đơn từ 500K</span>
            <span><i class="ti ti-flame"></i>Đại tiệc 5.5 — 800+ sản phẩm đang giảm sốc</span>
            <span><i class="ti ti-confetti"></i>Quay vòng may mắn nhận voucher mỗi ngày</span>
            <span><i class="ti ti-bolt"></i>FLASH SALE 12H mỗi ngày — giảm đến 70%</span>
            <span><i class="ti ti-gift"></i>Nhập mã <strong>MONO150K</strong> giảm 150K cho đơn từ 800K</span>
        </div>
    </div>

    <div class="announce">
        🔥 ĐẠI TIỆC SALE 5.5 — GIẢM SỐC ĐẾN 70% · KÉO DÀI ĐẾN HẾT TUẦN 🔥
    </div>

    <header class="header">
        <div class="header-top">
            <a href="/" class="logo">MONO<span>.WEAR</span></a>
            <div class="search-box">
                <i class="ti ti-search"></i>
                <input type="text" placeholder="Tìm sản phẩm sale..." />
            </div>
            <div class="header-icons">
                <a asp-controller="Home" asp-action="ThongBao" aria-label="Thông báo">
                    <i class="ti ti-bell bell-icon"></i>
                    <span class="notif-badge">5</span>
                </a>

                <a asp-controller="Home" asp-action="TaiKhoan" aria-label="Tài khoản">
                    <i class="ti ti-user"></i>
                </a>

                <a asp-controller="Home" asp-action="YeuThich" aria-label="Yêu thích">
                    <i class="ti ti-heart"></i>
                </a>

                <a asp-controller="Home" asp-action="GioHang" aria-label="Giỏ hàng">
                    <i class="ti ti-shopping-bag"></i>
                    <span class="cart-badge">3</span>
                </a>
            </div>
        </div>
        <nav class="nav">
            <a asp-controller="Home" asp-action="Index" >Trang chủ</a>

            <a asp-controller="Home" asp-action="Nam" asp-route-id="nam">Nam</a>

            <a asp-controller="Home" asp-action="Nu" asp-route-id="nu">Nữ</a>

            <a asp-controller="Home" asp-action="MoiVe">Mới về</a>

            <a asp-controller="Home" asp-action="BoSuuTap">Bộ sưu tập</a>

            <a asp-controller="Home" asp-action="Sale" class="active">Sale</a>

            <a asp-controller="Home" asp-action="GioiThieu">Về chúng tôi</a>
        </nav>
    </header>

    <!-- HERO -->
    <section class="page-hero">
        <div class="page-hero-grid">
            <div>
                <div class="hero-tag">
                    <span class="dot"></span>
                    Đang diễn ra · Live event
                </div>
                <h1>Đại Tiệc Sale <span>5.5</span><br />Bùng Nổ Đầu Hè</h1>
                <p class="hero-desc">
                    Hơn <strong style="color:#fff;">800 sản phẩm</strong> giảm sốc đến 70%, voucher tích lũy, freeship toàn quốc và vòng quay may mắn mỗi ngày. Đừng bỏ lỡ — sự kiện chỉ kéo dài đến hết tuần này!
                </p>
                <div class="hero-stats">
                    <div>
                        <div class="hero-stat-num">800+</div>
                        <div class="hero-stat-label">SẢN PHẨM SALE</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">70%</div>
                        <div class="hero-stat-label">GIẢM TỐI ĐA</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">12K+</div>
                        <div class="hero-stat-label">ĐÃ MUA HÔM NAY</div>
                    </div>
                </div>
            </div>

            @{
                var nextEvent = ViewBag.NextSaleEvent as ThoiTrang.Models.Entities.ScheduledEvent;
                var currentEvent = ViewBag.CurrentSaleEvent as ThoiTrang.Models.Entities.ScheduledEvent;
            }
            <div class="countdown-box" id="countdownBox" data-target="@(nextEvent != null ? nextEvent.EventDate.ToString("yyyy-MM-ddTHH:mm:ss") : "")">
                @if (nextEvent != null)
                {
                    <div class="countdown-title">
                        <i class="ti ti-calendar-event"></i><span id="cdTitle">@nextEvent.Title.ToUpper()</span> — BẮT ĐẦU SAU
                    </div>
                }
                else
                {
                    <div class="countdown-title">
                        <i class="ti ti-flame"></i>@(currentEvent != null ? currentEvent.Title.ToUpper() + " — ĐANG DIỄN RA" : "SALE ĐANG DIỄN RA")
                    </div>
                }
                <div class="timer">
                    <div class="time-segment">
                        <div class="time-num" id="hours">--</div>
                        <div class="time-label">GIỜ</div>
                    </div>
                    <div class="time-segment">
                        <div class="time-num" id="minutes">--</div>
                        <div class="time-label">PHÚT</div>
                    </div>
                    <div class="time-segment">
                        <div class="time-num" id="seconds">--</div>
                        <div class="time-label">GIÂY</div>
                    </div>
                </div>
                <div class="countdown-sub">
                    @if (nextEvent != null)
                    {
                        <text>Sự kiện sale mới sẽ tự động mở khi đếm ngược về 0</text>
                    }
                    else if (currentEvent != null)
                    {
                        @($"Ưu đãi {currentEvent.Title} đang áp dụng — chốt đơn ngay!")
                    }
                    else
                    {
                        <text>Chốt đơn ngay để không bỏ lỡ ưu đãi sốc</text>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- 2 BANNER COMBO - click scroll tới section -->
    <section class="ads-combo-section">
        <a href="#donggia-section" class="banner-adv adv-1" id="bannerDongGia">
            <div class="banner-mini-badge">⚡ HOT TODAY</div>
            <div>
                <h3>Đồng giá<br />99K - 199K</h3>
                <p>Hơn 200 sản phẩm chất lượng cao đồng giá siêu hời</p>
            </div>
            <button class="adv-btn">Xem ngay <i class="ti ti-arrow-down"></i></button>
            <i class="ti ti-tag adv-icon-bg"></i>
        </a>

        <a href="#combo-section" class="banner-adv adv-2" id="bannerCombo">
            <div class="banner-mini-badge" style="background: rgba(230,57,70,0.3); border-color: #e63946;">🎁 COMBO DEAL</div>
            <div>
                <h3>Mua 2 Tặng 1<br />Combo Đại Hạ Giá</h3>
                <p>Áp dụng cho 50+ bộ sưu tập đặc biệt</p>
            </div>
            <button class="adv-btn">Khám phá combo <i class="ti ti-arrow-down"></i></button>
            <i class="ti ti-shirt adv-icon-bg"></i>
        </a>
    </section>

    <!-- LUCKY WHEEL -->
    <section class="lucky-zone">
        <div class="wheel-container">
            <div class="wheel-pointer"></div>
            <div class="wheel" id="wheel">
                <div class="wheel-segment dark-bg" style="transform: rotate(0deg);">150K</div>
                <div class="wheel-segment" style="transform: rotate(60deg);">FREESHIP</div>
                <div class="wheel-segment dark-bg" style="transform: rotate(120deg);">50K</div>
                <div class="wheel-segment" style="transform: rotate(180deg);">VOUCHER</div>
                <div class="wheel-segment dark-bg" style="transform: rotate(240deg);">100K</div>
                <div class="wheel-segment" style="transform: rotate(300deg);">10%</div>
            </div>
            <button class="wheel-center-btn" id="spinBtn">QUAY!</button>
        </div>

        <div class="wheel-side">
            <h2><i class="ti ti-confetti"></i>Vòng Quay May Mắn</h2>
            <p>Quay 1 lần miễn phí mỗi ngày, có cơ hội nhận voucher giảm giá lên đến 150.000₫ vào tài khoản của bạn.</p>
            <div class="wheel-perks">
                <div class="wheel-perk"><i class="ti ti-coin"></i>Voucher tiền mặt 50K - 150K</div>
                <div class="wheel-perk"><i class="ti ti-truck-delivery"></i>Mã miễn phí vận chuyển</div>
                <div class="wheel-perk"><i class="ti ti-percentage"></i>Giảm 10% toàn bộ đơn hàng</div>
                <div class="wheel-perk"><i class="ti ti-gift"></i>Quà tặng bí ẩn từ MONO.WEAR</div>
            </div>
            <div class="wheel-result empty" id="wheelResult">
                Nhấn nút QUAY ở giữa để bắt đầu — chúc bạn may mắn!
            </div>
        </div>
    </section>

    <!-- VOUCHERS -->
    <section class="vouchers-section">
        <div class="section-title">
            <i class="ti ti-ticket"></i>Kho Voucher Hot — Sưu Tầm Ngay
            <span class="badge-soon">SẮP HẾT</span>
        </div>
        <div class="voucher-grid">
            @{
                var saleVouchers = ViewBag.ActiveVouchers as List<ThoiTrang.Models.Entities.Voucher>;
                var savedVIds = (ViewBag.SavedVoucherIds as List<int>) ?? new List<int>();
            }
            @if (saleVouchers != null && saleVouchers.Count > 0)
            {
                foreach (var v in saleVouchers)
                {
                    var saved = savedVIds.Contains(v.VoucherId);
                    var vbig = v.DiscountType == "percent" ? $"{v.DiscountValue:#,##0}%" : (v.DiscountValue >= 1000 ? $"{v.DiscountValue / 1000:#,##0}K" : $"{v.DiscountValue:#,##0}");
                    <div class="voucher-card">
                        <div class="v-left">
                            <div class="v-icon"><i class="ti ti-discount-2"></i></div>
                            <div class="value">@vbig</div>
                            <div class="unit">@(v.DiscountType == "percent" ? "GIẢM %" : "GIẢM GIÁ")</div>
                        </div>
                        <div class="v-right">
                            <div>
                                <div class="v-title">@v.Code</div>
                                <div class="v-desc">@(v.Description ?? $"Đơn từ {v.MinOrder:#,##0}₫")@(v.EndDate.HasValue ? " · HSD " + v.EndDate.Value.ToString("dd/MM") : "")</div>
                                <div class="v-bar"><div class="v-bar-fill" style="width: 60%;"></div></div>
                                <div class="v-bar-text">Còn @v.Quantity lượt</div>
                            </div>
                            <button class="v-copy-btn" data-vid="@v.VoucherId" onclick="saveSaleVoucher(@v.VoucherId, this)">
