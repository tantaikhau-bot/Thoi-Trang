@model List<ThoiTrang.Models.Entities.Product>
@{
    ViewData["Title"] = "Siêu Sale Bùng Nổ";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MONO.WEAR - Đại Tiệc Sale Lớn Nhất Năm</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@2.47.0/tabler-icons.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            overflow-x: clip; /* Chặn tuyệt đối việc tràn viền ngang */
            position: relative;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            color: #1a1a1a;
            background: #f5f5f3;
            line-height: 1.5;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button {
            font-family: inherit;
            cursor: pointer;
        }

        img {
            max-width: 100%;
            display: block;
        }

        /* ============ ANIMATIONS ============ */
        @@keyframes shimmer {
            0% {
                background-position: -200% 0;
            }

            100% {
                background-position: 200% 0;
            }
        }

        @@keyframes pulseNeon {
            0%, 100% {
                box-shadow: 0 0 5px #e63946, 0 0 12px rgba(230,57,70,0.5);
            }

            50% {
                box-shadow: 0 0 18px #ff758c, 0 0 30px rgba(255,117,140,0.7);
            }
        }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-8px);
            }
        }

        @@keyframes marquee {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        @@keyframes confettiFall {
            0% {
                transform: translateY(-10px) rotate(0deg);
                opacity: 1;
            }

            100% {
                transform: translateY(100vh) rotate(720deg);
                opacity: 0;
            }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes ring {
            0%, 100% {
                transform: rotate(0);
            }

            10%, 30% {
                transform: rotate(-15deg);
            }

            20%, 40% {
                transform: rotate(15deg);
            }

            50% {
                transform: rotate(0);
            }
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.08);
            }
        }

        @@keyframes pulseRing {
            0% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(230,57,70,0.7);
            }

            70% {
                transform: scale(1);
                box-shadow: 0 0 0 12px rgba(230,57,70,0);
            }

            100% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(230,57,70,0);
            }
        }

        @@keyframes wobble {
            0%, 100% {
                transform: rotate(0deg);
            }

            25% {
                transform: rotate(-8deg);
            }

            75% {
                transform: rotate(8deg);
            }
        }

        @@keyframes glow {
            0%, 100% {
                filter: drop-shadow(0 0 4px rgba(255,117,140,0.6));
            }

            50% {
                filter: drop-shadow(0 0 14px rgba(255,117,140,1));
            }
        }

        @@keyframes slideInRightToast {
            from {
                transform: translateX(120%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes slideOutRightToast {
            from {
                transform: translateX(0);
                opacity: 1;
            }

            to {
                transform: translateX(120%);
                opacity: 0;
            }
        }

        @@keyframes heartBeat {
            0%, 100% {
                transform: scale(1);
            }

            25% {
                transform: scale(1.3);
            }

            50% {
                transform: scale(1.1);
            }

            75% {
                transform: scale(1.2);
            }
        }

        @@keyframes highlight {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(230,57,70,0);
            }

            20%, 80% {
                box-shadow: 0 0 0 6px rgba(230,57,70,0.25);
            }

            50% {
                box-shadow: 0 0 0 12px rgba(230,57,70,0.4);
            }
        }

        /* LIVE ADS */
        .live-ads-bar {
            background: #1a1a1a;
            color: #fff;
            padding: 9px 0;
            font-size: 12px;
            overflow: hidden;
            white-space: nowrap;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .marquee-inner {
            display: inline-block;
            padding-left: 100%;
            animation: marquee 30s linear infinite;
        }

            .marquee-inner span {
                margin-right: 60px;
                color: #ff758c;
                font-weight: 600;
            }

                .marquee-inner span i {
                    color: #fff;
                    margin-right: 6px;
                }

        .announce {
            background: linear-gradient(90deg, #e63946, #ff758c, #e63946);
            background-size: 200% auto;
            color: #fff;
            text-align: center;
            padding: 12px 16px;
            font-size: 13px;
            letter-spacing: 1px;
            font-weight: 700;
            animation: shimmer 4s linear infinite;
        }

        /* HEADER */
        .header {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #f0f0f0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 60px;
        }

        .logo {
            font-size: 26px;
            font-weight: 500;
            letter-spacing: 1.5px;
            transition: transform 0.3s;
        }

            .logo:hover {
                transform: scale(1.05);
            }

            .logo span {
                font-weight: 300;
            }

        .search-box {
            flex: 1;
            max-width: 480px;
            margin: 0 60px;
            display: flex;
            align-items: center;
            background: #fff5f5;
            border-radius: 12px;
            padding: 11px 16px;
            border: 1px solid #ffe0e0;
        }

            .search-box i {
                font-size: 18px;
                color: #e63946;
            }

            .search-box input {
                border: none;
                background: transparent;
                outline: none;
                flex: 1;
                margin-left: 10px;
                font-size: 14px;
            }

        .header-icons {
            display: flex;
            align-items: center;
            gap: 24px;
            font-size: 22px;
        }

            .header-icons a {
                position: relative;
                color: #1a1a1a;
                transition: transform 0.3s;
            }

                .header-icons a:hover {
                    transform: translateY(-3px);
                }

        .bell-icon {
            animation: ring 4s ease infinite;
            transform-origin: top center;
        }

        .cart-badge, .notif-badge {
            position: absolute;
            top: -6px;
            right: -8px;
            background: #e63946;
            color: #fff;
            font-size: 10px;
            min-width: 18px;
            height: 18px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            font-family: sans-serif;
            font-weight: 600;
            animation: pulse 2s infinite;
        }

        .nav {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 48px;
            padding: 14px 60px;
            border-top: 1px solid #f5f5f5;
            font-size: 14px;
            letter-spacing: 0.3px;
        }

            .nav a {
                color: #666;
                position: relative;
                padding: 4px 0;
                transition: color 0.3s;
            }

                .nav a.active {
                    color: #e63946;
                    font-weight: 600;
                }

                .nav a::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 50%;
                    width: 0;
                    height: 2px;
                    background: #e63946;
                    transition: all 0.3s;
                    transform: translateX(-50%);
                }

                .nav a.active::after, .nav a:hover::after {
                    width: 100%;
                }

                .nav a:hover {
                    color: #e63946;
                }

            .nav .sale-badge {
                background: #e63946;
                color: #fff;
                font-size: 9px;
                padding: 2px 6px;
                border-radius: 4px;
                margin-left: 4px;
                vertical-align: super;
                animation: pulse 1.5s infinite;
            }

        /* HERO */
        .page-hero {
            background: radial-gradient(circle at top right, #3a0ca3 0%, #111 40%, #e63946 100%);
            color: #fff;
            padding: 70px 60px;
            position: relative;
            overflow: hidden;
        }

            .page-hero::after {
                content: '';
                position: absolute;
                inset: 0;
                background-image: radial-gradient(rgba(255,255,255,0.15) 1px, transparent 0);
                background-size: 24px 24px;
                opacity: 0.4;
                pointer-events: none;
            }

            .page-hero::before {
                content: '';
                position: absolute;
                bottom: -100px;
                left: -100px;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(255,117,140,0.3), transparent 70%);
                filter: blur(40px);
                animation: float 6s ease-in-out infinite;
            }

        .page-hero-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            align-items: center;
            gap: 40px;
            position: relative;
            z-index: 2;
        }

        .hero-tag {
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            padding: 7px 16px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 22px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            border: 1px solid rgba(255,255,255,0.2);
            animation: fadeInUp 0.8s ease;
        }

            .hero-tag .dot {
                width: 7px;
                height: 7px;
                background: #ff758c;
                border-radius: 50%;
                animation: pulseRing 1.5s infinite;
            }

        .page-hero h1 {
            font-size: clamp(38px, 5vw, 58px);
            font-weight: 800;
            letter-spacing: -1.5px;
            margin-bottom: 16px;
            line-height: 1.1;
            text-transform: uppercase;
            animation: fadeInUp 0.8s ease 0.1s both;
        }

            .page-hero h1 span {
                color: #ff758c;
                text-shadow: 0 0 20px rgba(255,117,140,0.6);
                animation: glow 2s ease-in-out infinite;
                display: inline-block;
            }

        .hero-desc {
            font-size: 15px;
            color: rgba(255,255,255,0.75);
            max-width: 480px;
            margin-bottom: 28px;
            line-height: 1.7;
            animation: fadeInUp 0.8s ease 0.2s both;
        }

        .hero-stats {
            display: flex;
            gap: 30px;
            animation: fadeInUp 0.8s ease 0.3s both;
            flex-wrap: wrap;
        }

        .hero-stat-num {
            font-size: 28px;
            font-weight: 700;
            line-height: 1;
            background: linear-gradient(135deg, #fff, #ff758c);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 4px;
        }

        .hero-stat-label {
            font-size: 11px;
            color: rgba(255,255,255,0.6);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* COUNTDOWN */
        .countdown-box {
            background: rgba(0,0,0,0.45);
            backdrop-filter: blur(15px);
            padding: 28px;
            border-radius: 22px;
            border: 1px solid rgba(255,255,255,0.15);
            text-align: center;
            animation: pulseNeon 3s infinite, fadeInUp 0.8s ease 0.4s both;
        }

        .countdown-title {
            font-size: 12px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #ff758c;
            margin-bottom: 16px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

            .countdown-title i {
                font-size: 16px;
            }

        .timer {
            display: flex;
            justify-content: center;
            gap: 12px;
        }

        .time-segment {
            background: #fff;
            color: #1a1a1a;
            min-width: 70px;
            padding: 14px 6px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

        .time-num {
            font-size: 32px;
            font-weight: 800;
            line-height: 1;
            color: #e63946;
        }

        .time-label {
            font-size: 11px;
            color: #666;
            margin-top: 6px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .countdown-sub {
            font-size: 11px;
            color: rgba(255,255,255,0.5);
            margin-top: 14px;
            letter-spacing: 0.5px;
        }

        /* BANNER COMBO */
        .ads-combo-section {
            padding: 40px 60px 24px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 22px;
        }

        .banner-adv {
            position: relative;
            border-radius: 18px;
            padding: 32px;
            color: #fff;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(230,57,70,0.12);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 200px;
            cursor: pointer;
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }

            .banner-adv:hover {
                transform: translateY(-4px);
                box-shadow: 0 20px 40px rgba(230,57,70,0.2);
            }

        .adv-1 {
            background: linear-gradient(135deg, #ff416c, #ff4b2b);
        }

        .adv-2 {
            background: linear-gradient(135deg, #111111, #434343);
            border: 2px solid #e63946;
        }

        .banner-adv h3 {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 8px;
            line-height: 1.2;
            position: relative;
            z-index: 2;
        }

        .banner-adv p {
            font-size: 14px;
            opacity: 0.9;
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }

        .adv-btn {
            background: #fff;
            color: #1a1a1a;
            padding: 10px 22px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            width: fit-content;
            transition: all 0.3s;
            position: relative;
            z-index: 2;
            border: none;
            cursor: pointer;
        }

        .adv-2 .adv-btn {
            background: #e63946;
            color: #fff;
        }

        .banner-adv:hover .adv-btn {
            transform: scale(1.05);
        }

        .adv-icon-bg {
            position: absolute;
            right: -10px;
            bottom: -10px;
            font-size: 160px;
            opacity: 0.15;
            transform: rotate(-15deg);
            pointer-events: none;
        }

        .banner-mini-badge {
            position: absolute;
            top: 16px;
            right: 16px;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(6px);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            border: 1px solid rgba(255,255,255,0.25);
        }

        /* HIGHLIGHT (khi scroll tới) */
        .highlight-flash {
            animation: highlight 1.6s ease;
        }

        /* LUCKY WHEEL */
        .lucky-zone {
            padding: 36px;
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 36px;
            background: #fff;
            border-radius: 24px;
            margin: 0 60px 24px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.04);
            align-items: center;
        }

        .wheel-side h2 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .wheel-side h2 i {
                color: #e63946;
                font-size: 28px;
                animation: wobble 3s ease-in-out infinite;
            }

        .wheel-side p {
            font-size: 14px;
            color: #666;
            margin-bottom: 18px;
            line-height: 1.7;
        }

        .wheel-perks {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 18px;
        }

        .wheel-perk {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: #555;
        }

            .wheel-perk i {
                width: 28px;
                height: 28px;
                background: #fff5f5;
                color: #e63946;
                border-radius: 8px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 15px;
                flex-shrink: 0;
            }

        .wheel-result {
            font-size: 14px;
            color: #1a1a1a;
            font-weight: 500;
            padding: 12px 14px;
            background: linear-gradient(135deg, #fff5f5, #ffe0e8);
            border-radius: 10px;
            min-height: 44px;
            display: flex;
            align-items: center;
            border: 1px dashed #e63946;
        }

            .wheel-result.empty {
                color: #999;
                font-weight: 400;
            }

        .wheel-container {
            position: relative;
            width: 280px;
            height: 280px;
            margin: 0 auto;
        }

        .wheel {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 8px solid #1a1a1a;
            position: relative;
            overflow: hidden;
            transition: transform 4s cubic-bezier(0.15, 0.85, 0.35, 1);
            box-shadow: 0 0 25px rgba(0,0,0,0.18), inset 0 0 30px rgba(0,0,0,0.1);
            background: conic-gradient( #e63946 0deg 60deg, #ffd6dc 60deg 120deg, #ff758c 120deg 180deg, #ffd6dc 180deg 240deg, #1a1a1a 240deg 300deg, #ffd6dc 300deg 360deg );
        }

        .wheel-segment {
            position: absolute;
            top: 0;
            left: 50%;
            width: 50%;
            height: 50%;
            transform-origin: 0% 100%;
            font-size: 11px;
            font-weight: 700;
            color: #1a1a1a;
            padding-top: 24px;
            text-align: center;
            letter-spacing: 0.5px;
        }

            .wheel-segment.dark-bg {
                color: #fff;
            }

        .wheel-pointer {
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 14px solid transparent;
            border-right: 14px solid transparent;
            border-top: 28px solid #1a1a1a;
            z-index: 10;
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
        }

        .wheel-center-btn {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #e63946, #ff758c);
            border-radius: 50%;
            border: 4px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: 13px;
            z-index: 11;
            cursor: pointer;
            box-shadow: 0 6px 16px rgba(230,57,70,0.4);
            transition: all 0.3s;
        }

            .wheel-center-btn:hover {
                transform: translate(-50%, -50%) scale(1.08);
                box-shadow: 0 8px 22px rgba(230,57,70,0.6);
            }

            .wheel-center-btn:disabled {
                cursor: not-allowed;
                opacity: 0.7;
            }

        /* VOUCHERS */
        .vouchers-section {
            padding: 16px 60px 24px;
            scroll-margin-top: 130px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .section-title i {
                color: #e63946;
                font-size: 26px;
            }

            .section-title .badge-soon {
                background: #e63946;
                color: #fff;
                font-size: 10px;
                padding: 3px 10px;
                border-radius: 999px;
                letter-spacing: 1px;
                margin-left: auto;
                animation: pulse 1.8s infinite;
            }

        .voucher-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
        }

        .voucher-card {
            background: #fff;
            border: 1px solid #ffccd5;
            border-radius: 14px;
            display: flex;
            align-items: stretch;
            overflow: hidden;
            position: relative;
            box-shadow: 0 6px 18px rgba(230,57,70,0.04);
            transition: all 0.3s;
        }

            .voucher-card::before, .voucher-card::after {
                content: '';
                position: absolute;
                width: 16px;
                height: 16px;
                background: #fff5f5;
                border-radius: 50%;
                left: 110px;
                transform: translateX(-50%);
            }

            .voucher-card::before {
                top: -8px;
            }

            .voucher-card::after {
                bottom: -8px;
            }

            .voucher-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 28px rgba(230,57,70,0.12);
            }

        .v-left {
            background: linear-gradient(135deg, #e63946, #ff758c);
            color: #fff;
            padding: 22px 18px;
            text-align: center;
            min-width: 110px;
            max-width: 110px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-right: 2px dashed rgba(255,255,255,0.4);
        }

            .v-left .value {
                font-size: 24px;
                font-weight: 800;
                line-height: 1;
            }

            .v-left .unit {
                font-size: 10px;
                opacity: 0.95;
                text-transform: uppercase;
                font-weight: 600;
                margin-top: 4px;
                letter-spacing: 0.5px;
            }

            .v-left .v-icon {
                font-size: 20px;
                margin-bottom: 6px;
            }

        .v-right {
            padding: 16px 18px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 8px;
