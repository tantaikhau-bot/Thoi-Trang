    <script>
        // ===== Banner click - scroll tới section + highlight =====
        document.getElementById('bannerDongGia').addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.getElementById('donggia-section');
            target.scrollIntoView({ behavior: 'smooth' });
            // Highlight section title sau khi scroll
            setTimeout(() => {
                const title = target.querySelector('.section-title');
                title.classList.add('highlight-flash');
                setTimeout(() => title.classList.remove('highlight-flash'), 1800);
            }, 600);
            showToast('info', 'Chuyển đến Đồng giá 99K', 'Tham khảo hơn 200 sản phẩm đồng giá siêu hời');
        });

        document.getElementById('bannerCombo').addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.getElementById('combo-section');
            target.scrollIntoView({ behavior: 'smooth' });
            setTimeout(() => {
                const title = target.querySelector('.section-title');
                title.classList.add('highlight-flash');
                setTimeout(() => title.classList.remove('highlight-flash'), 1800);
            }, 600);
            showToast('info', 'Chuyển đến Combo Mua 2 Tặng 1', 'Khám phá 50+ combo siêu hời');
        });

        // ===== Countdown đếm tới sự kiện sale đã lên lịch =====
        function startTimer() {
            const box = document.getElementById('countdownBox');
            const target = box ? box.dataset.target : '';
            const setAll = (hh, mm, ss) => {
                ['hours','minutes','seconds'].forEach((id, i) => {
                    const el = document.getElementById(id); if (el) el.textContent = [hh,mm,ss][i];
                });
                [['miniHours',hh],['miniMinutes',mm],['miniSeconds',ss]].forEach(([id,v]) => {
                    const el = document.getElementById(id); if (el) el.textContent = v;
                });
            };
            const pad = n => (n < 10 ? '0' + n : '' + n);

            if (target) {
                // Đếm ngược tới EventDate của sự kiện sale kế tiếp
                const targetTime = new Date(target).getTime();
                const tick = () => {
                    let diff = Math.floor((targetTime - Date.now()) / 1000);
                    if (diff <= 0) {
                        setAll('00','00','00');
                        showToast('success', 'Sự kiện sale mới bắt đầu! 🎉', 'Đang tải ưu đãi mới...');
                        setTimeout(() => location.reload(), 1500);
                        return false;
                    }
                    const h = Math.floor(diff / 3600);
                    const m = Math.floor((diff % 3600) / 60);
                    const s = diff % 60;
                    setAll(pad(h), pad(m), pad(s));
                    return true;
                };
                if (tick()) {
                    const iv = setInterval(() => { if (!tick()) clearInterval(iv); }, 1000);
                }
            } else {
                // Không có sự kiện sắp tới — đồng hồ ưu đãi thường (24h lặp)
                let s = 40, m = 19, h = 8;
                setInterval(() => {
                    s--; if (s < 0) { s = 59; m--; } if (m < 0) { m = 59; h--; } if (h < 0) { h = 23; }
                    setAll(pad(h), pad(m), pad(s));
                }, 1000);
            }
        }
        startTimer();

        // ===== Lucky Wheel =====
        const wheel = document.getElementById('wheel');
        const spinBtn = document.getElementById('spinBtn');
        const wheelResult = document.getElementById('wheelResult');
        let hasSpun = false;

        spinBtn.addEventListener('click', () => {
            if (hasSpun) {
                showToast('warning', 'Hết lượt', 'Bạn đã quay hết lượt hôm nay. Quay lại vào ngày mai nhé!');
                return;
            }
            spinBtn.disabled = true;
            spinBtn.textContent = '...';

            // Gọi server: mỗi tài khoản 1 lần/ngày
            fetch('/Home/SpinWheel', { method: 'POST' })
                .then(r => {
                    if (r.status === 401) { showToast('warning', 'Cần đăng nhập', 'Đăng nhập để quay thưởng'); setTimeout(() => location.href = '/Home/DangNhap', 800); return null; }
                    return r.ok ? r.json() : Promise.reject(r);
                })
                .then(d => {
                    if (!d) { spinBtn.disabled = false; spinBtn.textContent = 'QUAY'; return; }
                    if (!d.success) {
                        spinBtn.disabled = false; spinBtn.textContent = 'QUAY';
                        showToast('warning', 'Không thể quay', d.message || 'Hôm nay bạn đã quay rồi');
                        return;
                    }
                    hasSpun = true;
                    const totalDeg = 360 * 5 + Math.floor(Math.random() * 360);
                    wheel.style.transform = `rotate(${totalDeg}deg)`;
                    setTimeout(() => {
                        wheelResult.classList.remove('empty');
                        wheelResult.innerHTML = `🎉 Chúc mừng! Bạn trúng mã <strong style="color:#e63946;">${d.code}</strong> giảm ${d.value}!`;
                        showToast('success', 'Trúng thưởng!', `Mã ${d.code} đã lưu vào kho voucher của bạn.`);
                        triggerConfetti();
                        spinBtn.textContent = 'XONG';
                    }, 4000);
                })
                .catch(() => { spinBtn.disabled = false; spinBtn.textContent = 'QUAY'; showToast('error', 'Lỗi', 'Thử lại sau'); });
        });

        // ===== Săn voucher (lưu vào tài khoản) =====
        function saveSaleVoucher(voucherId, btn) {
            const fd = new FormData(); fd.append('voucherId', voucherId);
            fetch('/Home/SaveUserVoucher', { method: 'POST', body: fd })
                .then(r => { if (r.status === 401) { showToast('warning', 'Cần đăng nhập', 'Đăng nhập để săn voucher'); setTimeout(() => location.href = '/Home/DangNhap', 800); return null; } return r.ok ? r.json() : Promise.reject(r); })
                .then(d => {
                    if (!d) return;
                    btn.innerHTML = '<i class="ti ti-check"></i>Đã lưu';
                    if (d.success) { showToast('success', 'Săn voucher thành công', 'Voucher đã vào kho của bạn'); triggerConfetti(); }
                    else showToast('info', 'Đã lưu trước đó', d.message || 'Bạn đã có voucher này');
                })
                .catch(() => showToast('error', 'Lỗi', 'Không lưu được voucher'));
        }

        // ===== Confetti =====
        function triggerConfetti() {
            const colors = ['#e63946', '#ff758c', '#ffccd5', '#1a1a1a', '#f0b400'];
            for (let i = 0; i < 50; i++) {
                const c = document.createElement('div');
                c.style.position = 'fixed';
                c.style.width = (Math.random() * 8 + 6) + 'px';
                c.style.height = (Math.random() * 8 + 6) + 'px';
                c.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                c.style.left = Math.random() * 100 + 'vw';
                c.style.top = '-20px';
                c.style.zIndex = '9999';
                c.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                c.style.pointerEvents = 'none';
                c.style.animation = `confettiFall ${Math.random() * 2 + 1.5}s linear forwards`;
                document.body.appendChild(c);
                setTimeout(() => c.remove(), 3500);
            }
        }

        // ===== Copy voucher =====
        function copyVoucher(btn, code) {
            const doCopy = () => {
                btn.classList.add('copied');
                btn.innerHTML = '<i class="ti ti-check"></i>Đã lưu';
                showToast('success', 'Lưu mã thành công', `Bạn đã copy mã ${code}. Dùng ngay khi thanh toán!`);
                triggerConfetti();
                setTimeout(() => {
                    btn.classList.remove('copied');
                    btn.innerHTML = '<i class="ti ti-copy"></i>Lưu mã';
                }, 2500);
            };
            if (navigator.clipboard) {
                navigator.clipboard.writeText(code).then(doCopy).catch(doCopy);
            } else {
                doCopy();
            }
        }

        // ===== Tabs tầm giá (lọc sản phẩm thật) =====
        document.querySelectorAll('.donggia-tab').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.donggia-tab').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const pg = btn.dataset.pg;
                let shown = 0;
                document.querySelectorAll('#priceGrid .dg-card').forEach(card => {
                    const ok = card.dataset.pg === pg;
                    card.style.display = ok ? '' : 'none';
                    if (ok) shown++;
                });
                const empty = document.getElementById('priceEmpty');
                if (empty) empty.style.display = shown === 0 ? 'block' : 'none';
            });
        });

        // ===== Thêm nhanh sản phẩm vào giỏ (theo productId) =====
        function quickAddProduct(productId, btn) {
            const fd = new FormData(); fd.append('productId', productId);
            fetch('/Home/AddProductToCart', { method: 'POST', body: fd })
                .then(async r => {
                    if (r.status === 401) { showToast('warning', 'Cần đăng nhập', 'Vui lòng đăng nhập để mua hàng'); setTimeout(() => window.location.href = '/Home/DangNhap', 1000); return null; }
                    if (!r.ok) { const e = await r.json().catch(()=>({})); throw new Error(e.message || 'Không thêm được'); }
                    return r.json();
                })
                .then(d => {
                    if (!d) return;
                    const badge = document.getElementById('headerCartBadge');
                    if (badge) { badge.textContent = d.count; }
                    btn.innerHTML = '<i class="ti ti-check"></i>';
                    setTimeout(() => btn.innerHTML = '<i class="ti ti-plus"></i>', 1200);
                    showToast('success', 'Đã thêm vào giỏ', 'Sản phẩm đã vào giỏ hàng');
                })
                .catch(err => showToast('warning', 'Không thêm được', err.message || 'Thử lại sau'));
        }

        // ===== Add to cart =====
        function addToCart(btn, name) {
            // Combo = nhiều món; deal lẻ = 1 món
            const isCombo = (name || '').toLowerCase().indexOf('combo') === 0;
            const count = isCombo ? 3 : 1;
            const fd = new FormData(); fd.append('count', count);
            fetch('/Home/AddComboToCart', { method: 'POST', body: fd })
                .then(r => {
                    if (r.status === 401) { showToast('warning', 'Cần đăng nhập', 'Vui lòng đăng nhập để mua hàng'); setTimeout(() => window.location.href = '/Home/DangNhap', 900); return null; }
                    return r.ok ? r.json() : Promise.reject(r);
                })
                .then(d => {
                    if (!d) return;
                    const badge = document.getElementById('headerCartBadge');
                    if (badge) { badge.textContent = d.count; badge.style.animation = 'none'; void badge.offsetWidth; badge.style.animation = 'heartBeat 0.6s ease, pulse 2s infinite 0.6s'; }
                    showToast('success', 'Đã thêm vào giỏ', `${name} đã vào giỏ hàng của bạn.`);
                })
                .catch(() => showToast('error', 'Lỗi', 'Không thể thêm vào giỏ'));
        }

        // ===== Mua combo thật (theo comboId) =====
        function buyCombo(btn, comboId) {
            const fd = new FormData(); fd.append('comboId', comboId);
            btn.disabled = true;
            fetch('/Home/AddComboToCart', { method: 'POST', body: fd })
                .then(async r => {
                    if (r.status === 401) { showToast('warning', 'Cần đăng nhập', 'Vui lòng đăng nhập để mua hàng'); setTimeout(() => window.location.href = '/Home/DangNhap', 1000); return null; }
                    if (!r.ok) { const e = await r.json().catch(()=>({})); throw new Error(e.message || 'Không thêm được combo'); }
                    return r.json();
                })
                .then(d => {
                    btn.disabled = false;
                    if (!d) return;
                    const badge = document.getElementById('headerCartBadge');
                    if (badge) { badge.textContent = d.count; badge.style.animation = 'none'; void badge.offsetWidth; badge.style.animation = 'heartBeat 0.6s ease, pulse 2s infinite 0.6s'; }
                    showToast('success', 'Đã thêm combo', `${d.added} sản phẩm trong combo đã vào giỏ hàng.`);
                })
                .catch(err => { btn.disabled = false; showToast('warning', 'Không thêm được', err.message || 'Thử lại sau'); });
        }

        // ===== Toggle heart =====
        function toggleHeart(e, btn) {
            e.stopPropagation();
            btn.classList.toggle('active');
            const icon = btn.querySelector('i');
            if (btn.classList.contains('active')) {
                icon.classList.remove('ti-heart');
                icon.classList.add('ti-heart-filled');
                showToast('success', 'Đã yêu thích', 'Sản phẩm đã được lưu vào danh sách');
            } else {
                icon.classList.remove('ti-heart-filled');
                icon.classList.add('ti-heart');
            }
        }

        // ===== Clear filters =====
        function clearFilters() {
            document.querySelectorAll('.filter-check input').forEach(cb => cb.checked = false);
            showToast('info', 'Đã đặt lại', 'Tất cả bộ lọc đã được xóa');
        }

        // ===== Scroll top =====
        const scrollTopBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 400) scrollTopBtn.classList.add('show');
            else scrollTopBtn.classList.remove('show');
        });
        scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // ===== Toast =====
        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type || ''}`;
            const icons = {
                success: 'ti-circle-check',
                info: 'ti-info-circle',
                warning: 'ti-alert-circle'
            };
            toast.innerHTML = `
                <div class="toast-icon-wrap"><i class="ti ${icons[type] || 'ti-gift'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            }, 3500);
        }
    </script>

    <script src="~/js/filter.js" asp-append-version="true"></script>

    <script src="/js/search.js"></script>
    @await Html.PartialAsync("_ChatWidget")
</body>
</html>
