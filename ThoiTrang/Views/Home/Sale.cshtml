    <section class="combo-section" id="combo-section">
        <div class="section-title">
            <i class="ti ti-gift"></i>Combo Mua 2 Tặng 1 — Deal Hời Mỗi Ngày
            <span class="badge-soon">DEAL HOT</span>
        </div>
        <div class="combo-grid">
            @{
                var combos = ViewBag.Combos as List<ThoiTrang.Models.Entities.Combo> ?? new List<ThoiTrang.Models.Entities.Combo>();
                string[] comboBgs = { "bg-cream", "bg-dark dark", "bg-blue dark", "bg-gray", "bg-brown dark" };
                string ComboIcon(string? name) {
                    var n = (name ?? "").ToLower();
                    if (n.Contains("giày") || n.Contains("sneaker")) return "ti-shoe";
                    if (n.Contains("quần") || n.Contains("jean") || n.Contains("kaki") || n.Contains("váy") || n.Contains("đầm")) return "ti-hanger";
                    if (n.Contains("túi")) return "ti-shopping-bag";
                    if (n.Contains("hoodie") || n.Contains("khoác") || n.Contains("bomber")) return "ti-shirt-sport";
                    return "ti-shirt";
                }
            }
            @foreach (var cb in combos)
            {
                var oldP = cb.OldPrice > 0 ? cb.OldPrice : cb.Items.Sum(i => (i.Product?.Price ?? 0) * i.Quantity);
                int savePct = oldP > 0 ? (int)Math.Round((1 - (double)(cb.ComboPrice / oldP)) * 100) : 0;
                var ribbonCls = cb.Badge == "fire" ? "combo-ribbon fire" : "combo-ribbon";
                var ribbonIc = cb.Badge == "fire" ? "ti-flame" : "ti-gift";
                var ribbonTxt = cb.Badge == "fire" ? "BÁN CHẠY" : (cb.Badge == "new" ? "COMBO MỚI" : "ƯU ĐÃI");
                var itemsList = cb.Items.ToList();
                <div class="combo-card">
                    <div class="@ribbonCls"><i class="ti @ribbonIc"></i>@ribbonTxt</div>
                    <div class="combo-images">
                        @for (int ii = 0; ii < itemsList.Count; ii++)
                        {
                            var it = itemsList[ii];
                            <div class="combo-img @comboBgs[ii % 5]">
                                <i class="ti @ComboIcon(it.Product?.Name)"></i>
                                @if (ii < itemsList.Count - 1)
                                {
                                    <div class="combo-plus">+</div>
                                }
                            </div>
                        }
                    </div>
                    <div class="combo-info">
                        <div class="combo-title">@cb.Name</div>
                        <div class="combo-meta">
                            @foreach (var it in itemsList)
                            {
                                <span class="combo-meta-tag">@it.Product?.Name</span>
                            }
                        </div>
                        <div class="combo-price-row">
                            <span class="combo-price-current">@cb.ComboPrice.ToString("#,##0")₫</span>
                            <span class="combo-price-old">@oldP.ToString("#,##0")₫</span>
                            @if (savePct > 0)
                            {
                                <span class="combo-saving">-@savePct%</span>
                            }
                        </div>
                        <button class="combo-btn" onclick="buyCombo(this, @cb.ComboId)">
                            <i class="ti ti-shopping-bag-plus"></i>Mua combo
                        </button>
                    </div>
                </div>
            }
            @if (combos.Count == 0)
