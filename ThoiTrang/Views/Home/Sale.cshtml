                string[] dgBgs = { "bg-cream", "bg-dark dark", "bg-gray", "bg-blue dark", "bg-brown dark" };
                string DgIcon(string? name) {
                    var n = (name ?? "").ToLower();
                    if (n.Contains("giày") || n.Contains("sneaker")) return "ti-shoe";
                    if (n.Contains("quần") || n.Contains("jean") || n.Contains("kaki") || n.Contains("váy") || n.Contains("đầm")) return "ti-hanger";
                    if (n.Contains("túi")) return "ti-shopping-bag";
                    if (n.Contains("kính")) return "ti-sunglasses";
                    if (n.Contains("mũ") || n.Contains("nón")) return "ti-hat";
                    return "ti-shirt";
                }
                int dgIdx = 0;
            }
            @foreach (var pp in priceProds)
            {
                int pg = pp.Price < 400000 ? 1 : (pp.Price <= 700000 ? 2 : 3);
                var firstVariant = pp.Variants?.FirstOrDefault(v => v.Stock > 0) ?? pp.Variants?.FirstOrDefault();
                <div class="dg-card" data-pg="@pg" style="@(pg == 1 ? "" : "display:none;")">
                    <div class="dg-img @dgBgs[dgIdx % 5]" style="cursor:pointer;" onclick="location.href='/Home/CTSP/@pp.ProductId'">
                        <span class="dg-fixed-price@(dgIdx % 2 == 1 ? " red" : "")">@((pp.Price/1000).ToString("#,##0"))K</span>
                        <i class="ti @DgIcon(pp.Name)"></i>
                    </div>
                    <div class="dg-info">
                        <div class="dg-cat">@(pp.Category?.Name?.ToUpper())</div>
                        <div class="dg-name">@pp.Name</div>
                        <div class="dg-bottom">
                            <span class="dg-sold">Đã bán @pp.SoldCount</span>
                            <button class="dg-add" onclick="quickAddProduct(@pp.ProductId, this)" title="Thêm vào giỏ"><i class="ti ti-plus"></i></button>
                        </div>
                    </div>
                </div>
                dgIdx++;
            }
