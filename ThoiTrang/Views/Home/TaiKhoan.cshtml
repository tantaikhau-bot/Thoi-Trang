            <!-- PANEL: THÔNG BÁO -->
            <div class="panel" data-panel="notifications">
                @{
                    var notifs = ViewBag.Notifications as List<ThoiTrang.Models.Entities.Notification> ?? new List<ThoiTrang.Models.Entities.Notification>();
                    int unreadNotif = ViewBag.UnreadNotifCount ?? 0;
                    string NotifAgo(DateTime t)
                    {
                        var sp = DateTime.Now - t;
                        if (sp.TotalMinutes < 1) return "Vừa xong";
                        if (sp.TotalMinutes < 60) return $"{(int)sp.TotalMinutes} phút trước";
                        if (sp.TotalHours < 24) return $"{(int)sp.TotalHours} giờ trước";
                        if (sp.TotalDays < 30) return $"{(int)sp.TotalDays} ngày trước";
                        return t.ToString("dd/MM/yyyy");
                    }
                    (string, string) NotifIcon(string? type) => type switch
                    {
                        "order" => ("order", "ti-circle-check"),
                        "promo" => ("promo", "ti-gift"),
                        "system" => ("system", "ti-shield-check"),
                        _ => ("system", "ti-bell")
                    };
                }
                <div class="panel-header">
                    <div>
                        <div class="panel-title"><i class="ti ti-bell"></i>Thông báo</div>
                        <div class="panel-sub">@(unreadNotif > 0 ? $"Bạn có {unreadNotif} thông báo chưa đọc" : "Bạn đã đọc hết thông báo")</div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i class="ti ti-inbox"></i>Tất cả thông báo</div>
                        @if (unreadNotif > 0)
                        {
                            <a class="card-link" onclick="markAllNotifRead(this)">Đánh dấu đã đọc</a>
                        }
                    </div>
                    <div class="notif-list">
                        @if (notifs.Count > 0)
                        {
                            foreach (var n in notifs)
                            {
                                var (ncls, nic) = NotifIcon(n.Type);
                                <div class="notif-row @(n.IsRead ? "" : "unread")">
                                    <div class="notif-icon @ncls"><i class="ti @nic"></i></div>
                                    <div class="notif-content">
                                        <div class="notif-title">@n.Title</div>
                                        <div class="notif-desc">@n.Content</div>
                                        <div class="notif-time">@NotifAgo(n.CreatedAt)</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="padding:40px;text-align:center;color:#999;">
                                <i class="ti ti-bell-off" style="font-size:42px;color:#ccc;"></i>
                                <div style="margin-top:10px;">Chưa có thông báo nào</div>
                            </div>
                        }
                    </div>
                </div>
                <script>
                    async function markAllNotifRead(link) {
                        const r = await fetch('/Home/MarkNotificationsRead', { method:'POST' });
                        if (r.ok) {
                            document.querySelectorAll('.notif-row.unread').forEach(el => el.classList.remove('unread'));
                            if (link) link.style.display = 'none';
                            document.querySelector('[data-panel="notifications"] .panel-sub').textContent = 'Bạn đã đọc hết thông báo';
                            showToast('success','Đã đánh dấu','Tất cả thông báo đã được đánh dấu đã đọc');
                            if (typeof monoUpdateBadges === 'function') monoUpdateBadges();
                        } else showToast('error','Lỗi','Thử lại sau');
                    }
                </script>
            </div>

