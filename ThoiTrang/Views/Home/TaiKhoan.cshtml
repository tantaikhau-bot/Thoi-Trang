                            <div style="font-weight:600;margin-bottom:12px;">Thêm phương thức thanh toán</div>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                                <select id="pm-type" style="padding:10px 12px;border:1px solid #e0e0db;border-radius:8px;">
