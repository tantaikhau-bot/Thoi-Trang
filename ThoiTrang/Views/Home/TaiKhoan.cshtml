                <script>
                    function savePay() {
                        const fd = new FormData();
                        fd.append('type', document.getElementById('pm-type').value);
                        fd.append('label', document.getElementById('pm-label').value);
                        fd.append('detail', document.getElementById('pm-detail').value);
                        fd.append('isDefault', document.getElementById('pm-default').checked);
                        fetch('/Home/AddPaymentMethod', { method: 'POST', body: fd })
                            .then(r => r.ok ? r.json() : Promise.reject(r))
                            .then(() => { showToast('success', 'Đã thêm', 'Phương thức thanh toán đã lưu'); setTimeout(() => location.reload(), 700); })
                            .catch(() => showToast('error', 'Lỗi', 'Vui lòng nhập tên phương thức'));
                    }
                    function setDefaultPay(id) { const fd = new FormData(); fd.append('paymentMethodId', id); fetch('/Home/SetDefaultPaymentMethod', { method: 'POST', body: fd }).then(() => location.reload()); }
                    function deletePay(id, btn) { if (!confirm('Xóa phương thức này?')) return; const fd = new FormData(); fd.append('paymentMethodId', id); fetch('/Home/DeletePaymentMethod', { method: 'POST', body: fd }).then(() => btn.closest('.payment-card').remove()); }
                    function removeWish(productId, btn) {
                        const fd = new FormData(); fd.append('productId', productId);
                        fetch('/Home/ToggleWishlist', { method: 'POST', body: fd })
                            .then(r => r.ok ? r.json() : Promise.reject(r))
                            .then(d => { if (!d.added) { btn.closest('.wish-item').remove(); showToast('info', 'Đã bỏ yêu thích', ''); } })
                            .catch(() => {});
                    }
                </script>
