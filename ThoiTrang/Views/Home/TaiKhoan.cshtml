    <script>
        let currentOrderId = null;
        async function viewOrderDetail(orderId) {
            currentOrderId = orderId;
            const modal = document.getElementById('orderDetailModal');
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            document.getElementById('odCancelWrap').style.display = 'none';
            // Reset
            ['odCode','odStatus','odDate','odName','odPhone','odAddr','odNote','odSubtotal','odVoucherDiscount','odShipping','odTotal'].forEach(id => document.getElementById(id).textContent = '...');
            document.getElementById('odItems').innerHTML = '<div style="padding:16px;text-align:center;color:#bbb;">Đang tải...</div>';

            try {
                const r = await fetch(`/Home/GetOrderDetail?orderId=${orderId}`);
                if (!r.ok) { document.getElementById('odItems').innerHTML = '<div style="padding:16px;text-align:center;color:#e55;">Không thể tải đơn hàng</div>'; return; }
                const d = await r.json();

                const statusMap = {
                    'Pending': ['Đang xử lý','#f59e0b','#fffbeb'],
                    'Confirmed': ['Đã xác nhận','#3b82f6','#eff6ff'],
                    'Shipping': ['Đang giao','#8b5cf6','#f5f3ff'],
                    'Completed': ['Hoàn tất','#10b981','#ecfdf5'],
                    'Cancelled': ['Đã hủy','#ef4444','#fef2f2']
                };
                const [stxt, scolor, sbg] = statusMap[d.status] || [d.status,'#888','#f5f5f5'];
                const stEl = document.getElementById('odStatus');
                stEl.textContent = stxt; stEl.style.color = scolor; stEl.style.background = sbg;

                // Cho phép hủy khi đơn chưa giao
                document.getElementById('odCancelWrap').style.display = (d.status === 'Pending' || d.status === 'Confirmed') ? 'block' : 'none';

                document.getElementById('odCode').textContent = '#' + d.orderCode;
                document.getElementById('odDate').textContent = d.createdAt;
                document.getElementById('odName').textContent = d.receiverName;
                document.getElementById('odPhone').textContent = d.receiverPhone;
                document.getElementById('odAddr').textContent = d.shippingAddress;
                document.getElementById('odNote').textContent = d.note ? '📝 ' + d.note : '';

                const fmt = v => Number(v).toLocaleString('vi-VN') + '₫';
                document.getElementById('odSubtotal').textContent = fmt(d.subtotal);
                document.getElementById('odShipping').textContent = d.shippingFee > 0 ? fmt(d.shippingFee) : 'Miễn phí';
                document.getElementById('odTotal').textContent = fmt(d.totalAmount);
                const vRow = document.getElementById('odVoucherRow');
                if (d.voucherDiscount > 0) {
                    document.getElementById('odVoucherDiscount').textContent = '-' + fmt(d.voucherDiscount);
                    vRow.style.display = 'flex';
                } else { vRow.style.display = 'none'; }

                const itemsEl = document.getElementById('odItems');
                if (!d.items || d.items.length === 0) { itemsEl.innerHTML = '<div style="color:#999;padding:10px;">Không có sản phẩm</div>'; return; }
                itemsEl.innerHTML = d.items.map(it => `
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;padding:10px 0;border-bottom:1px solid #f5f5f5;">
                        <div style="flex:1;">
                            <div style="font-weight:600;font-size:14px;">${it.productName}</div>
                            ${it.variantInfo ? `<div style="color:#888;font-size:12px;margin-top:2px;">${it.variantInfo}</div>` : ''}
                        </div>
                        <div style="text-align:right;min-width:140px;">
                            <div style="font-size:13px;color:#888;">${Number(it.unitPrice).toLocaleString('vi-VN')}₫ × ${it.quantity}</div>
                            <div style="font-weight:600;color:#1a1a1a;">${Number(it.lineTotal).toLocaleString('vi-VN')}₫</div>
                        </div>
                    </div>
                `).join('');
            } catch(e) {
                document.getElementById('odItems').innerHTML = '<div style="padding:16px;text-align:center;color:#e55;">Lỗi kết nối</div>';
            }
        }
        function closeOrderModal() {
            document.getElementById('orderDetailModal').style.display = 'none';
            document.body.style.overflow = '';
        }
        async function cancelOrderFromModal() {
            if (!currentOrderId) return;
            if (!confirm('Bạn có chắc muốn hủy đơn hàng này?')) return;
            const btn = document.getElementById('odCancelBtn');
            btn.disabled = true; btn.textContent = 'Đang hủy...';
            const fd = new FormData(); fd.append('orderId', currentOrderId);
            try {
                const r = await fetch('/Home/CancelOrder', { method:'POST', body: fd });
                if (r.ok) {
                    showToast('success','Đã hủy đơn','Đơn hàng đã được hủy thành công');
                    closeOrderModal();
                    setTimeout(() => location.reload(), 1000);
                } else {
                    const d = await r.json().catch(()=>({}));
                    showToast('error','Không hủy được', d.message || 'Thử lại sau');
                    btn.disabled = false; btn.innerHTML = '<i class="ti ti-x"></i> Hủy đơn hàng';
                }
            } catch {
                showToast('error','Lỗi','Thử lại sau');
                btn.disabled = false; btn.innerHTML = '<i class="ti ti-x"></i> Hủy đơn hàng';
            }
        }
        document.getElementById('orderDetailModal').addEventListener('click', e => {
            if (e.target === document.getElementById('orderDetailModal')) closeOrderModal();
        });
    </script>

    @await Html.PartialAsync("_ChatWidget")
</body>
</html>
