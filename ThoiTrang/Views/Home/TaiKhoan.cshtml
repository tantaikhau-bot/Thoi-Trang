    <script>
        // ===== Switch panel =====
        const panelTitles = {
            overview: 'Tổng quan',
            profile: 'Thông tin cá nhân',
            security: 'Bảo mật',
            orders: 'Đơn hàng',
            wishlist: 'Yêu thích',
            address: 'Địa chỉ giao hàng',
            payment: 'Phương thức thanh toán',
            voucher: 'Voucher của tôi',
            membership: 'Hạng thành viên',
            points: 'Điểm thưởng',
            notifications: 'Thông báo',
            help: 'Trợ giúp'
        };

        function switchPanel(section) {
            const targetPanel = document.querySelector(`[data-panel="${section}"]`);
            if (!targetPanel) return;

            // Update sidebar active
            document.querySelectorAll('.menu-item').forEach(item => {
                item.classList.toggle('active', item.dataset.section === section);
            });

            // Hide all panels
            document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
            // Show target
            targetPanel.classList.add('active');

            // Smooth scroll to top of content area
            const mainContainer = document.querySelector('.main-container');
            const offset = mainContainer.offsetTop - 110;
            window.scrollTo({ top: offset, behavior: 'smooth' });

            // Toast feedback
            showToast('info', panelTitles[section] || 'Chuyển trang', 'Đang xem mục: ' + (panelTitles[section] || section));
        }

        document.querySelectorAll('.menu-item[data-section]').forEach(item => {
            item.addEventListener('click', () => {
                switchPanel(item.dataset.section);
            });
        });

        // ===== Logout =====
        const logoutBtn = document.getElementById('logoutBtn');
        const logoutModal = document.getElementById('logoutModal');

        logoutBtn.addEventListener('click', () => {
            logoutModal.classList.add('show');
        });

        function closeLogoutModal() {
            logoutModal.classList.remove('show');
        }

        function confirmLogout() {
            closeLogoutModal();
            showToast('success', 'Đã đăng xuất', 'Đang chuyển về trang đăng nhập...');
            setTimeout(() => {
                window.location.href = '/Home/Logout';
            }, 1200);
        }

        logoutModal.addEventListener('click', (e) => {
            if (e.target === logoutModal) closeLogoutModal();
        });

        // ===== FAQ accordion =====
        document.querySelectorAll('.faq-question').forEach(btn => {
            btn.addEventListener('click', () => {
                const item = btn.closest('.faq-item');
                item.classList.toggle('open');
            });
        });

        // ===== Wishlist heart toggle =====
        document.querySelectorAll('.wish-heart').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const icon = btn.querySelector('i');
                icon.classList.toggle('ti-heart-filled');
                icon.classList.toggle('ti-heart');
                if (!icon.classList.contains('ti-heart-filled')) {
                    btn.closest('.wish-item').style.opacity = '0';
                    btn.closest('.wish-item').style.transition = 'opacity 0.4s';
                    setTimeout(() => btn.closest('.wish-item').remove(), 400);
                    showToast('info', 'Đã xóa khỏi yêu thích', 'Sản phẩm đã được loại bỏ');
                }
            });
        });

        // ===== Notif click marks as read =====
        document.querySelectorAll('.notif-row').forEach(row => {
            row.addEventListener('click', () => {
                row.classList.remove('unread');
            });
        });

        // ===== Point reward click =====
        document.querySelectorAll('.point-reward').forEach(card => {
            card.addEventListener('click', () => {
                const name = card.querySelector('.point-reward-name').textContent;
                const cost = card.querySelector('.point-reward-cost').textContent;
                showToast('success', 'Đổi quà thành công', `${name} · Trừ ${cost}`);
            });
        });

        // ===== Voucher card click =====
        document.querySelectorAll('.voucher-card').forEach(card => {
            card.addEventListener('click', () => {
                const code = card.querySelector('.v-title').textContent;
                if (navigator.clipboard) {
                    navigator.clipboard.writeText(code).then(() => {
                        showToast('success', 'Đã copy mã', `Mã ${code} đã được sao chép`);
                    }).catch(() => {
                        showToast('info', 'Mã voucher', code);
                    });
                } else {
                    showToast('info', 'Mã voucher', code);
                }
            });
        });

        // ===== Header scroll shadow =====
        const header = document.getElementById('header');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) header.classList.add('scrolled');
            else header.classList.remove('scrolled');
        });

        // ===== Toast =====
        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type || ''}`;
            const icons = {
                success: 'ti-circle-check',
                info: 'ti-info-circle',
                warning: 'ti-alert-circle'
            };
            toast.innerHTML = `
                <div class="toast-icon-w"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        }

        // Welcome
        setTimeout(() => {
            showToast('success', 'Chào mừng trở lại', 'Khôi Trần · VIP GOLD');
        }, 600);

        // ===== ẢNH ĐẠI DIỆN =====
        async function handleAvatarChange(input) {
            if (!input.files || !input.files[0]) return;
            const file = input.files[0];

            // Validate client-side
            if (file.size > 5 * 1024 * 1024) {
                showToast('error', 'Ảnh quá lớn', 'Vui lòng chọn ảnh nhỏ hơn 5MB');
                return;
            }
            const allowed = ['image/jpeg','image/png','image/webp','image/gif'];
            if (!allowed.includes(file.type)) {
                showToast('error', 'Định dạng không hỗ trợ', 'Chỉ hỗ trợ JPG, PNG, WebP, GIF');
                return;
            }

            // Preview ngay lập tức (local blob URL)
            const blobUrl = URL.createObjectURL(file);
            applyAvatarPreview(blobUrl);

            // Upload lên server
            const fd = new FormData();
            fd.append('avatar', file);
            try {
                const res = await fetch('/Home/UpdateAvatar', { method: 'POST', body: fd });
                if (res.status === 401) {
                    showToast('info', 'Cần đăng nhập', 'Vui lòng đăng nhập lại');
                    return;
                }
                if (!res.ok) {
                    const err = await res.json().catch(() => ({}));
                    showToast('error', 'Lỗi upload', err.message || 'Không thể tải ảnh lên');
                    return;
                }
                const d = await res.json();
                // Thay blob bằng URL thật từ server (để không bị mất khi reload)
                applyAvatarPreview(d.avatarUrl);
                showToast('success', 'Đã cập nhật ảnh', 'Ảnh đại diện mới đã được lưu ✅');
                // Hiện status trong panel
                const st = document.getElementById('avatarUploadStatus');
                if (st) { st.style.display = 'inline'; setTimeout(() => st.style.display = 'none', 3000); }
            } catch (e) {
                showToast('error', 'Lỗi kết nối', 'Thử lại sau');
            }
        }

        function applyAvatarPreview(src) {
            // Cập nhật hero avatar
            const heroImg = document.getElementById('avatarImg');
            const heroInit = document.getElementById('avatarInitials');
            const heroDisplay = document.getElementById('avatarDisplay');
            if (heroImg) {
                heroImg.src = src;
                heroImg.style.display = 'block';
                if (heroInit) heroInit.style.display = 'none';
                if (heroDisplay) {
                    heroDisplay.style.background = 'none';
                    heroDisplay.style.padding = '0';
                    heroDisplay.style.overflow = 'hidden';
                }
            }
            // Cập nhật panel avatar
            const panelImg = document.getElementById('panelAvatarImg');
            const panelInit = document.getElementById('panelAvatarInitials');
            if (panelImg) {
                panelImg.src = src;
                panelImg.style.display = 'block';
                if (panelInit) panelInit.style.display = 'none';
            }
        }
    </script>

