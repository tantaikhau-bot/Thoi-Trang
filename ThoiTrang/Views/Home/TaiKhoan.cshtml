                                <input id="a-phone" placeholder="Số điện thoại" style="padding:10px 12px;border:1px solid #e0e0db;border-radius:8px;" />
                                <input id="a-province" placeholder="Tỉnh/Thành phố" style="padding:10px 12px;border:1px solid #e0e0db;border-radius:8px;" />
                                <input id="a-district" placeholder="Quận/Huyện" style="padding:10px 12px;border:1px solid #e0e0db;border-radius:8px;" />
                                <input id="a-ward" placeholder="Phường/Xã" style="padding:10px 12px;border:1px solid #e0e0db;border-radius:8px;" />
                                <input id="a-line" placeholder="Số nhà, tên đường" style="padding:10px 12px;border:1px solid #e0e0db;border-radius:8px;" />
                                <label style="grid-column:1/-1;display:flex;align-items:center;gap:8px;font-size:13px;"><input type="checkbox" id="a-default" /> Đặt làm địa chỉ mặc định</label>
                            </div>
                            <button onclick="saveAddr()" style="margin-top:12px;padding:10px 22px;background:#1a1a1a;color:#fff;border:none;border-radius:8px;cursor:pointer;">Lưu địa chỉ</button>
                        </div>
                    </div>
                </div>
                <script>
                    function saveAddr() {
                        const fd = new FormData();
                        fd.append('receiverName', document.getElementById('a-name').value);
                        fd.append('phone', document.getElementById('a-phone').value);
                        fd.append('province', document.getElementById('a-province').value);
                        fd.append('district', document.getElementById('a-district').value);
                        fd.append('ward', document.getElementById('a-ward').value);
                        fd.append('addressLine', document.getElementById('a-line').value);
                        fd.append('isDefault', document.getElementById('a-default').checked);
                        fetch('/Home/AddAddress', { method: 'POST', body: fd })
                            .then(r => r.ok ? r.json() : Promise.reject(r))
                            .then(() => { showToast('success', 'Đã thêm địa chỉ', 'Địa chỉ đã được lưu'); setTimeout(() => location.reload(), 700); })
                            .catch(() => showToast('error', 'Lỗi', 'Vui lòng nhập đủ họ tên, SĐT, địa chỉ'));
                    }
                    function setDefaultAddr(id) {
                        const fd = new FormData(); fd.append('addressId', id);
                        fetch('/Home/SetDefaultAddress', { method: 'POST', body: fd }).then(() => location.reload());
                    }
                    function deleteAddr(id, btn) {
                        if (!confirm('Xóa địa chỉ này?')) return;
                        const fd = new FormData(); fd.append('addressId', id);
                        fetch('/Home/DeleteAddress', { method: 'POST', body: fd }).then(() => btn.closest('.address-card').remove());
                    }
                </script>
