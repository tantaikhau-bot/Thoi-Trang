                        }
                        @if (myPays != null && myPays.Count > 0)
                        {
                            foreach (var pm in myPays)
                            {
                                var picon = pm.Type switch { "momo" => "ti-wallet", "visa" => "ti-credit-card", "bank" => "ti-building-bank", _ => "ti-cash" };
                                <div class="payment-card @(pm.IsDefault ? "default" : "")">
