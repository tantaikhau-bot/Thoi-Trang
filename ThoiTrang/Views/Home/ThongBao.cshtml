    <script>
        document.querySelectorAll('.notif-item').forEach(item => {
            item.addEventListener('click', (e) => {
                if (e.target.closest('.notif-close') || e.target.closest('.notif-btn')) return;
                if (item.classList.contains('unread')) {
                    item.classList.remove('unread');
                    updateCounts();
                }
            });
        });

        function removeItem(e, btn) {
            e.stopPropagation();
            const item = btn.closest('.notif-item');
            item.classList.add('removing');
            setTimeout(() => {
                item.remove();
                cleanupEmptyGroups();
                updateCounts();
                showToast('info', 'Đã xóa thông báo', 'Thông báo đã được loại khỏi danh sách');
            }, 400);
        }

        function cleanupEmptyGroups() {
            document.querySelectorAll('.notif-group').forEach(g => {
                if (g.querySelectorAll('.notif-item').length === 0) g.remove();
            });
            if (document.querySelectorAll('.notif-item').length === 0) {
                document.getElementById('notifList').style.display = 'none';
                document.getElementById('emptyState').classList.add('show');
            }
        }

        document.querySelectorAll('.group-action').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const group = btn.closest('.notif-group');
                const unread = group.querySelectorAll('.notif-item.unread');
                if (unread.length === 0) {
                    showToast('info', 'Đã đọc hết', 'Không còn thông báo chưa đọc trong nhóm này');
                    return;
                }
                unread.forEach(item => item.classList.remove('unread'));
                updateCounts();
                showToast('success', 'Đã đánh dấu', `${unread.length} thông báo đã được đánh dấu đã đọc`);
            });
        });

        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const filter = tab.dataset.filter;

                document.querySelectorAll('.notif-item').forEach(item => {
                    if (filter === 'all') {
                        item.style.display = '';
                    } else if (filter === 'unread') {
                        item.style.display = item.classList.contains('unread') ? '' : 'none';
                    } else {
                        item.style.display = item.dataset.cat === filter ? '' : 'none';
                    }
                });

                document.querySelectorAll('.notif-group').forEach(g => {
                    const visible = Array.from(g.querySelectorAll('.notif-item')).filter(i => i.style.display !== 'none');
                    g.style.display = visible.length > 0 ? '' : 'none';
                });
            });
        });

        function markAllRead() {
            const unread = document.querySelectorAll('.notif-item.unread');
            if (unread.length === 0) {
                showToast('info', 'Đã đọc hết', 'Không còn thông báo chưa đọc');
                return;
            }
            unread.forEach(item => item.classList.remove('unread'));
            updateCounts();
            showToast('success', 'Hoàn tất', `${unread.length} thông báo đã được đánh dấu đã đọc`);
        }

        async function clearAll() {
            const items = document.querySelectorAll('.notif-item');
            if (items.length === 0) {
                showToast('info', 'Đang trống', 'Không có thông báo để xóa');
                return;
            }
            if (!confirm('Xóa tất cả thông báo của bạn?')) return;
            try {
                const r = await fetch('/Home/DeleteAllNotifications', { method: 'POST' });
                if (r.ok) {
                    showToast('success', 'Đã xóa', 'Tất cả thông báo đã được xóa');
                    setTimeout(() => location.reload(), 800);
                } else if (r.status === 401) {
                    showToast('info', 'Cần đăng nhập', 'Vui lòng đăng nhập lại');
                } else showToast('error', 'Lỗi', 'Không xóa được, thử lại sau');
            } catch { showToast('error', 'Lỗi', 'Thử lại sau'); }
        }

        function updateCounts() {
            const total = document.querySelectorAll('.notif-item').length;
            const unread = document.querySelectorAll('.notif-item.unread').length;
            document.getElementById('unreadCount').textContent = unread + ' thông báo chưa đọc';
            document.getElementById('totalNotif').textContent = total + ' thông báo';
            const badge = document.getElementById('headerNotifBadge');
            badge.textContent = unread;
            badge.style.display = unread === 0 ? 'none' : '';

            const allTab = document.querySelector('.tab[data-filter="all"] .tab-count');
            const unreadTab = document.querySelector('.tab[data-filter="unread"] .tab-count');
            if (allTab) allTab.textContent = total;
            if (unreadTab) unreadTab.textContent = unread;
        }

        const header = document.getElementById('header');
        const scrollTopBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) header.classList.add('scrolled');
            else header.classList.remove('scrolled');
            if (window.scrollY > 400) scrollTopBtn.classList.add('show');
            else scrollTopBtn.classList.remove('show');
        });
        scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        document.querySelectorAll('.toggle input').forEach(input => {
            input.addEventListener('change', () => {
                const label = input.closest('.setting-row').querySelector('.setting-label').textContent;
                showToast('info', input.checked ? 'Đã bật' : 'Đã tắt', label);
            });
        });

        document.querySelectorAll('.quick-link').forEach(link => {
            link.addEventListener('click', () => {
                const name = link.querySelector('span').textContent;
                showToast('info', 'Chuyển trang', `Đang mở: ${name}`);
            });
        });

        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icons = { success: 'ti-circle-check', info: 'ti-info-circle', warning: 'ti-alert-circle' };
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
                <button class="toast-close"><i class="ti ti-x"></i></button>
            `;
            container.appendChild(toast);
            const closeBtn = toast.querySelector('.toast-close');
            const removeToast = () => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            };
            closeBtn.addEventListener('click', removeToast);
            setTimeout(removeToast, 3500);
        }
    </script>

