    <script>
        // ===== Xóa khỏi yêu thích (lưu DB) =====
        function removeFav(e, productId, btn) {
            e.stopPropagation();
            const card = btn.closest('.product');
            const fd = new FormData();
            fd.append('productId', productId);
            fetch('/Home/RemoveFromWishlist', { method: 'POST', body: fd })
                .then(() => {
                    card.classList.add('removing');
                    setTimeout(() => {
                        card.remove();
                        // Nếu hết sản phẩm → hiện empty state
                        if (document.querySelectorAll('#wishlistGrid .product').length === 0) {
                            document.getElementById('wishlistGrid').style.display = 'none';
                            document.getElementById('emptyState').style.display = '';
                        }
                    }, 350);
                    showToast('info', 'Đã xóa', 'Sản phẩm đã được bỏ khỏi danh sách yêu thích');
                })
                .catch(() => showToast('error', 'Lỗi', 'Không thể xóa, thử lại sau'));
        }

        // ===== Mua ngay từ trang yêu thích =====
        function buyNowFromWish(name, price, bgClass, icon) {
            const order = {
                items: [{ name: name, cat: '', variant: 'Mặc định', unit: price, qty: 1, bgClass: bgClass || 'bg-cream', icon: icon || 'ti-shirt' }],
                subtotal: price, productDiscount: 0, voucher: '', voucherDiscount: 0, shipping: 30000, total: price + 30000
            };
            try { sessionStorage.setItem('monoOrder', JSON.stringify(order)); } catch (e) {}
            showToast('success', 'Tiến hành đặt hàng', 'Đang chuyển đến trang thanh toán...');
            setTimeout(() => { window.location.href = '/Home/Checkout'; }, 800);
        }

        function removeProduct(e, btn) {
            e.stopPropagation();
            const product = btn.closest('.product');
            const name = product.querySelector('.product-name').textContent;
            const rect = btn.getBoundingClientRect();
            createFloatingHeart(rect.left + rect.width / 2, rect.top + rect.height / 2);
            product.classList.add('removing');
            setTimeout(() => {
                product.remove();
                updateCounts();
                showToast('info', 'Đã xóa khỏi yêu thích', name);
            }, 400);
        }

        function createFloatingHeart(x, y) {
            for (let i = 0; i < 3; i++) {
                const heart = document.createElement('div');
                heart.className = 'float-heart';
                heart.innerHTML = '<i class="ti ti-heart-filled"></i>';
                heart.style.left = x + 'px';
                heart.style.top = y + 'px';
                heart.style.setProperty('--dx', ((Math.random() - 0.5) * 60) + 'px');
                heart.style.animationDelay = (i * 0.1) + 's';
                document.body.appendChild(heart);
                setTimeout(() => heart.remove(), 1500);
            }
        }

        function addToCart(btn, name) {
            const badge = document.getElementById('headerCartBadge');
            badge.textContent = parseInt(badge.textContent) + 1;
            badge.style.animation = 'none';
            void badge.offsetWidth;
            badge.style.animation = 'heartBeat 0.6s ease, pulse 2s infinite 0.6s';
            showToast('success', 'Thêm vào giỏ thành công', name);
        }

        function quickView(btn, name) {
            showToast('info', 'Xem nhanh', name);
        }

        function notifyMe(btn, name) {
            showToast('success', 'Đã đăng ký thông báo', `Sẽ báo khi "${name}" có hàng lại`);
        }

        function toggleInspireHeart(e, btn, productId) {
            e.preventDefault();
            e.stopPropagation();
            const fd = new FormData(); fd.append('productId', productId);
            fetch('/Home/ToggleWishlist', { method: 'POST', body: fd })
                .then(r => { if (r.status === 401) { window.location.href = '/Home/DangNhap'; return null; } return r.ok ? r.json() : Promise.reject(r); })
                .then(d => {
                    if (!d) return;
                    if (d.added) {
                        const icon = btn.querySelector('i');
                        icon.classList.remove('ti-heart'); icon.classList.add('ti-heart-filled');
                        btn.classList.add('active');
                        const rect = btn.getBoundingClientRect();
                        createFloatingHeart(rect.left + rect.width / 2, rect.top + rect.height / 2);
                        showToast('success', 'Đã thêm yêu thích', 'Tải lại danh sách...');
                        setTimeout(() => location.reload(), 800);
                    } else {
                        showToast('info', 'Đã bỏ yêu thích', '');
                    }
                })
                .catch(() => showToast('error', 'Lỗi', 'Thử lại sau'));
        }

        document.querySelectorAll('.pill').forEach(pill => {
            pill.addEventListener('click', () => {
                document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
                pill.classList.add('active');
                const filter = pill.dataset.filter;
                document.querySelectorAll('.product').forEach(p => {
                    if (filter === 'all' || p.dataset.cat.includes(filter)) {
                        p.style.display = '';
                    } else {
                        p.style.display = 'none';
                    }
                });
            });
        });

        document.querySelectorAll('.view-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });

        function addAllToCart() {
            const count = document.querySelectorAll('.product').length;
            if (count === 0) {
                showToast('warning', 'Không có sản phẩm', 'Danh sách yêu thích đang trống');
                return;
            }
            const badge = document.getElementById('headerCartBadge');
            badge.textContent = parseInt(badge.textContent) + count;
            badge.style.animation = 'none';
            void badge.offsetWidth;
            badge.style.animation = 'heartBeat 0.6s ease, pulse 2s infinite 0.6s';
            showToast('success', `Đã thêm ${count} sản phẩm`, 'Tất cả đã được thêm vào giỏ hàng');
        }

        async function clearAll() {
            if (!confirm('Xóa tất cả sản phẩm khỏi danh sách yêu thích?')) return;
            try {
                const r = await fetch('/Home/ClearWishlist', { method: 'POST' });
                if (r.ok) {
                    showToast('success', 'Đã xóa', 'Đã xóa tất cả sản phẩm yêu thích');
                    setTimeout(() => location.reload(), 800);
                } else if (r.status === 401) {
                    showToast('info', 'Cần đăng nhập', 'Vui lòng đăng nhập lại');
                } else showToast('error', 'Lỗi', 'Không xóa được, thử lại sau');
            } catch { showToast('error', 'Lỗi', 'Thử lại sau'); }
        }

        function shareWishlist() {
            showToast('success', 'Link đã được sao chép', 'Chia sẻ danh sách yêu thích của bạn');
        }

        function updateCounts() {
            const products = document.querySelectorAll('.product');
            const count = products.length;
            document.getElementById('totalCount').textContent = count + ' sản phẩm';
            let total = 0;
            products.forEach(p => {
                const price = p.querySelector('.price-current').textContent.replace(/\D/g, '');
                total += parseInt(price) || 0;
            });
            document.getElementById('totalValue').textContent = total.toLocaleString('vi-VN') + '₫';
            const allPill = document.querySelector('.pill[data-filter="all"] .pill-count');
            if (allPill) allPill.textContent = count;
            if (count === 0) {
                document.getElementById('wishlistGrid').style.display = 'none';
                document.getElementById('emptyState').classList.add('show');
            }
        }

        const header = document.getElementById('header');
        const scrollTopBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) header.classList.add('scrolled');
            else header.classList.remove('scrolled');
            if (window.scrollY > 400) scrollTopBtn.classList.add('show');
            else scrollTopBtn.classList.remove('show');
        });
        scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        function showToast(type, title, desc) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icons = { success: 'ti-circle-check', info: 'ti-info-circle', warning: 'ti-alert-circle' };
            toast.innerHTML = `
                <div class="toast-icon"><i class="ti ${icons[type] || 'ti-bell'}"></i></div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-desc">${desc}</div>
                </div>
                <button class="toast-close"><i class="ti ti-x"></i></button>
            `;
            container.appendChild(toast);
            const closeBtn = toast.querySelector('.toast-close');
            const removeToast = () => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            };
            closeBtn.addEventListener('click', removeToast);
            setTimeout(removeToast, 3500);
        }

        updateCounts();
    </script>

    <script src="/js/search.js"></script>
    @await Html.PartialAsync("_ChatWidget")
</body>
</html>
