@if (!User.IsInRole("Admin"))
{
    <style>
        .mono-chat-fab { position: fixed; right: 24px; bottom: 24px; width: 60px; height: 60px; border-radius: 50%; background: linear-gradient(135deg, #d4537e, #e2856b); color: #fff; border: none; cursor: pointer; box-shadow: 0 8px 24px rgba(212,83,126,.45); display: flex; align-items: center; justify-content: center; font-size: 26px; z-index: 9998; transition: transform .25s; }
        .mono-chat-fab:hover { transform: scale(1.1) rotate(-6deg); }
        .mono-chat-fab .mono-chat-dot { position: absolute; top: 8px; right: 10px; width: 12px; height: 12px; background: #2eb872; border: 2px solid #fff; border-radius: 50%; display: none; }
        .mono-chat-fab .mono-chat-dot.show { display: block; }
        .mono-chat-panel { position: fixed; right: 24px; bottom: 96px; width: 350px; max-width: calc(100vw - 32px); height: 480px; max-height: calc(100vh - 130px); background: #fff; border-radius: 18px; box-shadow: 0 18px 50px rgba(0,0,0,.22); z-index: 9999; display: none; flex-direction: column; overflow: hidden; animation: monoChatIn .25s ease; }
        .mono-chat-panel.open { display: flex; }
        @@keyframes monoChatIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .mono-chat-head { background: linear-gradient(135deg, #1a1a1a, #2c2c2a); color: #fff; padding: 16px 18px; display: flex; align-items: center; gap: 12px; }
        .mono-chat-head .av { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, #d4537e, #e2856b); display: flex; align-items: center; justify-content: center; font-size: 18px; }
        .mono-chat-head .info { flex: 1; }
        .mono-chat-head .nm { font-size: 14px; font-weight: 600; }
        .mono-chat-head .st { font-size: 11px; color: #2eb872; display: flex; align-items: center; gap: 5px; }
        .mono-chat-head .st::before { content: ''; width: 7px; height: 7px; background: #2eb872; border-radius: 50%; }
        .mono-chat-head .cls { background: none; border: none; color: rgba(255,255,255,.7); font-size: 20px; cursor: pointer; }
        .mono-chat-body { flex: 1; overflow-y: auto; padding: 16px; background: #f7f7f5; display: flex; flex-direction: column; gap: 10px; }
        .mono-msg { max-width: 80%; padding: 9px 13px; border-radius: 14px; font-size: 13px; line-height: 1.5; word-wrap: break-word; }
        .mono-msg.them { background: #fff; border: 1px solid #eee; align-self: flex-start; border-bottom-left-radius: 4px; }
        .mono-msg.me { background: #1a1a1a; color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }
        .mono-chat-prod { align-self: flex-start; width: 80%; display: flex; gap: 10px; background: #fff; border: 1px solid #eee; border-radius: 12px; padding: 8px; text-decoration: none; color: #1a1a1a; }
        .mono-chat-prod .ci { width: 46px; height: 46px; border-radius: 8px; background: #f1efe8; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: rgba(0,0,0,.3); font-size: 22px; }
        .mono-chat-prod .cn { font-size: 12.5px; font-weight: 600; }
        .mono-chat-prod .cp { font-size: 12.5px; color: #d4537e; font-weight: 600; }
        .mono-chat-prod .cc { font-size: 10px; color: #999; text-transform: uppercase; }
        .mono-chat-cta { align-self: flex-start; display: inline-flex; gap: 6px; align-items: center; background: linear-gradient(135deg,#d4537e,#e2856b); color: #fff; padding: 9px 16px; border-radius: 999px; font-size: 13px; font-weight: 600; text-decoration: none; cursor: pointer; }
        .mono-chat-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 2px; }
        .mono-chat-chip { background: #fff; border: 1px solid #f0c9d6; color: #d4537e; padding: 7px 12px; border-radius: 999px; font-size: 12px; cursor: pointer; transition: all .2s; }
        .mono-chat-chip:hover { background: #d4537e; color: #fff; border-color: #d4537e; }
        .mono-chat-foot { display: flex; gap: 8px; padding: 12px; border-top: 1px solid #eee; background: #fff; }
        .mono-chat-foot input { flex: 1; border: 1px solid #e0e0db; border-radius: 999px; padding: 10px 16px; font-size: 13px; outline: none; }
        .mono-chat-foot input:focus { border-color: #1a1a1a; }
        .mono-chat-foot button { width: 40px; height: 40px; border-radius: 50%; background: #d4537e; color: #fff; border: none; cursor: pointer; font-size: 18px; flex-shrink: 0; }
    </style>

    <button class="mono-chat-fab" id="monoChatFab" title="Chat với shop" onclick="monoToggleChat()">
        <i class="ti ti-message-circle"></i>
        <span class="mono-chat-dot" id="monoChatDot"></span>
    </button>

    <div class="mono-chat-panel" id="monoChatPanel">
        <div class="mono-chat-head">
            <div class="av"><i class="ti ti-headset"></i></div>
            <div class="info">
                <div class="nm">MONO.WEAR Support</div>
                <div class="st">Trợ lý ảo · Phản hồi ngay</div>
            </div>
            <button class="cls" onclick="monoToggleChat()"><i class="ti ti-x"></i></button>
        </div>
        <div class="mono-chat-body" id="monoChatBody"></div>
        <div class="mono-chat-foot">
            <input type="text" id="monoChatInput" placeholder="Nhập tin nhắn..." onkeydown="if(event.key==='Enter')monoSendChat()" />
            <button onclick="monoSendChat()"><i class="ti ti-send"></i></button>
        </div>
    </div>

    <script>
        var MONO_LOGGEDIN = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
        var MONO_AUTOREPLY = true;
        var monoChatOpen = false, monoGreeted = false, monoLastDbCount = 0;

        function monoEsc(s) { return (s || '').replace(/[&<>]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]; }); }
        function monoBody() { return document.getElementById('monoChatBody'); }
        function monoScroll() { var b = monoBody(); b.scrollTop = b.scrollHeight; }

        function monoAppend(side, text) {
            var d = document.createElement('div');
            d.className = 'mono-msg ' + side;
            d.innerHTML = monoEsc(text);
            monoBody().appendChild(d); monoScroll();
        }
        function monoAppendProducts(list) {
            (list || []).forEach(function (p) {
                var a = document.createElement('a');
                a.className = 'mono-chat-prod';
                a.href = '/Home/CTSP/' + p.id;
                a.innerHTML = '<div class="ci"><i class="ti ti-shirt"></i></div><div><div class="cc">' + monoEsc(p.category) + '</div><div class="cn">' + monoEsc(p.name) + '</div><div class="cp">' + (p.price || 0).toLocaleString('vi-VN') + '₫</div></div>';
                monoBody().appendChild(a);
            });
            monoScroll();
        }
        function monoAppendCta(text, href, onclick) {
            var a = document.createElement(href ? 'a' : 'button');
            a.className = 'mono-chat-cta';
            if (href) a.href = href;
            if (onclick) a.onclick = onclick;
            a.innerHTML = '<i class="ti ti-arrow-right"></i>' + text;
            monoBody().appendChild(a); monoScroll();
        }

        function monoAppendChips(chips) {
            if (!chips || !chips.length) return;
            var wrap = document.createElement('div');
            wrap.className = 'mono-chat-chips';
            chips.forEach(function (c) {
                var b = document.createElement('button');
                b.className = 'mono-chat-chip';
                b.textContent = c;
                b.onclick = function () { document.getElementById('monoChatInput').value = c; monoSendChat(); };
                wrap.appendChild(b);
            });
            monoBody().appendChild(wrap); monoScroll();
        }

        function monoGreet() {
            if (monoGreeted) return; monoGreeted = true;
            monoAppend('them', 'Dạ em chào anh/chị 👋 Em là trợ lý ảo MONO.WEAR. Em giúp được gì cho mình ạ?');
            monoAppendChips(['Sản phẩm bán chạy 🔥', 'Đang khuyến mãi 🎁', 'Theo dõi đơn 📦', 'Tư vấn chọn size 📏', 'Địa chỉ cửa hàng 📍']);
        }

        function monoToggleChat() {
            monoChatOpen = !monoChatOpen;
            document.getElementById('monoChatPanel').classList.toggle('open', monoChatOpen);
            if (monoChatOpen) {
                document.getElementById('monoChatDot').classList.remove('show');
                if (MONO_LOGGEDIN) monoLoadDb(); else monoGreet();
                document.getElementById('monoChatInput').focus();
            }
        }

        // Lịch sử chat thật (nếu đã đăng nhập, để admin/khách nhắn qua lại)
        function monoLoadDb() {
            fetch('/Home/GetMessages').then(function (r) { return r.ok ? r.json() : []; }).then(function (msgs) {
                if (!monoBody().querySelector('.mono-msg') && msgs.length === 0) { monoGreet(); return; }
                if (!monoBody().hasChildNodes()) {
                    msgs.forEach(function (m) { monoAppend(m.fromAdmin ? 'them' : 'me', m.content); });
                    monoLastDbCount = msgs.length;
                    if (msgs.length === 0) monoGreet();
                }
            }).catch(monoGreet);
        }

        function monoSendChat() {
            var inp = document.getElementById('monoChatInput');
            var txt = inp.value.trim(); if (!txt) return;
            inp.value = '';
            monoAppend('me', txt);
            // Lưu DB nếu đã đăng nhập (để admin thấy)
            if (MONO_LOGGEDIN) { var fd = new FormData(); fd.append('content', txt); fetch('/Home/SendMessage', { method: 'POST', body: fd }); }
            // Bot tự trả lời
            if (MONO_AUTOREPLY) {
                var fb = new FormData(); fb.append('message', txt);
                fetch('/Home/ChatBotReply', { method: 'POST', body: fb })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (d) {
                        if (!d) return;
                        monoAppend('them', d.reply);
                        if (d.products && d.products.length) monoAppendProducts(d.products);
                        if (d.needLogin) {
                            monoAppendCta('Đăng nhập để chốt đơn', '/Home/DangNhap');
                        } else if (d.checkout && d.addProductId) {
                            var fc = new FormData(); fc.append('productId', d.addProductId);
                            fetch('/Home/AddProductToCart', { method: 'POST', body: fc })
                                .then(function () { monoAppendCta('Đến trang thanh toán', '/Home/Checkout'); });
                        }
                        if (d.chips && d.chips.length) monoAppendChips(d.chips);
                    });
            }
        }

        // Lấy cấu hình autoreply
        fetch('/Home/ChatConfig').then(function (r) { return r.ok ? r.json() : null; }).then(function (c) { if (c) MONO_AUTOREPLY = c.autoreply; }).catch(function () {});

        // ===== Cập nhật badge header (chỉ khi đã đăng nhập) =====
        function monoSetBadge(el, n) { if (!el) return; if (n > 0) { el.textContent = n; el.style.display = ''; } else { el.style.display = 'none'; } }
        function monoEnsureWishBadge() {
            if (document.querySelector('.wish-badge')) return;
            var link = null;
            document.querySelectorAll('a').forEach(function (a) {
                if (link) return;
                var href = a.getAttribute('href') || '';
                if (href.indexOf('/Home/YeuThich') >= 0 && a.querySelector('i.ti-heart')) link = a;
            });
            if (!link) return;
            link.style.position = 'relative';
            var b = document.createElement('span'); b.className = 'wish-badge';
            b.style.cssText = 'position:absolute;top:-6px;right:-8px;background:#d4537e;color:#fff;font-size:10px;min-width:18px;height:18px;border-radius:50%;display:none;align-items:center;justify-content:center;padding:0 4px;font-family:sans-serif;';
            link.appendChild(b);
        }
        function monoSetWishBadge(el, n) { if (!el) return; if (n > 0) { el.textContent = n; el.style.display = 'inline-flex'; } else { el.style.display = 'none'; } }
        function monoUpdateBadges() {
            if (!MONO_LOGGEDIN) return;
            fetch('/Home/Counts').then(function (r) { return r.ok ? r.json() : null; }).then(function (d) {
                if (!d) return;
                document.querySelectorAll('.notif-badge').forEach(function (e) { monoSetBadge(e, d.notif); });
                document.querySelectorAll('.cart-badge, #headerCartBadge').forEach(function (e) { monoSetBadge(e, d.cart); });
                monoEnsureWishBadge();
                document.querySelectorAll('.wish-badge, #wishBadge').forEach(function (e) { monoSetWishBadge(e, d.wishlist); });
            }).catch(function () {});
        }
        monoUpdateBadges();
        setInterval(monoUpdateBadges, 10000);

        // Poll tin nhắn admin mới (chỉ khi đã đăng nhập, báo chấm xanh)
        if (MONO_LOGGEDIN) {
            setInterval(function () {
                fetch('/Home/GetMessages').then(function (r) { return r.ok ? r.json() : []; }).then(function (msgs) {
                    if (!monoChatOpen && msgs.length > monoLastDbCount) {
                        var last = msgs[msgs.length - 1];
                        if (last && last.fromAdmin) document.getElementById('monoChatDot').classList.add('show');
                    }
                    monoLastDbCount = msgs.length;
                }).catch(function () {});
            }, 7000);
        }
    </script>
}
